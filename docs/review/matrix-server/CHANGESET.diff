+      LETSENCRYPT_EMAIL: webmaster@maier.wtf
+    entrypoint: ["/bin/sh", "-ec"]
+    command: |
+      test -s /run/secrets/synapse_postgres_password
+      test -s /run/secrets/synapse_signing_key
+      test -s /run/secrets/synapse_turn_shared_secret
+      umask 077
+      python3 - <<'PY'
+      from pathlib import Path
+      import yaml
+
+      template_path = Path("/etc/synapse/homeserver.yaml.example")
+      output_path = Path("/run/synapse/homeserver.yaml")
+      password_path = Path("/run/secrets/synapse_postgres_password")
+      signing_key_path = Path("/run/secrets/synapse_signing_key")
+      turn_secret_path = Path("/run/secrets/synapse_turn_shared_secret")
+      runtime_signing_key_path = Path("/run/synapse/signing.key")
+
+      config = yaml.safe_load(template_path.read_text(encoding="utf-8"))
+      password = password_path.read_text(encoding="utf-8").strip()
+      turn_secret = turn_secret_path.read_text(encoding="utf-8").strip()
+      if not password:
+          raise SystemExit("PostgreSQL password secret is empty")
+      if not turn_secret:
+          raise SystemExit("TURN shared secret is empty")
+      config["database"]["args"]["password"] = password
+      config["turn_shared_secret"] = turn_secret
+      runtime_signing_key_path.write_bytes(signing_key_path.read_bytes())
+      config["signing_key_path"] = str(runtime_signing_key_path)
+      output_path.write_text(
+          yaml.safe_dump(config, sort_keys=False),
+          encoding="utf-8",
+      )
+      PY
+      chown 991:991 /run/synapse /run/synapse/homeserver.yaml /run/synapse/signing.key
+      exec /start.py run --config-path /run/synapse/homeserver.yaml
+    healthcheck:
+      test: ["CMD", "python3", "-c", "import urllib.request; urllib.request.urlopen('http://localhost:8008/health', timeout=5)"]
+      interval: 15s
+      timeout: 10s
+      retries: 5
+      start_period: 60s
+    mem_limit: 1536m
+    cpus: "2.0"
+    security_opt:
+      - no-new-privileges:true
+    logging:
+      driver: json-file
+      options:
+        max-size: "10m"
+        max-file: "7"
+    secrets:
+      - synapse_postgres_password
+      - synapse_signing_key
+      - synapse_turn_shared_secret
+    tmpfs:
+      - /run/synapse:rw,noexec,nosuid,nodev,size=1m,mode=0750
+    expose:
+      - "8008"
+    volumes:
+      - synapse_data:/data
+      - synapse_media:/media
+      - ../synapse/synapse.yaml.example:/etc/synapse/homeserver.yaml.example:ro
+    networks:
+      - frontproxy_default
+      - synapse_internal
+
+volumes:
+  synapse_data:
+    driver_opts:
+      type: none
+      device: /mnt/hardDrive/docker/synapse/data
+      o: bind
+  synapse_media:
+    driver_opts:
+      type: none
+      device: /mnt/hardDrive/docker/synapse/media
+      o: bind
+  synapse_db:
+    driver_opts:
+      type: none
+      device: /mnt/hardDrive/docker/synapse/db
+      o: bind
+
+networks:
+  frontproxy_default:
+    external: true
+  synapse_internal:
+    internal: true
+
+secrets:
