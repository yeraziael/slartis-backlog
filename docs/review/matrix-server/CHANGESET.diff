new file mode 100644
index 0000000..3bc872b
--- /dev/null
+++ b/runtime/messaging/router.py
@@ -0,0 +1,142 @@
+#!/usr/bin/env python3
+"""Map channel inputs to Envelope v1 and parse channel-neutral commands."""
+
+import argparse
+import hashlib
+import json
+import re
+import sys
+
+import validate_envelope
+
+
+CHANNEL_PREFIX = {"telegram": "tg", "signal": "sig", "matrix": "mx"}
+MESSAGE_ID = re.compile(r"^[a-z]+-[a-z0-9]+-[A-Za-z0-9._~-]+$")
+
+
+class RoutingError(ValueError):
+    """Raised when a channel message cannot safely enter Lydia core."""
+
+
+def route(message):
+    """Return an Envelope v1 plus a channel-neutral command parse."""
+    if not isinstance(message, dict):
+        raise RoutingError("message must be an object")
+    envelope = dict(message) if message.get("envelope_version") == 1 else _legacy_envelope(message)
+    errors = validate_envelope.validate(envelope)
+    if errors:
+        raise RoutingError(f"invalid envelope: {errors[0]}")
+
+    text = envelope["text"]
+    parts = text.strip().split(maxsplit=1)
+    command = parts[0].lower() if parts and parts[0].startswith("/") else ""
+    arguments = parts[1] if command and len(parts) == 2 else ""
+    return {"envelope": envelope, "command": command, "arguments": arguments}
+
+
+def _legacy_envelope(message):
+    channel = message.get("channel")
+    if channel not in {"telegram", "signal"}:
+        raise RoutingError("unsupported channel")
+    bot = _string(message.get("bot"), "lydia")
+    target_id = _string(message.get("chat_id"))
+    if not target_id:
+        raise RoutingError("message requires a target ID")
+    prefix = CHANNEL_PREFIX[channel]
+    raw_id = _string(message.get("id"))
+    if not raw_id:
+        raw_id = ":".join(
+            (
+                channel,
+                bot,
+                target_id,
+                str(message.get("timestamp", "")),
+                str(message.get("message_id", "")),
+            )
+        )
+    message_id = raw_id if MESSAGE_ID.fullmatch(raw_id) else _safe_message_id(prefix, bot, raw_id)
+    timestamp = _timestamp(message.get("timestamp"), channel)
+    sender_name = _string(message.get("sender"))
+
+    envelope = {
+        "envelope_version": 1,
+        "message_id": message_id,
+        "trace_id": f"trace-{message_id}",
+        "origin_id": f"{prefix}-{bot}",
+        "channel": channel,
+        "sender": {"id": target_id},
+        "target": {"id": target_id, "type": "private"},
+        "text": _string(message.get("text")),
+        "timestamp": timestamp,
+        "attachments": _attachments(message.get("attachments")),
+        "hops": [],
+        "metadata": {"bot": bot},
+    }
+    if sender_name:
+        envelope["sender"]["name"] = sender_name
+    platform_message_id = message.get("message_id")
+    if isinstance(platform_message_id, int) and not isinstance(platform_message_id, bool):
+        envelope["metadata"]["message_id"] = platform_message_id
+    reply_id = message.get("reply_to_message_id")
+    if reply_id not in (None, ""):
+        envelope["reply_to"] = {"message_id": str(reply_id)}
+    return envelope
+
+
+def _safe_message_id(prefix, bot, raw_id):
+    safe_bot = re.sub(r"[^a-z0-9]", "", bot.lower()) or "lydia"
+    digest = hashlib.sha256(raw_id.encode("utf-8")).hexdigest()[:16]
+    return f"{prefix}-{safe_bot}-{digest}"
+
+
+def _timestamp(value, channel):
+    if value in (None, ""):
+        return 0
+    try:
+        timestamp = int(value)
+    except (TypeError, ValueError) as exc:
+        raise RoutingError("message timestamp must be an integer") from exc
+    if timestamp < 0:
+        raise RoutingError("message timestamp must not be negative")
+    if channel == "signal" and timestamp > 99_999_999_999:
+        timestamp //= 1000
+    return timestamp
+
+
+def _attachments(value):
+    if value in (None, "", "[]"):
+        return []
+    if not isinstance(value, list):
+        raise RoutingError("message attachments must be an array")
+    sanitized = []
+    for attachment in value:
+        if not isinstance(attachment, dict):
+            raise RoutingError("attachment must be an object")
+        item = {}
+        for field in ("content_uri", "content_type", "filename", "size_bytes", "sha256"):
+            if field in attachment:
+                item[field] = attachment[field]
+        sanitized.append(item)
+    return sanitized
+
+
+def _string(value, default=""):
+    return value if isinstance(value, str) else default
+
+
+def main():
+    parser = argparse.ArgumentParser(description=__doc__)
+    parser.add_argument("--envelope", action="store_true", help="print only Envelope v1")
+    args = parser.parse_args()
+    try:
+        result = route(json.load(sys.stdin))
+    except (json.JSONDecodeError, RoutingError) as exc:
+        print(f"routing failed: {exc}", file=sys.stderr)
+        return 1
+    json.dump(result["envelope"] if args.envelope else result, sys.stdout, separators=(",", ":"))
+    sys.stdout.write("\n")
+    return 0
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
