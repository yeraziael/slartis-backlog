@@ -0,0 +1,251 @@
+#!/usr/bin/env bash
+# Static contract tests for the production-shaped Synapse Compose stack.
+set -uo pipefail
+
+REPO_ROOT="$(cd "$(dirname "$0")/../.." && pwd)"
+COMPOSE_FILE="$REPO_ROOT/pi/compose/synapse.yml"
+CONFIG_FILE="$REPO_ROOT/pi/synapse/synapse.yaml.example"
+ENV_FILE="$REPO_ROOT/pi/synapse/synapse.env.example"
+PROXY_DOC="$REPO_ROOT/docs/matrix/proxy.md"
+
+python3 - "$COMPOSE_FILE" "$CONFIG_FILE" "$ENV_FILE" "$PROXY_DOC" <<'PY'
+from pathlib import Path
+import os
+import subprocess
+import sys
+import tempfile
+
+import yaml
+
+paths = [Path(raw_path) for raw_path in sys.argv[1:]]
+
+for path in paths:
+    if not path.is_file():
+        raise SystemExit(f"FAIL: required input missing: {path}")
+    with path.open(encoding="utf-8") as handle:
+        if path.suffix in {".yml", ".yaml", ".example"} and "env.example" not in path.name:
+            yaml.safe_load(handle)
+    print(f"PASS: required input exists: {path.name}")
+
+
+def require(condition, message):
+    if not condition:
+        raise SystemExit(f"FAIL: {message}")
+    print(f"PASS: {message}")
+
+
+with paths[0].open(encoding="utf-8") as handle:
+    compose = yaml.safe_load(handle)
+
+services = compose.get("services", {})
+require(set(services) == {"synapse", "postgres"}, "stack defines only Synapse and PostgreSQL")
+
+for name in ("synapse", "postgres"):
+    service = services[name]
+    image = service.get("image", "")
+    require("@sha256:" in image and ":latest" not in image, f"{name} image is digest-pinned")
+    require(service.get("platform") == "linux/arm64", f"{name} is explicitly ARM64")
+    require(service.get("restart") == "unless-stopped", f"{name} has restart policy")
+    require("healthcheck" in service, f"{name} has a healthcheck")
+    require("mem_limit" in service and "cpus" in service, f"{name} has CPU and memory limits")
+    require("ports" not in service, f"{name} publishes no host port")
+
+synapse_networks = set(services["synapse"].get("networks", []))
+postgres_networks = set(services["postgres"].get("networks", []))
+require(
+    synapse_networks == {"frontproxy_default", "synapse_internal"},
+    "only Synapse joins frontproxy and the private DB network",
+)
+require(postgres_networks == {"synapse_internal"}, "PostgreSQL joins only the private DB network")
+require(compose.get("networks", {}).get("frontproxy_default", {}).get("external") is True,
+        "frontproxy network is external")
+require(compose.get("networks", {}).get("synapse_internal", {}).get("internal") is True,
+        "database network is internal")
+require(services["synapse"].get("depends_on", {}).get("postgres", {}).get("condition") == "service_healthy",
+        "Synapse waits for healthy PostgreSQL")
+
+secrets = compose.get("secrets", {})
+require(set(secrets) == {"synapse_postgres_password", "synapse_signing_key", "synapse_turn_shared_secret"},
+        "stack declares only the required external secret files")
+for name, variable in (
+    ("synapse_postgres_password", "SYNAPSE_POSTGRES_PASSWORD_FILE"),
+    ("synapse_signing_key", "SYNAPSE_SIGNING_KEY_FILE"),
+    ("synapse_turn_shared_secret", "SYNAPSE_TURN_SHARED_SECRET_FILE"),
+):
+    source = secrets[name].get("file", "")
+    require(variable in source and "/home/michael/matrix/secrets/" in source,
+            f"{name} uses an overridable external host file")
+
+postgres_environment = services["postgres"].get("environment", {})
+require("POSTGRES_PASSWORD" not in postgres_environment, "PostgreSQL has no plaintext password variable")
+require(postgres_environment.get("POSTGRES_PASSWORD_FILE") == "/run/secrets/synapse_postgres_password",
+        "PostgreSQL consumes its mounted password file")
+require(set(services["postgres"].get("secrets", [])) == {"synapse_postgres_password"},
+        "PostgreSQL receives only its password secret")
+require(set(services["synapse"].get("secrets", [])) ==
+        {"synapse_postgres_password", "synapse_signing_key", "synapse_turn_shared_secret"},
+        "Synapse receives only its database password, signing key and TURN secret")
+
+synapse_environment = services["synapse"].get("environment", {})
+proxy_environment = {
+    "VIRTUAL_HOST": "matrix.hl.maier.wtf",
+    "VIRTUAL_PORT": "8008",
+    "LETSENCRYPT_HOST": "matrix.hl.maier.wtf",
+    "LETSENCRYPT_EMAIL": "webmaster@maier.wtf",
+}
+require(all(synapse_environment.get(key) == value for key, value in proxy_environment.items()),
+        "Synapse declares the frontproxy and ACME environment")
+require(all(key not in postgres_environment for key in proxy_environment),
+        "PostgreSQL declares no frontproxy or ACME environment")
+require(set(services["synapse"].get("expose", [])) == {"8008"},
+        "Synapse exposes only internal port 8008")
+
+command = services["synapse"].get("command", "")
+entrypoint = services["synapse"].get("entrypoint", [])
+require(entrypoint == ["/bin/sh", "-ec"], "Synapse uses a fail-fast pre-start entrypoint")
+for required in (
+    "test -s /run/secrets/synapse_postgres_password",
+    "test -s /run/secrets/synapse_signing_key",
+    "test -s /run/secrets/synapse_turn_shared_secret",
+    'config["database"]["args"]["password"] = password',
+    'config["turn_shared_secret"] = turn_secret',
+    'runtime_signing_key_path = Path("/run/synapse/signing.key")',
+    'runtime_signing_key_path.write_bytes(signing_key_path.read_bytes())',
+    'config["signing_key_path"] = str(runtime_signing_key_path)',
+    "/run/synapse/homeserver.yaml",
+    "chown 991:991 /run/synapse /run/synapse/homeserver.yaml /run/synapse/signing.key",
+    "exec /start.py run --config-path /run/synapse/homeserver.yaml",
+):
+    require(required in command, f"Synapse pre-start contract contains: {required}")
+require("/run/synapse" in str(services["synapse"].get("tmpfs", [])),
+        "rendered Synapse config lives on tmpfs")
+
+for name in ("synapse", "postgres"):
+    require("no-new-privileges:true" in services[name].get("security_opt", []),
+            f"{name} enables no-new-privileges")
+    logging = services[name].get("logging", {}).get("options", {})
+    require(logging.get("max-size") == "10m" and logging.get("max-file") == "7",
+            f"{name} has bounded JSON-file logs")
+
+with paths[1].open(encoding="utf-8") as handle:
+    config = yaml.safe_load(handle)
+
+require(config.get("server_name") == "matrix.hl.maier.wtf", "homeserver uses the Matrix service name")
+require(config.get("public_baseurl") == "https://matrix.hl.maier.wtf/",
+        "homeserver declares its public HTTPS base URL")
+require(config.get("enable_registration") is False and
+        config.get("enable_registration_without_verification") is False,
+        "public registration is disabled")
+database = config.get("database", {})
+require(database.get("name") == "psycopg2" and database.get("args", {}).get("host") == "postgres",
+        "homeserver uses the private PostgreSQL service")
+require("password" not in database.get("args", {}), "versioned homeserver config contains no DB password")
+require(config.get("signing_key_path") == "/run/secrets/synapse_signing_key",
+        "homeserver reads its signing key from the mounted secret")
+require(set(config.get("turn_uris", [])) == {
+            "turn:turn.hl.maier.wtf:3478?transport=udp",
+            "turn:turn.hl.maier.wtf:3478?transport=tcp",
+            "turns:turn.hl.maier.wtf:5349?transport=tcp",
+        }, "homeserver advertises only the documented TURN listeners")
+require("turn_shared_secret" not in config, "versioned homeserver config contains no TURN secret")
+require(config.get("turn_user_lifetime") == 3600000 and config.get("turn_allow_guests") is False,
+        "TURN credentials live for one hour and are unavailable to guests")
+listeners = config.get("listeners", [])
+resource_names = {
+    resource
+    for listener in listeners
+    for group in listener.get("resources", [])
+    for resource in group.get("names", [])
+}
+require(resource_names == {"client"}, "homeserver listener exposes only client resources")
+require(all(listener.get("x_forwarded") is True for listener in listeners),
+        "homeserver trusts proxy headers on every listener")
+require(all(listener.get("tls") is False and listener.get("port") == 8008 for listener in listeners),
+        "homeserver exposes only internal HTTP on port 8008")
+
+proxy_doc = paths[3].read_text(encoding="utf-8")
+for required in (
+    "https://matrix.hl.maier.wtf/_matrix/client/versions",
+    "openssl s_client -connect matrix.hl.maier.wtf:443 -servername matrix.hl.maier.wtf",
+    "docker inspect --format '{{json .HostConfig.PortBindings}}'",
+):
+    require(required in proxy_doc, f"proxy smoke documentation contains: {required}")
+
+env_values = {}
+for line in paths[2].read_text(encoding="utf-8").splitlines():
+    line = line.strip()
+    if not line or line.startswith("#"):
+        continue
+    key, value = line.split("=", 1)
+    env_values[key] = value
+require(set(env_values) == {
+            "SYNAPSE_POSTGRES_PASSWORD_FILE",
+            "SYNAPSE_SIGNING_KEY_FILE",
+            "SYNAPSE_TURN_SHARED_SECRET_FILE",
+        },
+        "environment example contains only external secret path overrides")
+require(all(value.startswith("/home/michael/matrix/secrets/") for value in env_values.values()),
+        "environment example contains absolute non-secret host paths")
+
+with tempfile.TemporaryDirectory() as temporary_directory:
+    temporary = Path(temporary_directory)
+    password_path = temporary / "postgres_password"
+    signing_key_path = temporary / "signing_key"
+    turn_secret_path = temporary / "turn_shared_secret"
+    rendered_path = temporary / "homeserver.yaml"
+    runtime_signing_key_path = temporary / "runtime_signing_key"
+
+    isolated_command = command.replace(
+        "/run/secrets/synapse_postgres_password", str(password_path)
+    ).replace(
+        "/run/secrets/synapse_signing_key", str(signing_key_path)
+    ).replace(
+        "/run/secrets/synapse_turn_shared_secret", str(turn_secret_path)
+    ).replace(
+        "/etc/synapse/homeserver.yaml.example", str(paths[1])
+    ).replace(
+        "/run/synapse/homeserver.yaml", str(rendered_path)
+    ).replace(
+        "/run/synapse/signing.key", str(runtime_signing_key_path)
+    ).replace(
+        f"chown 991:991 /run/synapse {rendered_path} {runtime_signing_key_path}",
+        f"test -s {rendered_path} && test -s {runtime_signing_key_path}",
+    ).replace(
+        f"exec /start.py run --config-path {rendered_path}", ":"
+    )
+
+    missing_result = subprocess.run(
+        ["/bin/sh", "-ec", isolated_command],
+        text=True,
+        capture_output=True,
+        check=False,
+    )
+    require(missing_result.returncode != 0 and not rendered_path.exists(),
+            "pre-start fails closed when required secret files are absent")
+
+    password_path.write_text("ci-database-password\n", encoding="utf-8")
+    signing_key_path.write_text("ci-signing-key\n", encoding="utf-8")
+    turn_secret_path.write_text("ci-turn-shared-secret\n", encoding="utf-8")
+    rendered_result = subprocess.run(
+        ["/bin/sh", "-ec", isolated_command],
+        text=True,
+        capture_output=True,
+        check=False,
+    )
+    require(rendered_result.returncode == 0 and rendered_path.is_file(),
+            "pre-start renders config from harmless external test secrets")
+    with rendered_path.open(encoding="utf-8") as handle:
+        rendered_config = yaml.safe_load(handle)
+    require(rendered_config["database"]["args"]["password"] == "ci-database-password",
+            "rendered config receives the database password")
+    require(rendered_config["signing_key_path"] == str(runtime_signing_key_path),
+            "rendered config uses the UID-991-readable signing-key copy")
+    require(rendered_config["turn_shared_secret"] == "ci-turn-shared-secret",
+            "rendered config receives the TURN shared secret")
+    require(os.stat(rendered_path).st_mode & 0o777 == 0o600,
+            "rendered config permissions are owner-only")
+    require(runtime_signing_key_path.read_text(encoding="utf-8") == "ci-signing-key\n",
+            "runtime signing-key copy preserves the external secret")
+    require(os.stat(runtime_signing_key_path).st_mode & 0o777 == 0o600,
+            "runtime signing-key copy permissions are owner-only")
+PY
diff --git a/pi/tests/test_synapse_poc.sh b/pi/tests/test_synapse_poc.sh
