+#!/usr/bin/env python3
+"""
+Idempotent Matrix room bootstrap from declarative policy.
+
+Loads room_policy.json, validates the policy against a schema, then
+creates or updates rooms on the configured Matrix homeserver with
+restrictive Power Levels that deny privileged actions to Vekling
+and gateway users.
+"""
+
+import argparse
+import json
+import os
+import re
+import sys
+import urllib.error
+import urllib.parse
+import urllib.request
+
+SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))
+DEFAULT_POLICY = os.path.join(SCRIPT_DIR, "room_policy.json")
+
+# -- Schema validation constants -----------------------------------------------
+
+REQUIRED_POLICY_KEYS = {"homeserver_url", "domain", "bot_user_id", "rooms"}
+REQUIRED_ROOM_KEYS = {"room_alias", "name", "preset", "members", "power_levels"}
+REQUIRED_POWER_LEVEL_KEYS = {
+    "ban", "events_default", "invite", "kick",
+    "notifications", "redact", "state_default",
+    "users", "users_default",
+}
+VALID_PRESETS = {"public_chat", "private_chat", "trusted_private_chat"}
+RESTRICTED_USER_KEYS = {"user_id_pattern", "power_level", "denied_actions"}
+VALID_DENIED_ACTIONS = {"invite", "kick", "ban", "redact", "state"}
+
+
+# -- Policy validation --------------------------------------------------------
+
+
+class PolicyValidationError(ValueError):
+    """Raised when the policy document fails validation."""
+
+
+class MatrixAPIError(RuntimeError):
+    """Raised when a Matrix request fails."""
+
+    def __init__(self, message, status=None):
+        super().__init__(message)
+        self.status = status
+
+
+def validate_policy(policy):
+    """Validate the loaded policy document.
+
+    Raises PolicyValidationError on first invalid field.
+    Returns True on success.
+    """
+    if not isinstance(policy, dict):
+        raise PolicyValidationError("Policy must be a JSON object")
+
+    missing = REQUIRED_POLICY_KEYS - set(policy.keys())
+    if missing:
+        raise PolicyValidationError(f"Missing required policy keys: {missing}")
+
+    if not isinstance(policy["homeserver_url"], str) or not policy["homeserver_url"]:
+        raise PolicyValidationError("homeserver_url must be a non-empty string")
+
+    if not isinstance(policy["domain"], str) or not policy["domain"]:
+        raise PolicyValidationError("domain must be a non-empty string")
+
+    if not isinstance(policy["bot_user_id"], str) or not policy["bot_user_id"]:
+        raise PolicyValidationError("bot_user_id must be a non-empty string")
+
+    if not policy["bot_user_id"].startswith("@"):
+        raise PolicyValidationError("bot_user_id must start with '@'")
+
+    if not isinstance(policy["rooms"], list) or not policy["rooms"]:
+        raise PolicyValidationError("rooms must be a non-empty list")
+
+    aliases = set()
+    for i, room in enumerate(policy["rooms"]):
+        _validate_room(room, i)
+        if room["room_alias"] in aliases:
+            raise PolicyValidationError(f"Duplicate room alias: {room['room_alias']}")
+        aliases.add(room["room_alias"])
+
+    if "restricted_users" in policy:
+        if not isinstance(policy["restricted_users"], list):
+            raise PolicyValidationError("restricted_users must be a list")
+        for j, user in enumerate(policy["restricted_users"]):
+            _validate_restricted_user(user, j)
+
+    return True
+
+
+def _validate_room(room, index):
+    if not isinstance(room, dict):
+        raise PolicyValidationError(f"rooms[{index}] must be a JSON object")
+
+    missing = REQUIRED_ROOM_KEYS - set(room.keys())
+    if missing:
+        raise PolicyValidationError(f"rooms[{index}] missing keys: {missing}")
+
+    if not isinstance(room["room_alias"], str) or not room["room_alias"]:
+        raise PolicyValidationError(f"rooms[{index}].room_alias must be a non-empty string")
+
+    if not isinstance(room["name"], str) or not room["name"]:
+        raise PolicyValidationError(f"rooms[{index}].name must be a non-empty string")
+
+    if not isinstance(room["members"], list):
+        raise PolicyValidationError(f"rooms[{index}].members must be a list")
+    for member in room["members"]:
+        if not _is_matrix_user_id(member):
+            raise PolicyValidationError(
+                f"rooms[{index}].members contains invalid Matrix user ID: {member!r}"
+            )
+
+    if room["preset"] not in VALID_PRESETS:
+        raise PolicyValidationError(
+            f"rooms[{index}].preset '{room['preset']}' not in {VALID_PRESETS}"
+        )
+
+    _validate_power_levels(room["power_levels"], index)
+
+
+def _validate_power_levels(pl, room_index):
+    if not isinstance(pl, dict):
+        raise PolicyValidationError(f"rooms[{room_index}].power_levels must be a JSON object")
+
+    missing = REQUIRED_POWER_LEVEL_KEYS - set(pl.keys())
+    if missing:
+        raise PolicyValidationError(
+            f"rooms[{room_index}].power_levels missing keys: {missing}"
+        )
+
+    for key in ("ban", "events_default", "invite", "kick", "redact", "state_default", "users_default"):
+        if not isinstance(pl.get(key), int):
+            raise PolicyValidationError(
+                f"rooms[{room_index}].power_levels.{key} must be an integer"
+            )
+
+    if not isinstance(pl.get("notifications"), dict):
+        raise PolicyValidationError(
+            f"rooms[{room_index}].power_levels.notifications must be a JSON object"
+        )
+
+    if not isinstance(pl.get("users"), dict):
+        raise PolicyValidationError(
+            f"rooms[{room_index}].power_levels.users must be a JSON object"
+        )
+    for user_id, level in pl["users"].items():
+        if not _is_matrix_user_id(user_id) or not isinstance(level, int):
+            raise PolicyValidationError(
+                f"rooms[{room_index}].power_levels.users must map Matrix user IDs to integers"
+            )
+
+    # Sanity: state_default should be >= events_default to prevent users
+    # from elevating themselves via state events.
+    if pl["state_default"] < pl["events_default"]:
+        raise PolicyValidationError(
+            f"rooms[{room_index}].power_levels.state_default ({pl['state_default']}) "
+            f"must be >= events_default ({pl['events_default']})"
+        )
+
+    # Sanity: invite/kick/ban should be >= state_default for consistency
+    for action in ("invite", "kick", "ban"):
+        if pl[action] < pl["state_default"]:
+            raise PolicyValidationError(
+                f"rooms[{room_index}].power_levels.{action} ({pl[action]}) "
+                f"must be >= state_default ({pl['state_default']})"
+            )
+
+
+def _validate_restricted_user(user, index):
+    if not isinstance(user, dict):
+        raise PolicyValidationError(f"restricted_users[{index}] must be a JSON object")
+
+    missing = RESTRICTED_USER_KEYS - set(user.keys())
+    if missing:
+        raise PolicyValidationError(f"restricted_users[{index}] missing keys: {missing}")
+
+    if not isinstance(user["user_id_pattern"], str) or not user["user_id_pattern"]:
+        raise PolicyValidationError(
+            f"restricted_users[{index}].user_id_pattern must be a non-empty string"
+        )
+    try:
+        re.compile(user["user_id_pattern"])
+    except re.error as exc:
+        raise PolicyValidationError(
+            f"restricted_users[{index}].user_id_pattern is invalid: {exc}"
+        ) from exc
+
+    if not isinstance(user["power_level"], int):
+        raise PolicyValidationError(
+            f"restricted_users[{index}].power_level must be an integer"
+        )
+
+    if not isinstance(user["denied_actions"], list) or not user["denied_actions"]:
+        raise PolicyValidationError(
+            f"restricted_users[{index}].denied_actions must be a non-empty list"
+        )
+
+    for action in user["denied_actions"]:
+        if action not in VALID_DENIED_ACTIONS:
+            raise PolicyValidationError(
+                f"restricted_users[{index}].denied_actions contains '{action}', "
+                f"valid: {VALID_DENIED_ACTIONS}"
+            )
+
+
+def _is_matrix_user_id(value):
+    return (
+        isinstance(value, str)
+        and value.startswith("@")
+        and ":" in value[1:]
+        and not any(char.isspace() for char in value)
+    )
+
+
+# -- Matrix API helper ---------------------------------------------------------
+
+
+class MatrixClient:
+    """Thin wrapper over the Matrix Client-Server v3 API."""
+
+    def __init__(self, homeserver_url, domain, access_token):
+        if not homeserver_url.endswith("/"):
+            homeserver_url += "/"
+        self.base = homeserver_url
+        self.api = f"{self.base}_matrix/client/v3/"
+        self.domain = domain
+        self.headers = {
+            "Authorization": f"Bearer {access_token}",
+            "Content-Type": "application/json",
+        }
+
+    def _request(self, method, path, data=None):
+        url = f"{self.api}{path.lstrip('/')}"
+        body = json.dumps(data).encode() if data is not None else None
+        req = urllib.request.Request(url, data=body, headers=self.headers, method=method)
+        try:
+            with urllib.request.urlopen(req, timeout=30) as resp:
+                return json.loads(resp.read())
+        except urllib.error.HTTPError as exc:
+            raw = exc.read()
+            body = raw.decode() if isinstance(raw, bytes) else str(raw)
+            raise MatrixAPIError(
+                f"Matrix API {method} {path} failed: {exc.code} {exc.reason} - {body}",
+                status=exc.code,
+            ) from exc
+        except urllib.error.URLError as exc:
+            raise MatrixAPIError(
+                f"Matrix API {method} {path} unreachable: {exc.reason}"
+            ) from exc
+
+    def get(self, path):
+        """GET request to the Matrix API."""
+        return self._request("GET", path)
+
+    def put(self, path, data):
+        """PUT request to the Matrix API."""
+        return self._request("PUT", path, data)
+
+    def post(self, path, data):
+        """POST request to the Matrix API."""
+        return self._request("POST", path, data)
+
+    def resolve_room_alias(self, alias):
+        """Resolve a room alias to a room ID.
+
+        Returns the room ID string, or None if the alias does not exist.
+        """
+        full_alias = f"#{alias}:{self.domain}"
+        try:
+            result = self.get(f"directory/room/{urllib.parse.quote(full_alias, safe='')}")
+            return result.get("room_id")
+        except MatrixAPIError as exc:
+            if exc.status == 404:
+                return None
+            raise
+
+    def create_room(self, alias, name, topic, preset):
+        """Create a new room.
+
+        Returns the room_id string.
+        """
+        payload = {
+            "name": name,
+            "topic": topic,
+            "preset": preset,
+            "room_alias_name": alias,
+            "visibility": "public" if preset == "public_chat" else "private",
+        }
+        result = self.post("createRoom", payload)
+        return result["room_id"]
+
+    def set_power_levels(self, room_id, power_levels, bot_user_id):
+        """Set room power levels and retain Lydia as room-level administrator.
+
+        *power_levels* is the base dict from the policy.
+        *bot_user_id* is the bot's full Matrix ID (gets room power level 100).
+        Restricted identities remain at ``users_default`` unless the validated
+        policy explicitly assigns a lower level to a concrete Matrix user ID.
+        """
+        pl = dict(power_levels)
+        users = dict(pl.get("users", {}))
+        # Ensure bot has admin power
+        users[bot_user_id] = 100
+
+        pl["users"] = users
+        self.put(f"rooms/{urllib.parse.quote(room_id, safe='')}/state/m.room.power_levels", pl)
+
+    def ensure_members(self, room_id, members):
+        """Invite missing members and return the user IDs newly invited."""
+        invited = []
+        encoded_room = urllib.parse.quote(room_id, safe="")
+        for user_id in members:
+            encoded_user = urllib.parse.quote(user_id, safe="")
+            try:
+                state = self.get(
+                    f"rooms/{encoded_room}/state/m.room.member/{encoded_user}"
+                )
+                if state.get("membership") in {"join", "invite"}:
+                    continue
+            except MatrixAPIError as exc:
+                if exc.status != 404:
+                    raise
+            self.post(f"rooms/{encoded_room}/invite", {"user_id": user_id})
+            invited.append(user_id)
+        return invited
+
+
+# -- Bootstrap orchestration ---------------------------------------------------
+
+
+def load_policy(path=None):
+    """Load and validate the policy file.
+
+    Returns the parsed policy dict.
+    Raises PolicyValidationError on invalid content.
+    """
+    path = path or DEFAULT_POLICY
+    if not os.path.isfile(path):
+        raise FileNotFoundError(f"Policy file not found: {path}")
+    with open(path) as fh:
+        policy = json.load(fh)
+    validate_policy(policy)
+    return policy
+
+
+def get_access_token():
+    """Get Matrix access token from environment or file."""
+    token = os.environ.get("MATRIX_ACCESS_TOKEN")
+    if token:
+        return token
+    # Fallback: try ~/.creds/matrix.token
+    token_path = os.path.expanduser("~/.creds/matrix.token")
+    if os.path.isfile(token_path):
+        with open(token_path) as fh:
+            return fh.read().strip()
+    raise RuntimeError(
+        "MATRIX_ACCESS_TOKEN not set and ~/.creds/matrix.token not found"
+    )
+
+
+def bootstrap_rooms(client, policy):
+    """Idempotent room bootstrap.
+
+    For each room in the policy:
+      1. Try to resolve the room alias.
+      2. If not found, create the room.
+      3. Set power levels with restricted user enforcement.
+
+    Returns a list of dicts with room_alias, room_id, and action.
+    """
+    results = []
+    domain = policy.get("domain", "homelab.local")
+    bot_user_id = policy["bot_user_id"]
+    for room_cfg in policy["rooms"]:
+        alias = room_cfg["room_alias"]
+        full_alias = f"#{alias}:{domain}"
+        action = "exists"
+
+        # 1. Resolve alias -> room ID
+        room_id = client.resolve_room_alias(alias)
+        if room_id is None:
+            # 2. Create room
+            room_id = client.create_room(
+                alias=alias,
+                name=room_cfg["name"],
+                topic=room_cfg.get("topic", ""),
+                preset=room_cfg["preset"],
+            )
+            action = "created"
+        else:
+            action = "exists"
+
+        # 3. Set power levels (idempotent — PUT always overwrites)
+        client.set_power_levels(
+            room_id,
+            room_cfg["power_levels"],
+            bot_user_id=bot_user_id,
+        )
+        invited = client.ensure_members(room_id, room_cfg["members"])
+        if action == "exists":
+            action = "power_levels_updated"
+
+        results.append({
+            "room_alias": full_alias,
+            "room_id": room_id,
+            "action": action,
+            "members_invited": invited,
+        })
+
+    return results
+
+
+# -- Restricted action validation (pre-flight) ---------------------------------
+
+
+def validate_restricted_actions(policy):
+    """Validate that restricted users cannot perform privileged actions.
+
+    Checks that the power levels in each room prevent users at the
+    restricted power level from performing the denied actions.
+
+    Returns a list of validation messages (empty = all good).
+    Raises PolicyValidationError on violation.
+    """
+    issues = []
+    restricted_users = policy.get("restricted_users", [])
+
+    for room in policy["rooms"]:
+        pl = room["power_levels"]
+        for restricted in restricted_users:
+            rl = restricted["power_level"]
+            pattern = restricted["user_id_pattern"]
+            for action in restricted["denied_actions"]:
+                required_level = _action_threshold(pl, action)
+                if rl >= required_level:
+                    issues.append(
+                        f"Room '{room['room_alias']}': user matching '{pattern}' "
+                        f"has power_level {rl} but {action} requires {required_level}. "
+                        f"Restricted user would NOT be denied."
+                    )
+            for user_id, user_level in pl["users"].items():
+                if re.match(pattern, user_id) and user_level > rl:
+                    issues.append(
+                        f"Room '{room['room_alias']}': restricted user '{user_id}' "
+                        f"has explicit power_level {user_level}, above allowed {rl}."
+                    )
+
+    if issues:
+        raise PolicyValidationError(
+            "Restricted action validation failed:\n  " + "\n  ".join(issues)
+        )
+    return issues
+
+
+def _action_threshold(power_levels, action):
+    """Return the power level threshold for a given action."""
+    if action == "state":
+        return power_levels.get("state_default", 50)
+    if action == "invite":
+        return power_levels.get("invite", 50)
+    if action == "kick":
+        return power_levels.get("kick", 50)
+    if action == "ban":
+        return power_levels.get("ban", 50)
+    if action == "redact":
+        return power_levels.get("redact", 50)
+    return 50
+
+
+def user_matches_restricted(user_id, restricted_users):
+    """Check if a user_id matches any restricted user pattern."""
+    for restricted in restricted_users:
+        pattern = restricted["user_id_pattern"]
+        if re.match(pattern, user_id):
+            return True
+    return False
+
+
+# -- Main entry point ----------------------------------------------------------
+
+
+def build_dry_run(policy):
+    """Build a JSON-serializable provisioning plan without contacting Matrix."""
+    return {
+        "status": "planned",
+        "homeserver_url": policy["homeserver_url"],
+        "domain": policy["domain"],
+        "bot_user_id": policy["bot_user_id"],
+        "rooms": [
+            {
+                "room_alias": f"#{room['room_alias']}:{policy['domain']}",
+                "name": room["name"],
+                "preset": room["preset"],
+                "members": room["members"],
+                "power_levels": room["power_levels"],
+            }
+            for room in policy["rooms"]
+        ],
+    }
+
+
+def parse_args(argv=None):
+    parser = argparse.ArgumentParser(description=__doc__)
+    parser.add_argument(
+        "--policy",
+        default=os.environ.get("MATRIX_POLICY_PATH") or DEFAULT_POLICY,
+    )
+    parser.add_argument(
+        "--dry-run",
+        action="store_true",
+        help="validate policy and print the provisioning plan as JSON without API calls",
+    )
+    return parser.parse_args(argv)
+
+
+def main(argv=None):
+    """Load policy, validate, bootstrap rooms."""
+    args = parse_args(argv)
+
+    try:
+        # 1. Load and validate policy
+        policy = load_policy(args.policy)
+
+        # 2. Validate restricted actions pre-flight
+        validate_restricted_actions(policy)
+
+        if args.dry_run:
+            print(json.dumps(build_dry_run(policy), sort_keys=True))
+            return 0
+
+        print(f"Policy loaded and validated from {args.policy}")
+        print("Restricted action validation passed")
+
+        # 3. Get access token
+        token = get_access_token()
+        print("Access token obtained")
+
+        # 4. Create Matrix client
+        client = MatrixClient(
+            homeserver_url=policy["homeserver_url"],
+            domain=policy["domain"],
+            access_token=token,
+        )
+
+        # 5. Bootstrap rooms
+        results = bootstrap_rooms(client, policy)
+        for r in results:
+            print(f"  {r['action']}: {r['room_alias']} -> {r['room_id']}")
+
+        print("Room bootstrap complete.")
+
+    except (PolicyValidationError, FileNotFoundError, RuntimeError) as exc:
+        print(f"ERROR: {exc}", file=sys.stderr)
+        return 1
+
+    return 0
+
+
+if __name__ == "__main__":
+    sys.exit(main())
