+#!/usr/bin/env bash
+# Contract tests for the declarative Keycloak client and Synapse OIDC runbook.
+set -euo pipefail
+
+REPO_ROOT="$(cd "$(dirname "$0")/../.." && pwd)"
+
+python3 - \
+  "$REPO_ROOT/pi/keycloak/matrix-client-realm-export.example.json" \
+  "$REPO_ROOT/docs/matrix/keycloak-oidc.md" <<'PY'
+from pathlib import Path
+import json
+import sys
+
+
+def require(condition, message):
+    if not condition:
+        raise SystemExit(f"FAIL: {message}")
+    print(f"PASS: {message}")
+
+
+template_path, documentation_path = map(Path, sys.argv[1:])
+for path in (template_path, documentation_path):
+    require(path.is_file(), f"required input exists: {path.name}")
+
+realm = json.loads(template_path.read_text(encoding="utf-8"))
+require(realm.get("realm") == "homelab", "template targets the non-master homelab realm")
+require(realm.get("realm") != "master", "template never targets the master realm")
+require(realm.get("enabled") is True, "realm template is enabled")
+
+clients = realm.get("clients", [])
+require(len(clients) == 1, "template declares exactly one client")
+client = clients[0]
+require(client.get("clientId") == "synapse", "client ID is synapse")
+require(client.get("protocol") == "openid-connect", "client uses OpenID Connect")
+require(client.get("enabled") is True, "client is enabled")
+require(client.get("publicClient") is False, "client is confidential, not public")
+require(client.get("clientAuthenticatorType") == "client-secret", "client authenticates confidentially")
+require(client.get("standardFlowEnabled") is True, "authorization-code flow is enabled")
+for field in ("implicitFlowEnabled", "directAccessGrantsEnabled", "serviceAccountsEnabled"):
+    require(client.get(field) is False, f"{field} is disabled")
+require(client.get("authorizationServicesEnabled") is False, "authorization services are disabled")
+require(client.get("fullScopeAllowed") is False, "full scope is disabled")
+
+callback = "https://matrix.hl.maier.wtf/_synapse/client/oidc/callback"
+logout = "https://matrix.hl.maier.wtf/_synapse/client/oidc/backchannel_logout"
+require(client.get("redirectUris") == [callback], "only the exact Synapse callback is allowed")
+require(client.get("webOrigins") == [], "no browser origins are granted")
+require(client.get("defaultClientScopes") == ["profile"], "only the minimal profile client scope is attached")
+require(client.get("optionalClientScopes") == [], "no optional scopes are attached")
+require(client.get("protocolMappers") == [], "no extra claims or role mappers are configured")
+attributes = client.get("attributes", {})
+require(attributes.get("oauth2.device.authorization.grant.enabled") == "false", "device authorization grant is disabled")
+require(attributes.get("oidc.ciba.grant.enabled") == "false", "CIBA grant is disabled")
+require(attributes.get("backchannel.logout.url") == logout, "back-channel logout targets Synapse")
+require(attributes.get("backchannel.logout.session.required") == "true", "logout notifications require a session")
+require("secret" not in client, "template contains no client secret")
+require("credentials" not in client, "template contains no credentials")
+
+documentation = documentation_path.read_text(encoding="utf-8")
+normalized_documentation = " ".join(documentation.split())
+host_secret = "/home/michael/matrix/secrets/oidc_client_secret"
+container_secret = "/run/secrets/synapse_oidc_client_secret"
+require(host_secret in documentation, "runbook names the persistent host secret source")
+require(container_secret in documentation, "runbook names the distinct container secret target")
+require("Host source" in documentation, "runbook labels the host-side path")
+require("Compose target" in documentation, "runbook labels the compose-side secret target")
+require("michael:michael" in documentation, "runbook specifies restrictive host ownership")
+require("mode `0700`" in documentation, "runbook restricts the host secret directory")
+require("mode to `0600`" in documentation, "runbook restricts the host secret file")
+require(
+    "separate reviewed Compose/runtime-config change" in normalized_documentation,
+    "runbook requires a separately reviewed runtime wiring change",
+)
+require(
+    "Do not activate the OIDC provider until" in documentation,
+    "runbook blocks activation until secret wiring exists",
+)
+require(
+    "Synapse host's runtime secret file at" not in documentation,
+    "runbook does not mislabel the container target as a host file",
+)
+runtime_secret = "/run/synapse/oidc_client_secret"
+require(
+    runtime_secret in documentation,
+    "runbook names the runtime tmpfs secret copy at /run/synapse/oidc_client_secret",
+)
+require(
+    "991:991" in documentation,
+    "runbook restricts the runtime secret ownership to the Synapse system user (991) after privdrop",
+)
+require(
+    "root pre-start" in documentation,
+    "runbook requires a root pre-start step to populate the runtime tmpfs copy",
+)
+for required in (
+    "https://auth.hl.maier.wtf/realms/homelab",
+    callback,
+    logout,
+    'scopes: ["openid", "profile"]',
+    'subject_claim: "sub"',
+    "backchannel_logout_enabled: true",
+    "matrix-client-realm-export.example.json",
+    "private browsing window",
+    "Login smoke test",
+    "Logout smoke test",
+    "https://www.keycloak.org/docs/latest/server_admin/#_oidc_clients",
+    "https://element-hq.github.io/synapse/latest/openid.html#keycloak",
+):
+    require(required in documentation, f"documentation contains: {required}")
+
+require("master realm" in documentation, "runbook explicitly excludes the master realm")
+require("Do not commit" in documentation, "runbook forbids committing the runtime credential")
+PY
