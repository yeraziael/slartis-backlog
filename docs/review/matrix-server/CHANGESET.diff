@@ -0,0 +1,90 @@
+"""Tests for Matrix parallel-operation test fixtures.
+
+Validates that every scenario in the parallel-operation-test.md runbook
+has an action, expected result, and evidence field.
+"""
+
+import pathlib
+import re
+import unittest
+
+ROOT = pathlib.Path(__file__).resolve().parents[2]
+RUNBOOK_PATH = ROOT / "docs/matrix/parallel-operation-test.md"
+
+
+class TestParallelRunbookStructure(unittest.TestCase):
+    def setUp(self):
+        self.content = RUNBOOK_PATH.read_text()
+
+    def test_runbook_exists(self):
+        self.assertTrue(RUNBOOK_PATH.exists(), "parallel-operation-test.md must exist")
+
+    def test_has_test_matrix(self):
+        self.assertIn("S01", self.content)
+        self.assertIn("S20", self.content)
+
+    def test_all_scenarios_have_action(self):
+        lines = self.content.split("\n")
+        for line in lines:
+            if re.match(r"^\| S\d", line):
+                parts = [p.strip() for p in line.split("|")]
+                parts = [p for p in parts if p]
+                if len(parts) == 5:
+                    _, channel, action, expected, evidence = parts
+                    self.assertTrue(
+                        expected and len(expected) > 3,
+                        f"Expected result seems empty: {expected}",
+                    )
+                    self.assertTrue(
+                        evidence and len(evidence) > 3,
+                        f"Evidence field seems empty: {evidence}",
+                    )
+
+    def test_scenario_numbering_is_complete(self):
+        """Ensure S01-S20 are all present in sequence."""
+        for i in range(1, 21):
+            self.assertIn(f"S{i:02d}", self.content, f"S{i:02d} not found")
+
+    def test_has_daily_checks(self):
+        self.assertIn("Tägliche Checks (Tag 1–7)", self.content)
+        self.assertIn("Health-Check (Matrix)", self.content)
+        self.assertIn("Ressourcen (Pi5)", self.content)
+        self.assertIn("Sync-Lag", self.content)
+        self.assertIn("Kanäle vergleichen", self.content)
+        self.assertIn("Log-Scan", self.content)
+
+    def test_has_abbruchkriterien(self):
+        self.assertIn("Abbruchkriterien", self.content)
+
+    def test_has_erfolgskriterien(self):
+        self.assertIn("Erfolgskriterien", self.content)
+
+    def test_has_ergebnistabelle(self):
+        self.assertIn("Ergebnistabelle", self.content)
+
+    def test_has_day_7_reference(self):
+        self.assertIn("Tag 7", self.content)
+
+    def test_coverage_of_channels(self):
+        """All three channels must be referenced in test scenarios."""
+        for channel in ["Matrix", "Telegram", "Signal"]:
+            self.assertIn(channel, self.content)
+
+    def test_bridge_loop_coverage(self):
+        """At least one scenario covers bridge-loop prevention."""
+        self.assertIn("Bridge-Loop", self.content) or self.assertIn("loop", self.content.lower())
+
+    def test_attachment_coverage(self):
+        """At least one scenario covers attachments."""
+        self.assertIn("PDF", self.content) or self.assertIn("Audio", self.content)
+
+    def test_chunking_coverage(self):
+        """At least one scenario covers message chunking."""
+        self.assertTrue(
+            "Chunking" in self.content or "gechunkt" in self.content,
+            "No chunking coverage found",
+        )
+
+
+if __name__ == "__main__":
+    unittest.main()

