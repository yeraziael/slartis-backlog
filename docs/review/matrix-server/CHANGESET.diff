+#!/usr/bin/env bash
+# Documentation contract tests for Matrix operations and rollback.
+set -euo pipefail
+
+REPO_ROOT="$(cd "$(dirname "$0")/../.." && pwd)"
+RUNBOOK="$REPO_ROOT/docs/matrix/runbook.md"
+
+python3 - "$RUNBOOK" <<'PY'
+from pathlib import Path
+import re
+import sys
+
+
+path = Path(sys.argv[1])
+if not path.is_file():
+    raise SystemExit(f"FAIL: required input missing: {path}")
+text = path.read_text(encoding="utf-8")
+
+
+def require(condition, message):
+    if not condition:
+        raise SystemExit(f"FAIL: {message}")
+    print(f"PASS: {message}")
+
+
+for section in (
+    "## Preconditions And Release Evidence",
+    "## Start And Stop",
+    "## Health Verification",
+    "## Upgrade",
+    "## Rollback",
+    "## Restore",
+    "## Credential Rotation",
+    "## Emergency Isolation",
+    "## External Fallback",
+    "## Operator Blackbox Test",
+):
+    require(section in text, f"runbook contains {section}")
+
+for command in (
+    "pi/backupMatrix.sh",
+    "docker compose -f pi/compose/synapse.yml",
+    "docker compose -f pi/compose/coturn.yml",
+    "sha256sum -c sha256sums.txt",
+    "https://matrix.hl.maier.wtf/_matrix/client/versions",
+    "git switch --detach <release-commit>",
+    "git switch --detach <previous-release-commit>",
+    "pi/restoreMatrix.md",
+):
+    require(command in text, f"runbook contains command or contract: {command}")
+
+for placeholder in (
+    "<release-commit>",
+    "<previous-release-commit>",
+    "<backup-timestamp>",
+    "<rotation-id>",
+):
+    require(placeholder in text, f"runbook uses placeholder {placeholder}")
+
+for profile_reference in (
+    "docs/releases/matrix-profile-v1.md",
+    "homelab-release/v1",
+):
+    require(profile_reference in text, f"runbook references {profile_reference}")
+
+for forbidden in (
+    r"syt_[A-Za-z0-9_-]{12,}",
+    r"[0-9]{8,10}:[A-Za-z0-9_-]{20,}",
+    r"static-auth-secret\s*=\s*[^<\s]",
+    r"password\s*=\s*[^<\s]",
+):
+    require(re.search(forbidden, text, re.IGNORECASE) is None, f"runbook excludes secret pattern {forbidden}")
+
+blackbox = text.split("## Operator Blackbox Test", 1)[1]
+for required in ("Action:", "Expected:", "Evidence:", "Abort:"):
+    require(required in blackbox, f"blackbox procedure contains {required}")
+PY
