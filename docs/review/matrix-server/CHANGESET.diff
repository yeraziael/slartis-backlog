index 0000000..f7ad7a2
--- /dev/null
+++ b/runtime/matrix/inbound.py
@@ -0,0 +1,130 @@
+#!/usr/bin/env python3
+"""Convert Matrix sync events into Lydia Message Envelope v1 objects."""
+
+import base64
+
+
+class MatrixPayloadError(ValueError):
+    """Raised when a Matrix sync response cannot be processed safely."""
+
+
+class MatrixInboundAdapter:
+    """Poll a Matrix client and expose channel-neutral message envelopes."""
+
+    def __init__(self, client, origin_id="mx-lydia", audit=None):
+        self.client = client
+        self.origin_id = origin_id
+        self.audit = audit or (lambda record: None)
+        self.next_cursor = None
+
+    def poll_once(self, cursor):
+        response = self.client.sync(cursor)
+        next_cursor, joined_rooms = _sync_parts(response)
+        envelopes = []
+        for room_id, room in joined_rooms.items():
+            if not isinstance(room_id, str) or not room_id:
+                raise MatrixPayloadError("joined room requires non-empty room_id")
+            if not isinstance(room, dict):
+                raise MatrixPayloadError("joined room payload must be an object")
+            timeline = room.get("timeline", {})
+            if not isinstance(timeline, dict) or not isinstance(timeline.get("events", []), list):
+                raise MatrixPayloadError("room timeline events must be a list")
+            for event in timeline.get("events", []):
+                if not isinstance(event, dict):
+                    raise MatrixPayloadError("timeline event must be an object")
+                if event.get("type") != "m.room.message":
+                    self._ignore(room_id, event, "unsupported_event_type")
+                    continue
+                content = event.get("content", {})
+                if not isinstance(content, dict):
+                    raise MatrixPayloadError("message content must be an object")
+                if content.get("msgtype") != "m.text":
+                    self._ignore(room_id, event, "unsupported_message_type")
+                    continue
+                _validate_text_event(event)
+                envelopes.append(self._to_envelope(room_id, event))
+        self.next_cursor = next_cursor
+        return envelopes
+
+    def _ignore(self, room_id, event, reason):
+        self.audit({
+            "action": "ignored",
+            "reason": reason,
+            "event_id": event.get("event_id"),
+            "room_id": room_id,
+            "event_type": event.get("type"),
+        })
+
+    def _to_envelope(self, room_id, event):
+        event_id = event["event_id"]
+        source_id = (
+            base64.urlsafe_b64encode(event_id.encode("utf-8"))
+            .decode("ascii")
+            .rstrip("=")
+        )
+        content = event["content"]
+        relation = _reply_relation(content)
+        text = content["body"]
+        if relation.get("event_id") and text.startswith("> ") and "\n\n" in text:
+            text = text.split("\n\n", 1)[1]
+
+        envelope = {
+            "envelope_version": 1,
+            "message_id": f"{self.origin_id}-{source_id}",
+            "trace_id": f"trace-{self.origin_id}-{source_id}",
+            "origin_id": self.origin_id,
+            "channel": "matrix",
+            "sender": {"id": event["sender"]},
+            "target": {"id": room_id, "type": "room"},
+            "text": text,
+            "timestamp": event["origin_server_ts"] // 1000,
+            "hops": [],
+            "metadata": {
+                "event_id": event_id,
+                "room_id": room_id,
+            },
+        }
+        if relation.get("event_id"):
+            envelope["reply_to"] = {"message_id": relation["event_id"]}
+        return envelope
+
+
+def _sync_parts(response):
+    if not isinstance(response, dict):
+        raise MatrixPayloadError("sync payload must be an object")
+    next_cursor = response.get("next_batch")
+    if not isinstance(next_cursor, str) or not next_cursor:
+        raise MatrixPayloadError("sync payload requires non-empty string next_batch")
+    rooms = response.get("rooms", {})
+    if not isinstance(rooms, dict):
+        raise MatrixPayloadError("sync rooms must be an object")
+    joined_rooms = rooms.get("join", {})
+    if not isinstance(joined_rooms, dict):
+        raise MatrixPayloadError("sync joined rooms must be an object")
+    return next_cursor, joined_rooms
+
+
+def _validate_text_event(event):
+    required_strings = ("event_id", "sender")
+    for field in required_strings:
+        if not isinstance(event.get(field), str) or not event[field]:
+            raise MatrixPayloadError(f"text event requires non-empty {field}")
+    timestamp = event.get("origin_server_ts")
+    if not isinstance(timestamp, int) or isinstance(timestamp, bool) or timestamp < 0:
+        raise MatrixPayloadError("text event requires non-negative origin_server_ts")
+    if not isinstance(event["content"].get("body"), str):
+        raise MatrixPayloadError("text event requires string body")
+    _reply_relation(event["content"])
+
+
+def _reply_relation(content):
+    relates_to = content.get("m.relates_to", {})
+    if not isinstance(relates_to, dict):
+        raise MatrixPayloadError("m.relates_to must be an object")
+    relation = relates_to.get("m.in_reply_to", {})
+    if not isinstance(relation, dict):
+        raise MatrixPayloadError("m.in_reply_to must be an object")
+    event_id = relation.get("event_id")
+    if event_id is not None and (not isinstance(event_id, str) or not event_id):
+        raise MatrixPayloadError("m.in_reply_to event_id must be a non-empty string")
+    return relation
