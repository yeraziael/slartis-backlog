+#!/usr/bin/env bash
+# Contract tests for Matrix identity/service-account/role model.
+# Asserts each required identity is documented and service accounts
+# have no server-admin scope.
+set -euo pipefail
+
+REPO_ROOT="$(cd "$(dirname "$0")/../.." && pwd)"
+
+python3 - \
+  "$REPO_ROOT/docs/matrix/identity-and-access.md" <<'PY'
+from pathlib import Path
+import sys
+
+
+def require(condition, message):
+    if not condition:
+        raise SystemExit(f"FAIL: {message}")
+    print(f"PASS: {message}")
+
+
+doc_path = Path(sys.argv[1])
+require(doc_path.is_file(), "required documentation exists: identity-and-access.md")
+
+doc = doc_path.read_text(encoding="utf-8")
+
+# ── Required sections ──────────────────────────────────────────────────
+REQUIRED_IDENTITIES = [
+    "Operator",
+    "break-glass admin",
+    "Lydia",
+    "Slarti",
+    "Vekling",
+    "gateway",
+]
+
+for ident in REQUIRED_IDENTITIES:
+    require(
+        ident.lower() in doc.lower(),
+        f"documentation covers the {ident} identity",
+    )
+
+# ── Per-identity fields (authentication, room scope, token lifecycle, revocation owner) ──
+REQUIRED_FIELDS = [
+    "authenticat",
+    "room scope",
+    "token lifecycle",
+    "revocation owner",
+]
+
+for field in REQUIRED_FIELDS:
+    require(field.lower() in doc.lower(), f"documentation defines {field} for each identity")
+
+# ── Service accounts vs OIDC human accounts ────────────────────────────
+require("service account" in doc.lower(), "documentation distinguishes service accounts")
+require("oidc" in doc.lower() or "human" in doc.lower(),
+        "documentation distinguishes OIDC human accounts from service accounts")
+
+# ── No service account with server-admin scope ─────────────────────────
+# Scan for any service-account row that grants server-admin scope
+lines = doc.splitlines()
+in_table = False
+service_account_with_admin = False
+server_admin_found = False
+
+for line in lines:
+    stripped = line.strip()
+    # Detect table rows with pipe separators (non-separator rows)
+    if stripped.startswith("|") and not stripped.replace("|", "").replace("-", "").replace(":", "").strip() == "":
+        cells = [c.strip().lower() for c in stripped.strip("|").split("|")]
+        # Check if this row mentions a service account
+        is_service_acct = any("service" in c or "vekling" in c or "gateway" in c for c in cells)
+        # Check if this row grants server-admin or admin scope
+        has_admin_scope = any("server-admin" in c or "server_admin" in c or "admin" in c for c in cells)
+        if is_service_acct and has_admin_scope:
+            service_account_with_admin = True
+    # Also detect explicit statements
+    if "service account" in stripped.lower() and "server-admin" in stripped.lower():
+        service_account_with_admin = True
+    if "service account" in stripped.lower() and "server admin" in stripped.lower():
+        service_account_with_admin = True
+
+# Also look for an explicit assertion that service accounts lack admin
+forbidden_ok = False
+if "no service account" in doc.lower() and "server-admin" in doc.lower():
+    forbidden_ok = True
+if "without server-admin" in doc.lower():
+    forbidden_ok = True
+if "forbidden" in doc.lower() and "service account" in doc.lower() and "admin" in doc.lower():
+    forbidden_ok = True
+
+# Pass if either the explicit prohibition is stated, or no service account row has admin
+require(
+    forbidden_ok or not service_account_with_admin,
+    "no service account is granted server-admin scope",
+)
+
+# ── Rotation / revocation steps (without creating credentials) ────────
+require("rotate" in doc.lower() or "rotation" in doc.lower(),
+        "documentation defines rotation procedures")
+require("revoke" in doc.lower() or "revocation" in doc.lower(),
+        "documentation defines revocation procedures")
+
+# ── No credential creation in the document itself ──────────────────────
+require("do not create" in doc.lower() or "never create" in doc.lower() or
+        "without creating" in doc.lower(),
+        "documentation forbids creating accounts/tokens/credentials inline")
+
+# ── Identity table structure ──────────────────────────────────────────
+require("|" in doc, "documentation uses a structured identity table")
+
+# ══════════════════════════════════════════════════════════════════════
+# Security corrections per post-merge review comment #3344 (issue #223)
+# ══════════════════════════════════════════════════════════════════════
+
+# ── MUST NOT claim Synapse access tokens are natively room-scoped ──────
+# Synapse access tokens are not natively scoped to a single room or task.
+# Access control is enforced via room membership and power levels, not
+# by the token itself.
+single_room_claims = [
+    "single-room", "single room", "room-scoped", "room scoped",
+    "per task", "task-scoped",
+]
+for phrase in single_room_claims:
+    # Find occurrences that associate the phrase with a token claim
+    # We use case-insensitive search in context windows
+    doc_lower = doc.lower()
+    idx = 0
+    while True:
+        idx = doc_lower.find(phrase, idx)
+        if idx == -1:
+            break
+        # Look at surrounding context (200 chars before and after)
+        start = max(0, idx - 200)
+        end = min(len(doc_lower), idx + len(phrase) + 200)
+        context = doc_lower[start:end]
+        # If the phrase appears near "token" in a claim context, reject
+        token_nearby = "token" in context
+        # Exclude legitimate uses like "token isolation" or "token revocation"
+        is_claim = token_nearby and not any(
+            excluded in context
+            for excluded in ["not natively", "enforced via", "membership", "power level"]
+        )
+        if is_claim:
+            require(
+                False,
+                f"document must not claim token is {phrase}: "
+                f"synapse access tokens are not natively scoped",
+            )
+        idx += len(phrase)
+    # end while
+# end for
+
+# ── MUST NOT claim a token-level admin flag ─────────────────────────────
+# Synapse access tokens do not carry an "admin" flag. Admin status is a
+# user-level property, not a token attribute. Allow legitimate references
+# such as "Admin API", "non-admin user", and "not a token attribute".
+import re
+admin_flag_claims = [
+    r"issued without (the )?`?admin`? flag",
+    r"access token.*without.*admin",
+    r"token.*carries.*admin",
+    r"token.*has.*admin",
+    r"token.*level.*admin",
+    r"admin (flag|scope).*on.*token",
+]
+for pattern in admin_flag_claims:
+    if re.search(pattern, doc, re.IGNORECASE):
+        require(
+            False,
+            f"document must not claim a token-level admin flag "
+            f"(matched: /{pattern}/i): admin is user-level, not token-level",
+        )
+
+# ── MUST NOT claim appservice tokens are room-scoped ────────────────────
+# Appservice tokens are scoped via the AS registration namespace/namespace
+# regex, not natively room-scoped. The doc must not claim "room-scoped"
+# or similar for appservice tokens.
+as_patterns = [
+    r"appservice.*room.scoped",
+    r"appservice.*scoped to.*room",
+    r"bridge.*room.scoped",
+    r"gateway.*room.scoped",
+    r"as token.*room",
+]
+for pattern in as_patterns:
+    if re.search(pattern, doc, re.IGNORECASE):
+        require(
+            False,
+            f"document must not claim appservice tokens are room-scoped "
+            f"(matched: /{pattern}/i): scope is via AS namespace regex",
+        )
+
+# ── MUST assert accurate enforcement controls ──────────────────────────
+# The document must describe enforceable access-control mechanisms for
+# service identities.
+require(
+    "separate" in doc.lower() and "non-admin" in doc.lower() and "synapse user" in doc.lower(),
+    "documentation states service identities are separate non-admin Synapse users",
+)
+require(
+    "room membership" in doc.lower() or "membership" in doc.lower(),
+    "documentation states access control is based on room membership",
+)
+require(
+    "power level" in doc.lower() or "power_level" in doc.lower(),
+    "documentation states restrictive room power levels for access control",
+)
+require(
+    "admin api" in doc.lower() and "not exposed" in doc.lower() or
+    "admin api" in doc.lower() and "must not" in doc.lower(),
+    "documentation states Synapse Admin API must not be exposed to or usable by service identities",
+)
+require(
+    "token isolation" in doc.lower() or "token revocation" in doc.lower() or
+    "operational token" in doc.lower(),
+    "documentation states operational token isolation/revocation for least privilege",
+)
+
+# ── MUST distinguish policy from deployment enforcement ────────────────
+# The document must clearly mark that deployment/configuration enforcement
+# is separate and separately reviewed.
+require(
+    "deployment" in doc.lower() and "separate" in doc.lower() or
+    "configuration" in doc.lower() and "separate" in doc.lower() or
+    "separately reviewed" in doc.lower(),
+    "documentation distinguishes policy from deployment/configuration enforcement work",
+)
+
+# ── MUST NOT describe token auto-revocation or auto-expiry ─────────────
+# A token does not auto-revoke or auto-expire by itself; revocation
+# requires an explicit Admin API call (whether by Operator or automation).
+# Allow legitimate descriptions of automated revocation via the Admin API.
+token_auto_claims = [
+    r"token.*auto.*revok",
+    r"token.*auto.*expir",
+    r"token.*expires automatically",
+    r"auto-revoked token",
+    r"auto.revoke.*token",
+    r"expire.*automatically.*token",
+    r"automatically when the task",
+]
+for pattern in token_auto_claims:
+    if re.search(pattern, doc, re.IGNORECASE):
+        require(
+            False,
+            f"document must not claim a token auto-revokes or auto-expires "
+            f"(matched: /{pattern}/i): revocation requires explicit Admin API action",
+        )
+
+# ══════════════════════════════════════════════════════════════════════
+# Third post-merge security correction per comment #3359 (issue #223)
+# ══════════════════════════════════════════════════════════════════════
+
+# ── OIDC applies only to Operator, not break-glass admin ──────────────
+# Scope must state only Operator is provisioned via OIDC. The break-glass
+# admin is a separately pre-provisioned, non-OIDC emergency identity.
+# Check the Scope section specifically — not other parts of the doc.
+scope_section = ""
+in_scope = False
+for line in doc.splitlines():
+    if line.strip().startswith("## Scope"):
+        in_scope = True
+        continue
+    if in_scope:
+        if line.strip().startswith("## "):
+            break
+        scope_section += line + "\n"
+scope_lower = scope_section.lower()
+require(
+    "only operator" in scope_lower and "oidc" in scope_lower,
+    "scope section limits OIDC provisioning to Operator only; "
+    "break-glass admin must not be conflated as OIDC-provisioned",
+)
+require(
+    "break-glass admin" not in scope_lower or "non-oidc" in scope_lower,
+    "scope section does not associate break-glass admin with OIDC "
+    "provisioning; break-glass admin is non-OIDC",
+)
+
+# ── Break-glass admin is pre-provisioned, not per-incident ─────────────
+# The identity must already exist before any incident; only its documented
+# offline credential/recovery material is used during incidents.
+require(
+    "pre-provisioned" in doc.lower(),
+    "break-glass admin identity must be described as pre-provisioned, "
+    "not created per incident",
+)
+
+# ── No per-incident identity provisioning wording anywhere ─────────────
+# The document must not contain phrasing that implies the identity is
+# created or provisioned at incident time.
+require(
+    "per incident" not in doc.lower(),
+    "document must not contain per-incident identity provisioning wording; "
+    "the break-glass identity already exists",
+)
+
+# ── Pre-provisioned non-OIDC identity contract ─────────────────────────
+# The break-glass admin is documented as both pre-provisioned and non-OIDC,
+# with offline credentials stored outside Git, tested periodically, and
+# the exact bootstrap mechanism separately reviewed.
+require(
+    "pre-provisioned" in doc.lower() and "non-oidc" in doc.lower(),
+    "documentation must state the break-glass admin is both pre-provisioned "
+    "and non-OIDC",
+)
+
+# ══════════════════════════════════════════════════════════════════════
+# Second post-merge security correction per comment #3355 (issue #223)
+# ══════════════════════════════════════════════════════════════════════
+
+# ── MUST NOT claim access tokens are "scoped" (ambiguous) ────────────────
+# The phrase "scoped access tokens" or "access token scoped to" implies the
+# token itself carries room-level scope. In Synapse, a token authenticates
+# its user; room membership and power levels constrain what that user may do.
+scoped_phrases = [
+    "scoped access token",
+    "access token scoped to",
+]
+for phrase in scoped_phrases:
+    require(
+        phrase.lower() not in doc.lower(),
+        f"document must not claim token is '{phrase}': "
+        f"token authenticates its user; room membership and power levels "
+        f"constrain what the user may do",
+    )
+
+# ── MUST NOT claim registration token creates/grants admin identity ─────
+# A Synapse registration token authenticates a registration request; it does
+# not itself create an existing server-admin identity or grant admin rights.
+registration_admin_claims = [
+    r"registration token.*server.admin",
+    r"registration token.*admin",
+    r"break.glass.*registration token",
+    r"Pre-shared Synapse registration token",
+]
+for pattern in registration_admin_claims:
+    if re.search(pattern, doc, re.IGNORECASE):
+        require(
+            False,
+            f"document must not claim a registration token creates or "
+            f"authenticates an admin identity "
+            f"(matched: /{pattern}/i): a registration token authenticates "
+            f"a registration request, not an existing admin identity",
+        )
+
+# ── MUST define break-glass as separate non-OIDC emergency admin identity ─
+# The break-glass mechanism must be a separately provisioned emergency admin
+# identity with offline credential/recovery material outside Git, tested
+# periodically. The exact mechanism is out of scope for this document.
+require(
+    "emergency admin identity" in doc.lower() or
+    "emergency admin" in doc.lower(),
+    "documentation must define a separately provisioned emergency admin "
+    "identity (not a registration token)",
+)
+require(
+    "offline" in doc.lower() and "credential" in doc.lower() or
+    "offline" in doc.lower() and "recovery" in doc.lower(),
+    "documentation states emergency admin credential/recovery material is "
+    "held offline",
+)
+require(
+    "tested" in doc.lower() and "periodically" in doc.lower() or
+    "periodic" in doc.lower() and "test" in doc.lower(),
+    "documentation states the emergency admin identity is tested periodically",
+)
+require(
+    "out of scope" in doc.lower() or
+    "separately reviewed" in doc.lower() or
+    "separate review" in doc.lower(),
+    "documentation states the exact emergency admin account mechanism is "
+    "separately reviewed / out of scope",
+)
+PY
