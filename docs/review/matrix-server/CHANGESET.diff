@@ -0,0 +1,117 @@
+#!/usr/bin/env python3
+"""Validate Matrix media and expose metadata without binary payloads."""
+
+import hashlib
+
+from client import (
+    MatrixClientError,
+    MatrixMediaTimeoutError,
+    MatrixMediaTooLargeError,
+    MatrixMediaTypeError,
+    MatrixMediaURIError,
+)
+
+
+DEFAULT_ALLOWED_MIME_TYPES = frozenset(
+    {
+        "application/pdf",
+        "audio/mpeg",
+        "audio/ogg",
+        "audio/wav",
+        "image/jpeg",
+        "image/png",
+        "image/webp",
+        "text/plain",
+    }
+)
+
+
+class AttachmentRejected(RuntimeError):
+    """A Matrix attachment was quarantined before downstream processing."""
+
+    def __init__(self, reason):
+        self.reason = reason
+        super().__init__(f"Matrix attachment rejected: {reason}")
+
+
+def process_attachment(
+    client,
+    source,
+    max_size_bytes,
+    allowed_mime_types=None,
+    audit=None,
+):
+    """Download and validate one attachment, returning metadata only."""
+    audit = audit or (lambda record: None)
+    required = (
+        "content_uri",
+        "content_type",
+        "filename",
+        "sender_id",
+        "room_id",
+        "event_id",
+    )
+    if not isinstance(source, dict) or any(
+        not isinstance(source.get(field), str) or not source[field]
+        for field in required
+    ):
+        _reject(audit, source, "invalid_metadata")
+
+    allowed = DEFAULT_ALLOWED_MIME_TYPES if allowed_mime_types is None else frozenset(
+        _normalize_mime(value) for value in allowed_mime_types
+    )
+    claimed_type = _normalize_mime(source["content_type"])
+    if claimed_type not in allowed:
+        _reject(audit, source, "mime_not_allowed")
+
+    try:
+        result = client.download_media(source["content_uri"], max_size_bytes)
+    except MatrixMediaURIError:
+        _reject(audit, source, "invalid_content_uri")
+    except MatrixMediaTooLargeError:
+        _reject(audit, source, "size_limit")
+    except MatrixMediaTypeError:
+        _reject(audit, source, "mime_missing")
+    except MatrixMediaTimeoutError:
+        _reject(audit, source, "download_timeout")
+    except MatrixClientError:
+        _reject(audit, source, "download_failed")
+    content = result.get("content") if isinstance(result, dict) else None
+    response_type = _normalize_mime(
+        result.get("content_type") if isinstance(result, dict) else None
+    )
+    if not isinstance(content, bytes):
+        _reject(audit, source, "invalid_download")
+    if response_type not in allowed:
+        _reject(audit, source, "mime_not_allowed")
+    if response_type != claimed_type:
+        _reject(audit, source, "mime_mismatch")
+    if len(content) > max_size_bytes:
+        _reject(audit, source, "size_limit")
+
+    return {
+        "content_uri": source["content_uri"],
+        "content_type": response_type,
+        "filename": source["filename"],
+        "size_bytes": len(content),
+        "sha256": hashlib.sha256(content).hexdigest(),
+    }
+
+
+def _normalize_mime(value):
+    if not isinstance(value, str):
+        return ""
+    return value.split(";", 1)[0].strip().lower()
+
+
+def _reject(audit, source, reason):
+    source = source if isinstance(source, dict) else {}
+    audit(
+        {
+            "action": "quarantined",
+            "reason": reason,
+            "event_id": source.get("event_id"),
+            "room_id": source.get("room_id"),
+        }
+    )
+    raise AttachmentRejected(reason)
