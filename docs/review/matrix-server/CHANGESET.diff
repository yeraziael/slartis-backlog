@@ -0,0 +1,79 @@
+services:
+  coturn:
+    image: docker.io/coturn/coturn@sha256:0c0e8fc0c263b85a134e9e4242b5e46e1f4c077c5029633511191c05b5c2c814
+    platform: linux/arm64
+    user: "1000:1000"
+    restart: unless-stopped
+    read_only: true
+    environment:
+      TURN_EXTERNAL_IP: "${TURN_EXTERNAL_IP:-192.0.2.10}"
+    entrypoint: ["/bin/sh", "-ec"]
+    command: |
+      test -s /run/secrets/turn_shared_secret
+      test -s /run/secrets/turn_tls_cert
+      test -s /run/secrets/turn_tls_key
+      case "$$TURN_EXTERNAL_IP" in
+        *[!0-9.]*|"") echo "TURN_EXTERNAL_IP must be an IPv4 address" >&2; exit 1 ;;
+        10.*|127.*|169.254.*|172.1[6-9].*|172.2[0-9].*|172.3[01].*|192.0.2.*|192.168.*|198.51.100.*|203.0.113.*) echo "TURN_EXTERNAL_IP must be a public IPv4 address" >&2; exit 1 ;;
+      esac
+      relay_ip="$$(hostname -i)"
+      set -- $$relay_ip
+      relay_ip="$$1"
+      case "$$relay_ip" in
+        *[!0-9.]*|"") echo "Unable to determine relay IPv4 address" >&2; exit 1 ;;
+      esac
+      umask 077
+      cp /etc/coturn/turnserver.conf.example /run/coturn/turnserver.conf
+      cp /run/secrets/turn_tls_cert /run/coturn/tls_cert.pem
+      cp /run/secrets/turn_tls_key /run/coturn/tls_key.pem
+      shared_secret="$$(tr -d '\r\n' </run/secrets/turn_shared_secret)"
+      test -n "$$shared_secret"
+      printf 'static-auth-secret=%s\n' "$$shared_secret" >>/run/coturn/turnserver.conf
+      printf 'relay-ip=%s\nexternal-ip=%s/%s\n' "$$relay_ip" "$$TURN_EXTERNAL_IP" "$$relay_ip" >>/run/coturn/turnserver.conf
+      exec turnserver -c /run/coturn/turnserver.conf
+    healthcheck:
+      test: ["CMD-SHELL", "turnutils_stunclient 127.0.0.1 -p 3478 >/dev/null 2>&1"]
+      interval: 30s
+      timeout: 10s
+      retries: 3
+      start_period: 20s
+    ports:
+      - "3478:3478/tcp"
+      - "3478:3478/udp"
+      - "5349:5349/tcp"
+      - "5349:5349/udp"
+      - "49160-49200:49160-49200/tcp"
+      - "49160-49200:49160-49200/udp"
+    mem_limit: 256m
+    cpus: "0.50"
+    cap_drop:
+      - ALL
+    security_opt:
+      - no-new-privileges:true
+    logging:
+      driver: json-file
+      options:
+        max-size: "10m"
+        max-file: "7"
+    secrets:
+      - turn_shared_secret
+      - turn_tls_cert
+      - turn_tls_key
+    tmpfs:
+      - /run/coturn:rw,noexec,nosuid,nodev,size=1m,mode=0700,uid=1000,gid=1000
+    volumes:
+      - ../coturn/turnserver.conf.example:/etc/coturn/turnserver.conf.example:ro
+    networks:
+      - turn_network
+
+networks:
+  turn_network:
+    driver: bridge
+
+secrets:
+  turn_shared_secret:
+    file: "${TURN_SHARED_SECRET_FILE:-/home/michael/matrix/secrets/turn_shared_secret}"
+  turn_tls_cert:
+    file: "${TURN_TLS_CERT_FILE:-/home/michael/matrix/secrets/turn_tls_cert.pem}"
+  turn_tls_key:
+    file: "${TURN_TLS_KEY_FILE:-/home/michael/matrix/secrets/turn_tls_key.pem}"
