@@ -0,0 +1,231 @@
+#!/usr/bin/env python3
+"""Minimal Matrix Client-Server API client for inbound sync polling."""
+
+import json
+import re
+import urllib.error
+import urllib.parse
+import urllib.request
+
+
+SYNC_FILTER = {"room": {"timeline": {"types": ["m.room.message"]}}}
+
+
+class MatrixClientError(RuntimeError):
+    """Base class for redacted Matrix client failures."""
+
+
+class MatrixRateLimitError(MatrixClientError):
+    """A retryable Matrix rate limit response."""
+
+    def __init__(self, retry_after_ms=None):
+        self.retry_after_ms = retry_after_ms
+        delay = f"{retry_after_ms} ms" if retry_after_ms is not None else "server guidance"
+        super().__init__(f"Matrix rate limited; retry after {delay}")
+
+
+class MatrixHTTPError(MatrixClientError):
+    """A redacted non-rate-limit Matrix HTTP response."""
+
+    def __init__(self, status):
+        self.status = status
+        self.retryable = status >= 500
+        super().__init__(f"Matrix HTTP request failed with status {status}")
+
+
+class MatrixTransportError(MatrixClientError):
+    """A retryable failure to reach the Matrix homeserver."""
+
+
+class MatrixResponseError(MatrixClientError):
+    """A Matrix response that is not valid JSON."""
+
+
+class MatrixMediaURIError(MatrixClientError):
+    """An attachment URI is not a strict Matrix Content URI."""
+
+
+class MatrixMediaTooLargeError(MatrixClientError):
+    """A media response exceeds the configured download limit."""
+
+
+class MatrixMediaTypeError(MatrixClientError):
+    """A media response does not provide its required content type."""
+
+
+class MatrixMediaTimeoutError(MatrixTransportError):
+    """A Matrix media download exceeded its request timeout."""
+
+
+MEDIA_ID = re.compile(r"^[A-Za-z0-9_-]+$")
+SERVER_NAME = re.compile(
+    r"^(?:[A-Za-z0-9.-]+|\[[0-9A-Fa-f:.]+\])(?::[0-9]{1,5})?$"
+)
+
+
+class MatrixRedirectHandler(urllib.request.HTTPRedirectHandler):
+    """Follow Matrix media redirects without leaking auth across origins."""
+
+    def redirect_request(self, request, fp, code, message, headers, new_url):
+        redirected = super().redirect_request(
+            request, fp, code, message, headers, new_url
+        )
+        if redirected is not None and _origin(request.full_url) != _origin(new_url):
+            redirected.remove_header("Authorization")
+        return redirected
+
+
+_MATRIX_OPENER = urllib.request.build_opener(MatrixRedirectHandler())
+
+
+def _matrix_urlopen(request, timeout):
+    return _MATRIX_OPENER.open(request, timeout=timeout)
+
+
+class MatrixClient:
+    """Perform bounded Matrix client-server requests without business logic."""
+
+    def __init__(
+        self,
+        homeserver_url,
+        access_token,
+        timeout_ms=30000,
+        request_timeout=35,
+        requester=None,
+    ):
+        self.homeserver_url = homeserver_url.rstrip("/")
+        self.access_token = access_token
+        self.timeout_ms = timeout_ms
+        self.request_timeout = request_timeout
+        self.requester = requester or _matrix_urlopen
+
+    def sync(self, cursor=None):
+        query = {
+            "timeout": str(self.timeout_ms),
+            "filter": json.dumps(SYNC_FILTER, separators=(",", ":")),
+        }
+        if cursor:
+            query["since"] = cursor
+        url = (
+            f"{self.homeserver_url}/_matrix/client/v3/sync?"
+            f"{urllib.parse.urlencode(query)}"
+        )
+        request = urllib.request.Request(
+            url,
+            headers={"Authorization": f"Bearer {self.access_token}"},
+        )
+        try:
+            with self.requester(request, timeout=self.request_timeout) as response:
+                payload = response.read()
+        except urllib.error.HTTPError as exc:
+            if exc.code == 429:
+                raise MatrixRateLimitError(_retry_after_ms(exc)) from None
+            raise MatrixHTTPError(exc.code) from None
+        except urllib.error.URLError:
+            raise MatrixTransportError("Matrix homeserver is unreachable") from None
+
+        try:
+            return json.loads(payload.decode("utf-8"))
+        except (UnicodeDecodeError, json.JSONDecodeError):
+            raise MatrixResponseError("Matrix response was not valid JSON") from None
+
+    def download_media(self, mxc_uri, max_bytes):
+        """Download an MXC object through this client's configured homeserver."""
+        if (
+            not isinstance(max_bytes, int)
+            or isinstance(max_bytes, bool)
+            or max_bytes < 1
+        ):
+            raise ValueError("max_bytes must be a positive integer")
+        server_name, media_id = _parse_mxc_uri(mxc_uri)
+        query = urllib.parse.urlencode({"timeout_ms": str(self.timeout_ms)})
+        url = (
+            f"{self.homeserver_url}/_matrix/client/v1/media/download/"
+            f"{urllib.parse.quote(server_name, safe='')}/"
+            f"{urllib.parse.quote(media_id, safe='')}?{query}"
+        )
+        request = urllib.request.Request(
+            url,
+            headers={"Authorization": f"Bearer {self.access_token}"},
+        )
+        try:
+            with self.requester(request, timeout=self.request_timeout) as response:
+                content_length = _content_length(response.headers)
+                if content_length is not None and content_length > max_bytes:
+                    raise MatrixMediaTooLargeError("Matrix media exceeds size limit")
+                content = response.read(max_bytes + 1)
+                if len(content) > max_bytes:
+                    raise MatrixMediaTooLargeError("Matrix media exceeds size limit")
+                content_type = response.headers.get("Content-Type")
+        except urllib.error.HTTPError as exc:
+            if exc.code == 429:
+                raise MatrixRateLimitError(_retry_after_ms(exc)) from None
+            if exc.code == 502:
+                raise MatrixMediaTooLargeError("Matrix media exceeds size limit") from None
+            raise MatrixHTTPError(exc.code) from None
+        except TimeoutError:
+            raise MatrixMediaTimeoutError("Matrix media download timed out") from None
+        except urllib.error.URLError:
+            raise MatrixTransportError("Matrix homeserver is unreachable") from None
+        if not isinstance(content_type, str) or not content_type.strip():
+            raise MatrixMediaTypeError("Matrix media response lacks Content-Type")
+        return {"content": content, "content_type": content_type}
+
+
+def _parse_mxc_uri(mxc_uri):
+    if not isinstance(mxc_uri, str):
+        raise MatrixMediaURIError("Matrix media URI must be a string")
+    try:
+        parsed = urllib.parse.urlsplit(mxc_uri)
+        username = parsed.username
+        password = parsed.password
+        port = parsed.port
+    except ValueError:
+        raise MatrixMediaURIError("invalid Matrix media URI") from None
+    path_parts = parsed.path.split("/")
+    if (
+        parsed.scheme != "mxc"
+        or not parsed.netloc
+        or not SERVER_NAME.fullmatch(parsed.netloc)
+        or username is not None
+        or password is not None
+        or (port is not None and port > 65535)
+        or parsed.query
+        or parsed.fragment
+        or len(path_parts) != 2
+        or path_parts[0] != ""
+        or not MEDIA_ID.fullmatch(path_parts[1])
+    ):
+        raise MatrixMediaURIError("invalid Matrix media URI")
+    return parsed.netloc, path_parts[1]
+
+
+def _content_length(headers):
+    try:
+        value = int(headers.get("Content-Length"))
+    except (AttributeError, TypeError, ValueError):
+        return None
+    return value if value >= 0 else None
+
+
+def _origin(url):
+    parsed = urllib.parse.urlsplit(url)
+    return parsed.scheme.lower(), parsed.hostname, parsed.port
+
+
+def _retry_after_ms(error):
+    try:
+        retry_after = error.headers.get("Retry-After")
+        retry_after_seconds = int(retry_after)
+        if retry_after_seconds >= 0:
+            return retry_after_seconds * 1000
+    except (AttributeError, TypeError, ValueError):
+        pass
+    try:
+        payload = json.loads(error.read().decode("utf-8"))
+        retry_after_ms = payload.get("retry_after_ms")
+        if isinstance(retry_after_ms, int) and retry_after_ms >= 0:
+            return retry_after_ms
+    except (AttributeError, UnicodeDecodeError, json.JSONDecodeError):
+        pass
+    return None
