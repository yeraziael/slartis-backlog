diff --git a/runtime/matrix/state_store.py b/runtime/matrix/state_store.py
new file mode 100644
index 0000000..1e62990
--- /dev/null
+++ b/runtime/matrix/state_store.py
@@ -0,0 +1,172 @@
+#!/usr/bin/env python3
+"""Durable Matrix cursor and processed-event state with atomic updates."""
+
+import fcntl
+import json
+import os
+import tempfile
+import uuid
+
+
+SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))
+SCHEMA_PATH = os.path.join(SCRIPT_DIR, "state.schema.json")
+MAX_ATTEMPTS = 2
+
+
+class StateStoreError(RuntimeError):
+    """Base class for fail-closed Matrix state errors."""
+
+    retryable = False
+
+
+class RetryableStateStoreError(StateStoreError):
+    """A storage operation failed and may succeed when retried."""
+
+    retryable = True
+
+
+class StateConflictError(StateStoreError):
+    """The requested transition conflicts with durable state."""
+
+
+class StateValidationError(StateStoreError):
+    """Input or persisted Matrix state violates the state contract."""
+
+
+class MatrixStateStore:
+    """Atomically claim and complete Matrix events in a JSON state file."""
+
+    def __init__(self, path, owner_id=None):
+        if not isinstance(path, (str, os.PathLike)):
+            raise StateValidationError("state path must be path-like")
+        if owner_id is None:
+            owner_id = uuid.uuid4().hex
+        if not isinstance(owner_id, str) or not owner_id:
+            raise StateValidationError("owner_id must be a non-empty string")
+        self.path = os.fspath(path)
+        self.lock_path = f"{self.path}.lock"
+        self.owner_id = owner_id
+
+    def claim(self, event_id):
+        """Claim an event, allowing one recovery claim from a new owner."""
+        _require_nonempty_string(event_id, "event_id")
+
+        def transition(state):
+            event = state["events"].get(event_id)
+            if event is None:
+                state["events"][event_id] = {
+                    "status": "claimed",
+                    "attempts": 1,
+                    "owner": self.owner_id,
+                }
+                return True, True
+            if event["status"] == "completed":
+                return False, False
+            if event["owner"] == self.owner_id or event["attempts"] >= MAX_ATTEMPTS:
+                return False, False
+            event["owner"] = self.owner_id
+            event["attempts"] += 1
+            return True, True
+
+        return self._transaction(transition)
+
+    def complete(self, event_id, cursor):
+        """Atomically complete the current owner's claim and advance cursor."""
+        _require_nonempty_string(event_id, "event_id")
+        _require_nonempty_string(cursor, "cursor")
+
+        def transition(state):
+            event = state["events"].get(event_id)
+            if event is None:
+                raise StateConflictError("event must be claimed before completion")
+            if event["status"] == "completed":
+                return False, False
+            if event["owner"] != self.owner_id:
+                raise StateConflictError("claim belongs to another store owner")
+            event["status"] = "completed"
+            state["cursor"] = cursor
+            return True, True
+
+        return self._transaction(transition)
+
+    def is_processed(self, event_id):
+        """Return whether an event has durably completed processing."""
+        _require_nonempty_string(event_id, "event_id")
+
+        def query(state):
+            event = state["events"].get(event_id)
+            return bool(event and event["status"] == "completed"), False
+
+        return self._transaction(query)
+
+    def get_cursor(self):
+        """Return the last cursor committed with a completed event."""
+        return self._transaction(lambda state: (state["cursor"], False))
+
+    def _transaction(self, operation):
+        directory = os.path.dirname(os.path.abspath(self.path))
+        try:
+            os.makedirs(directory, mode=0o700, exist_ok=True)
+            with open(self.lock_path, "a+", encoding="utf-8") as lock_file:
+                os.chmod(self.lock_path, 0o600)
+                fcntl.flock(lock_file.fileno(), fcntl.LOCK_EX)
+                state = _load_state(self.path)
+                result, changed = operation(state)
+                if changed:
+                    _validate_state(state)
+                    _atomic_write(self.path, state)
+                return result
+        except StateStoreError:
+            raise
+        except OSError as exc:
+            raise RetryableStateStoreError("Matrix state storage is unavailable") from exc
+
+
+def _load_state(path):
+    if not os.path.exists(path):
+        return {"schema_version": 1, "cursor": None, "events": {}}
+    try:
+        with open(path, encoding="utf-8") as state_file:
+            state = json.load(state_file)
+    except json.JSONDecodeError as exc:
+        raise StateValidationError("persisted Matrix state is invalid JSON") from exc
+    _validate_state(state)
+    return state
+
+
+def _validate_state(state):
+    import jsonschema
+
+    try:
+        with open(SCHEMA_PATH, encoding="utf-8") as schema_file:
+            schema = json.load(schema_file)
+        jsonschema.Draft7Validator(schema).validate(state)
+    except (json.JSONDecodeError, jsonschema.SchemaError) as exc:
+        raise StateValidationError("Matrix state schema is invalid") from exc
+    except jsonschema.ValidationError as exc:
+        raise StateValidationError("persisted Matrix state violates its schema") from exc
+
+
+def _atomic_write(path, state):
+    directory = os.path.dirname(os.path.abspath(path))
+    descriptor, temporary_path = tempfile.mkstemp(prefix=".matrix-state-", dir=directory)
+    try:
+        with os.fdopen(descriptor, "w", encoding="utf-8") as temporary_file:
+            json.dump(state, temporary_file, sort_keys=True, separators=(",", ":"))
+            temporary_file.write("\n")
+            temporary_file.flush()
+            os.fsync(temporary_file.fileno())
+        os.replace(temporary_path, path)
+        directory_descriptor = os.open(directory, os.O_RDONLY | os.O_DIRECTORY)
+        try:
+            os.fsync(directory_descriptor)
+        finally:
+            os.close(directory_descriptor)
+    finally:
+        if os.path.exists(temporary_path):
+            os.unlink(temporary_path)
+
+
+def _require_nonempty_string(value, name):
+    if not isinstance(value, str) or not value:
+        raise StateValidationError(f"{name} must be a non-empty string")
