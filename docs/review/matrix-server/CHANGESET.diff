@@ -0,0 +1,116 @@
+#!/usr/bin/env bash
+# Static contract tests for the private Element Web deployment.
+set -euo pipefail
+
+REPO_ROOT="$(cd "$(dirname "$0")/../.." && pwd)"
+
+python3 - \
+  "$REPO_ROOT/pi/compose/element.yml" \
+  "$REPO_ROOT/pi/element/config.json.example" \
+  "$REPO_ROOT/docs/matrix/element.md" <<'PY'
+from pathlib import Path
+import json
+import re
+import sys
+
+import yaml
+
+
+def require(condition, message):
+    if not condition:
+        raise SystemExit(f"FAIL: {message}")
+    print(f"PASS: {message}")
+
+
+compose_path, config_path, docs_path = (Path(value) for value in sys.argv[1:])
+for path in (compose_path, config_path, docs_path):
+    require(path.is_file(), f"required input exists: {path}")
+
+compose = yaml.safe_load(compose_path.read_text(encoding="utf-8"))
+require(set(compose.get("services", {})) == {"element"}, "stack defines only Element Web")
+element = compose["services"]["element"]
+require(
+    element.get("image") ==
+    "docker.io/vectorim/element-web@sha256:2a65f32acc6fd7163523d1c4b5174de354b5ceb085898b15898f4d8ea01a8e3d",
+    "Element Web v1.12.23 OCI index is pinned by immutable digest",
+)
+require(element.get("platform") == "linux/arm64", "Element Web explicitly selects ARM64")
+require(element.get("restart") == "unless-stopped", "Element Web has a restart policy")
+require("ports" not in element, "Element Web publishes no host port")
+require(set(element.get("expose", [])) == {"8080"}, "Element Web exposes only internal HTTP port 8080")
+require(element.get("networks") == ["frontproxy_default"], "Element Web joins only frontproxy_default")
+require(
+    compose.get("networks") == {"frontproxy_default": {"external": True}},
+    "frontproxy_default is the only declared network and is external",
+)
+expected_environment = {
+    "ELEMENT_WEB_PORT": "8080",
+    "VIRTUAL_HOST": "element.hl.maier.wtf",
+    "VIRTUAL_PORT": "8080",
+    "LETSENCRYPT_HOST": "element.hl.maier.wtf",
+    "LETSENCRYPT_EMAIL": "webmaster@maier.wtf",
+}
+require(element.get("environment") == expected_environment, "proxy, ACME, and internal HTTP environment is exact")
+require(
+    element.get("volumes") == ["../element/config.json.example:/app/config.json:ro"],
+    "only the static non-secret Element configuration is mounted read-only",
+)
+require("secrets" not in element and "configs" not in element, "Element Web declares no secrets or extra configs")
+require("no-new-privileges:true" in element.get("security_opt", []), "Element Web blocks privilege escalation")
+require("mem_limit" in element and "cpus" in element, "Element Web has CPU and memory limits")
+logging = element.get("logging", {}).get("options", {})
+require(logging == {"max-size": "10m", "max-file": "7"}, "Element Web logs are bounded")
+
+config = json.loads(config_path.read_text(encoding="utf-8"))
+require(
+    config.get("default_server_config") == {
+        "m.homeserver": {
+            "base_url": "https://matrix.hl.maier.wtf",
+            "server_name": "matrix.hl.maier.wtf",
+        }
+    },
+    "Element Web points only to the private HTTPS homeserver",
+)
+require(config.get("disable_custom_urls") is True, "custom homeserver URLs are disabled")
+require(config.get("enable_client_well_known_lookups") is False, "runtime homeserver discovery is disabled")
+require(config.get("disable_guests") is True, "guest access is disabled")
+require(config.get("disable_3pid_login") is True, "third-party identifier login is disabled")
+for key in ("integrations_ui_url", "integrations_rest_url", "integrations_widgets_urls"):
+    require(key in config and config[key] is None, f"{key} is explicitly disabled")
+
+settings = config.get("setting_defaults", {})
+for key in (
+    "UIFeature.registration",
+    "UIFeature.allowCreatingPublicRooms",
+    "UIFeature.allowCreatingPublicSpaces",
+    "UIFeature.widgets",
+    "UIFeature.identityServer",
+    "UIFeature.thirdPartyId",
+    "UIFeature.voip",
+):
+    require(settings.get(key) is False, f"{key} is disabled")
+require(config.get("element_call") == {"disabled": True}, "Element Call integration is disabled")
+for key in ("posthog", "sentry", "bug_report_endpoint_url", "analytics_owner", "privacy_policy_url"):
+    require(key not in config, f"analytics/telemetry key is absent: {key}")
+
+serialized = json.dumps(config, sort_keys=True)
+urls = set(re.findall(r"https?://[^\"\\s]+", serialized))
+require(urls == {"https://matrix.hl.maier.wtf"}, "configuration contains no external service URL")
+require(
+    not re.search(r'(?i)(password|passwd|secret|token|api[_-]?key|credential)', serialized),
+    "configuration contains no credential or token keys",
+)
+
+docs = docs_path.read_text(encoding="utf-8")
+for required in (
+    "Prerequisites",
+    "Manual post-merge deployment",
+    "https://element.hl.maier.wtf",
+    "https://matrix.hl.maier.wtf/.well-known/matrix/client",
+    "private account",
+    "Rollback",
+    "docker compose -f pi/compose/element.yml config",
+    "sha256:f3cf1b621a985e1eebbc1ee8a6bd9dae430cf415a17384c482d3fa753c90f232",
+):
+    require(required in docs, f"operator documentation contains: {required}")
+PY
