+#!/usr/bin/env bash
+# test_synapse_poc.sh — Static assertions for the Synapse ARM64 PoC Compose file.
+#
+# Validates:
+#   1. Compose file exists and is valid YAML
+#   2. Security / isolation requirements (no published ports, no frontproxy,
+#      no federation, no OIDC)
+#   3. Immutable image digests (ARM64-capable multi-arch)
+#   4. Resource limits (CPU, RAM)
+#   5. Healthchecks on both services
+#   6. Compose topology (expected services, volumes, dependencies)
+#
+# Run from repo root: bash pi/tests/test_synapse_poc.sh
+set -uo pipefail
+
+REPO_ROOT="$(cd "$(dirname "$0")/../.." && pwd)"
+COMPOSE_FILE="$REPO_ROOT/pi/compose/synapse-poc.yml"
+HOMESERVER_FILE="$REPO_ROOT/pi/synapse-poc/homeserver.yaml"
+PASS=0
+FAIL=0
+
+pass() { PASS=$((PASS + 1)); echo "  PASS  $1"; }
+fail() { FAIL=$((FAIL + 1)); echo "  FAIL  $1: $2"; }
+
+# ---------------------------------------------------------------------------
+# Helper: run a Python YAML query on the compose file
+# ---------------------------------------------------------------------------
+yq() {
+  python3 -c "
+import yaml, sys
+with open('$COMPOSE_FILE') as f:
+    data = yaml.safe_load(f)
+try:
+    result = $1
+    if result is None:
+        sys.exit(1)
+    if isinstance(result, list):
+        for item in result:
+            print(item)
+    elif isinstance(result, bool):
+        print(str(result))
+        sys.exit(0 if result else 1)
+    elif isinstance(result, (int, float)):
+        print(result)
+    else:
+        print(result)
+except (KeyError, IndexError, TypeError) as e:
+    sys.exit(1)
+" 2>&1
+}
+
+# Helper: run a Python YAML query on the homeserver file
+yq_hs() {
+  python3 -c "
+import yaml, sys
+with open('$HOMESERVER_FILE') as f:
+    data = yaml.safe_load(f)
+try:
+    result = $1
+    if result is None:
+        sys.exit(1)
+    if isinstance(result, list):
+        for item in result:
+            print(item)
+    elif isinstance(result, bool):
+        print(str(result))
+        sys.exit(0 if result else 1)
+    elif isinstance(result, (int, float)):
+        print(result)
+    else:
+        print(result)
+except (KeyError, IndexError, TypeError) as e:
+    sys.exit(1)
+" 2>&1
+}
+
+# Usage: assert_yq <test_name> <python_expression> [expected_output]
+assert_yq() {
+  local name="$1" expr="$2" expected="${3-}"
+  local output
+  output=$(yq "$expr" 2>&1) || {
+    fail "$name" "expression '$expr' returned no data"
+    return
+  }
+  if [[ -n "$expected" ]]; then
+    if [[ "$output" == "$expected" ]]; then
+      pass "$name"
+    else
+      fail "$name" "expected '$expected', got '$output'"
+    fi
+  else
+    # Just check that it exists and is non-empty
+    if [[ -n "$output" ]]; then
+      pass "$name"
+    else
+      fail "$name" "expression '$expr' returned empty"
+    fi
+  fi
+}
+
+# ---------------------------------------------------------------------------
+# 1. Compose file exists and is valid YAML
+# ---------------------------------------------------------------------------
+test_compose_file_exists() {
+  if [[ -f "$COMPOSE_FILE" ]]; then
+    pass "compose file exists"
+  else
+    fail "compose file exists" "not found at $COMPOSE_FILE"
+  fi
+}
+
+test_compose_file_is_valid_yaml() {
+  if python3 -c "
+import yaml, sys
+try:
+    with open('$COMPOSE_FILE') as f:
+        yaml.safe_load(f)
+    sys.exit(0)
+except yaml.YAMLError as e:
+    print(f'YAML error: {e}')
+    sys.exit(1)
+" 2>&1; then
+    pass "compose file is valid YAML"
+  else
+    fail "compose file is valid YAML" "YAML validation failed"
+  fi
+}
+
+# ---------------------------------------------------------------------------
+# 2. Security / isolation requirements
+# ---------------------------------------------------------------------------
+test_no_published_ports() {
+  local output
+  output=$(yq "data.get('services', {}).get('synapse', {}).get('ports', None)") || {
+    pass "synapse: no ports section (isolated)"
+    return
+  }
+  fail "synapse: no ports section" "found ports: $output"
+}
+
+test_no_frontproxy_network() {
+  local output
+  output=$(yq "'frontproxy_default' in str(data.get('services', {}).get('synapse', {}).get('networks', {})) or 'frontproxy_default' in str(data.get('networks', {}))") || {
+    pass "no frontproxy_default network reference"
+    return
+  }
+  fail "no frontproxy_default network reference" "found frontproxy_default reference"
+}
+
+test_no_external_networks() {
+  local output
+  output=$(yq "any(n.get('external', False) for n in data.get('networks', {}).values())") 2>&1 && {
+    fail "no external networks" "found external network definition"
+    return
+  }
+  pass "no external networks defined"
+}
+
+test_no_environment_secrets() {
+  local syn_env
+  syn_env=$(yq "data.get('services', {}).get('synapse', {}).get('environment', {})") || syn_env=""
+  if echo "$syn_env" | grep -qiE '(password|secret|token|key)'; then
+    fail "synapse environment: no secrets" "found potential secret in environment"
+  else
+    pass "synapse environment: no secrets exposed"
+  fi
+}
+
+test_no_federation_config() {
+  # Federation is disabled by not publishing ports and not setting federation-related
+  # environment. Check that no SYNAPSE_FEDERATION or federation-related vars exist.
+  local syn_env
+  syn_env=$(yq "str(data.get('services', {}).get('synapse', {}).get('environment', {}))") || syn_env=""
+  if echo "$syn_env" | grep -qi 'federation'; then
+    fail "no federation configuration" "found federation reference in environment"
+  else
+    pass "no federation configuration in environment"
+  fi
+}
+
+test_no_oidc_config() {
+  local syn_env
+  syn_env=$(yq "str(data.get('services', {}).get('synapse', {}).get('environment', {}))") || syn_env=""
+  if echo "$syn_env" | grep -qiE '(oidc|keycloak|sso)'; then
+    fail "no OIDC configuration" "found OIDC reference in environment"
+  else
+    pass "no OIDC configuration in PoC"
+  fi
+}
+
+test_container_name_isolation() {
+  assert_yq "synapse container_name has poc prefix" \
+    "data.get('services', {}).get('synapse', {}).get('container_name', '')" \
+    "synapse-poc"
+  assert_yq "postgres container_name has poc prefix" \
+    "data.get('services', {}).get('postgres', {}).get('container_name', '')" \
+    "synapse-poc-db"
+}
+
+# ---------------------------------------------------------------------------
+# 3. Immutable image digests (ARM64-capable)
+# ---------------------------------------------------------------------------
+test_synapse_image_is_pinned_by_digest() {
+  local image
+  image=$(yq "data.get('services', {}).get('synapse', {}).get('image', '')") || {
+    fail "synapse image" "could not read image field"
+    return
+  }
+  if echo "$image" | grep -q '@sha256:'; then
+    pass "synapse image is pinned by digest: $image"
+  else
+    fail "synapse image is pinned by digest" "no @sha256: found in '$image'"
+  fi
+}
+
+test_postgres_image_is_pinned_by_digest() {
+  local image
+  image=$(yq "data.get('services', {}).get('postgres', {}).get('image', '')") || {
+    fail "postgres image" "could not read image field"
+    return
+  }
+  if echo "$image" | grep -q '@sha256:'; then
+    pass "postgres image is pinned by digest: $image"
+  else
+    fail "postgres image is pinned by digest" "no @sha256: found in '$image'"
+  fi
+}
+
+test_synapse_image_is_multiarch() {
+  local image
+  image=$(yq "data.get('services', {}).get('synapse', {}).get('image', '')") || {
+    fail "synapse image source check" "could not read image field"
+    return
+  }
+  # Check that it's from ghcr.io/element-hq which is known to be multi-arch
+  if echo "$image" | grep -q 'ghcr.io/element-hq/synapse'; then
+    pass "synapse image from ghcr.io/element-hq (multi-arch, includes arm64)"
+  else
+    fail "synapse image source" "expected ghcr.io/element-hq/synapse, got '$image'"
+  fi
+}
+
+test_postgres_image_is_multiarch() {
+  local image
+  image=$(yq "data.get('services', {}).get('postgres', {}).get('image', '')") || {
+    fail "postgres image source check" "could not read image field"
+    return
+  }
+  if echo "$image" | grep -q 'postgres'; then
+    pass "postgres image from docker.io/library (multi-arch, includes arm64)"
+  else
+    fail "postgres image source" "expected docker.io/library/postgres, got '$image'"
+  fi
+}
+
+# ---------------------------------------------------------------------------
+# 4. Resource limits
+# ---------------------------------------------------------------------------
+test_synapse_has_cpu_limit() {
+  assert_yq "synapse: CPU limit defined" \
+    "data.get('services', {}).get('synapse', {}).get('deploy', {}).get('resources', {}).get('limits', {}).get('cpus', None)"
+}
+
+test_synapse_has_memory_limit() {
+  assert_yq "synapse: memory limit defined" \
+    "data.get('services', {}).get('synapse', {}).get('deploy', {}).get('resources', {}).get('limits', {}).get('memory', None)"
+}
+
+test_postgres_has_cpu_limit() {
+  assert_yq "postgres: CPU limit defined" \
+    "data.get('services', {}).get('postgres', {}).get('deploy', {}).get('resources', {}).get('limits', {}).get('cpus', None)"
+}
+
+test_postgres_has_memory_limit() {
+  assert_yq "postgres: memory limit defined" \
+    "data.get('services', {}).get('postgres', {}).get('deploy', {}).get('resources', {}).get('limits', {}).get('memory', None)"
+}
+
+# ---------------------------------------------------------------------------
+# 5. Healthchecks
+# ---------------------------------------------------------------------------
+test_synapse_has_healthcheck() {
+  assert_yq "synapse: healthcheck defined" \
+    "data.get('services', {}).get('synapse', {}).get('healthcheck', None)"
+}
+
+test_postgres_has_healthcheck() {
+  assert_yq "postgres: healthcheck defined" \
+    "data.get('services', {}).get('postgres', {}).get('healthcheck', None)"
+}
+
+test_synapse_healthcheck_tests_exist() {
+  local test_cmd
+  test_cmd=$(yq "data.get('services', {}).get('synapse', {}).get('healthcheck', {}).get('test', [])") || {
+    fail "synapse healthcheck test" "could not read test command"
+    return
+  }
+  if echo "$test_cmd" | grep -qiE '(curl|wget|python)'; then
+    pass "synapse healthcheck includes HTTP probe"
+  else
+    fail "synapse healthcheck test" "expected curl/wget/python probe, got '$test_cmd'"
+  fi
+}
+
+test_postgres_healthcheck_tests_exist() {
+  assert_yq "postgres: healthcheck test command exists" \
+    "data.get('services', {}).get('postgres', {}).get('healthcheck', {}).get('test', None)"
+}
+
+# ---------------------------------------------------------------------------
+# 6. Compose topology
+# ---------------------------------------------------------------------------
+test_expected_services() {
+  local services
+  services=$(yq "list(data.get('services', {}).keys())") || {
+    fail "expected services" "could not list services"
+    return
+  }
+  if echo "$services" | grep -q 'synapse' && echo "$services" | grep -q 'postgres'; then
+    pass "expected services present: synapse, postgres"
+  else
+    fail "expected services" "expected synapse and postgres, got: $services"
+  fi
+}
+
+test_expected_volumes() {
+  local volumes
+  volumes=$(yq "list(data.get('volumes', {}).keys())") || {
+    fail "expected volumes" "could not list volumes"
+    return
+  }
+  if echo "$volumes" | grep -q 'synapse_data' && echo "$volumes" | grep -q 'synapse_media' && echo "$volumes" | grep -q 'synapse_db'; then
+    pass "expected volumes present: synapse_data, synapse_media, synapse_db"
+  else
+    fail "expected volumes" "expected synapse_data, synapse_media, synapse_db, got: $volumes"
+  fi
+}
+
+test_postgres_depends_on_synapse() {
+  # Actually synapse depends on postgres, not the other way around
+  local deps
+  deps=$(yq "data.get('services', {}).get('synapse', {}).get('depends_on', [])") || {
+    fail "synapse depends_on postgres" "could not read depends_on"
+    return
+  }
+  if echo "$deps" | grep -q 'postgres'; then
+    pass "synapse depends on postgres"
+  else
+    fail "synapse depends_on postgres" "expected 'postgres' in depends_on, got: $deps"
+  fi
+}
+
+test_no_extra_services() {
+  local services
+  services=$(yq "list(data.get('services', {}).keys())") || {
+    fail "no extra services" "could not list services"
+    return
+  }
+  local count
+  count=$(echo "$services" | wc -l)
+  if [[ "$count" -eq 2 ]]; then
+    pass "exactly 2 services (synapse + postgres, no extras)"
+  else
+    fail "exactly 2 services" "found $count services: $services"
+  fi
+}
+
+# ---------------------------------------------------------------------------
+# 7. HDD-backed driver_opts for all volumes (Correction 1)
+# ---------------------------------------------------------------------------
+test_volume_driver_opts_exist() {
+  local vol="$1"
+  local opts
+  opts=$(yq "data.get('volumes', {}).get('$vol', {}).get('driver_opts', None)") || {
+    fail "$vol: driver_opts defined" "missing driver_opts for $vol"
+    return
+  }
+  pass "$vol: driver_opts defined"
+}
+
+test_volume_driver_opts_type() {
+  local vol="$1"
+  local type_val
+  type_val=$(yq "data.get('volumes', {}).get('$vol', {}).get('driver_opts', {}).get('type', '')") || {
+    fail "$vol: driver_opts type" "could not read type"
+    return
+  }
+  if [[ "$type_val" == "none" ]]; then
+    pass "$vol: driver_opts type is 'none'"
+  else
+    fail "$vol: driver_opts type" "expected 'none', got '$type_val'"
+  fi
+}
+
+test_volume_driver_opts_o() {
+  local vol="$1"
+  local o_val
+  o_val=$(yq "data.get('volumes', {}).get('$vol', {}).get('driver_opts', {}).get('o', '')") || {
+    fail "$vol: driver_opts o" "could not read o"
+    return
+  }
+  if [[ "$o_val" == "bind" ]]; then
+    pass "$vol: driver_opts o is 'bind'"
+  else
+    fail "$vol: driver_opts o" "expected 'bind', got '$o_val'"
+  fi
+}
+
+test_volume_driver_opts_device() {
+  local vol="$1" expected_device="$2"
+  local dev_val
+  dev_val=$(yq "data.get('volumes', {}).get('$vol', {}).get('driver_opts', {}).get('device', '')") || {
+    fail "$vol: driver_opts device" "could not read device"
+    return
+  }
+  if [[ "$dev_val" == "$expected_device" ]]; then
+    pass "$vol: driver_opts device is '$expected_device'"
+  else
+    fail "$vol: driver_opts device" "expected '$expected_device', got '$dev_val'"
+  fi
+}
+
+# ---------------------------------------------------------------------------
+# 8. Versioned homeserver.yaml (Correction 2)
+# ---------------------------------------------------------------------------
+test_homeserver_yaml_exists() {
+  if [[ -f "$HOMESERVER_FILE" ]]; then
+    pass "homeserver.yaml exists at pi/synapse-poc/homeserver.yaml"
+  else
+    fail "homeserver.yaml exists" "not found at $HOMESERVER_FILE"
+  fi
+}
+
+test_homeserver_yaml_is_valid_yaml() {
+  if python3 -c "
+import yaml, sys
+try:
+    with open('$HOMESERVER_FILE') as f:
+        yaml.safe_load(f)
+    sys.exit(0)
+except yaml.YAMLError as e:
+    print(f'YAML error: {e}')
+    sys.exit(1)
+" 2>&1; then
+    pass "homeserver.yaml is valid YAML"
+  else
+    fail "homeserver.yaml is valid YAML" "YAML validation failed"
+  fi
+}
+
+test_homeserver_yaml_listener_only_client() {
+  # Check that every listener's resources contain only 'client', never 'federation'
+  local listener_names
+  listener_names=$(yq_hs "[r.get('names', []) for l in data.get('listeners', []) for r in l.get('resources', [])]") || {
+    fail "homeserver: listener resources" "could not read listener resources"
+    return
+  }
+  if echo "$listener_names" | grep -q 'federation'; then
+    fail "homeserver: listener resources" "found 'federation' in listener resources (only 'client' allowed)"
+    return
+  fi
+  if echo "$listener_names" | grep -q 'client'; then
+    pass "homeserver: listeners expose only 'client' resource (no federation)"
+  else
+    fail "homeserver: listener resources" "no 'client' resource found in listeners"
+  fi
+}
+
+test_homeserver_yaml_no_federation_listener() {
+  # Check that no listener declares a 'federation' resource and no federation_port exists
+  local federation_port
+  federation_port=$(yq_hs "data.get('federation_port', None)") && {
+    fail "homeserver: no federation_port" "found federation_port: $federation_port"
+    return
+  }
+  pass "homeserver: no federation_port declared"
+
+  local listener_count
+  listener_count=$(yq_hs "len(data.get('listeners', []))") || {
+    fail "homeserver: listeners" "could not count listeners"
+    return
+  }
+  if [[ "$listener_count" -ge 1 ]]; then
+    pass "homeserver: has $listener_count listener(s)"
+  else
+    fail "homeserver: listeners" "expected at least 1 listener, found $listener_count"
+  fi
+}
+
+test_homeserver_yaml_mounted_in_compose() {
+  local volumes_str
+  volumes_str=$(yq "str(data.get('services', {}).get('synapse', {}).get('volumes', []))") || {
+    fail "homeserver mounted in compose" "could not read synapse volumes"
+    return
+  }
+  if echo "$volumes_str" | grep -q 'homeserver.yaml'; then
+    pass "homeserver.yaml is mounted in compose (synapse volumes)"
+  else
+    fail "homeserver mounted in compose" "no reference to homeserver.yaml in synapse volumes"
+  fi
+}
+
+# ---------------------------------------------------------------------------
+# 10. Corrected bind-mount path resolution (Retry 2 — Correction 1)
+# ---------------------------------------------------------------------------
+test_config_bind_mount_source_is_correct() {
+  # Search for the volume entry with type: bind (index 2, the config mount)
+  local source
+  source=$(yq "[v for v in data.get('services', {}).get('synapse', {}).get('volumes', []) if isinstance(v, dict) and v.get('type') == 'bind'][0].get('source', '')") || {
+    fail "bind mount source" "could not read bind mount source"
+    return
+  }
+  # Expected: ../synapse-poc/homeserver.yaml (resolves from pi/compose/ to pi/synapse-poc/)
+  local expected="../synapse-poc/homeserver.yaml"
+  if [[ "$source" == "$expected" ]]; then
+    pass "bind mount source is '$expected' (resolves from pi/compose/ to pi/synapse-poc/homeserver.yaml)"
+  else
+    fail "bind mount source" "expected '$expected', got '$source'"
+  fi
+}
+
+test_config_bind_mount_is_type_bind() {
+  # Search for the volume entry with type: bind (the config mount)
+  local vol_entry
+  vol_entry=$(yq "[v for v in data.get('services', {}).get('synapse', {}).get('volumes', []) if isinstance(v, dict) and v.get('type') == 'bind'][0]") || {
+    fail "bind mount type" "could not find bind mount in synapse volumes"
+    return
+  }
+  pass "synapse volumes include a type:bind mount (the config bind mount)"
+}
+
+test_bind_mount_source_file_exists() {
+  # From the compose file directory (pi/compose/), the source ../synapse-poc/homeserver.yaml
+  # must resolve to pi/synapse-poc/homeserver.yaml which must exist.
+  local compose_dir
+  compose_dir="$(dirname "$COMPOSE_FILE")"  # pi/compose
+  local resolved
+  resolved="$(cd "$compose_dir" && realpath -m "../synapse-poc/homeserver.yaml" 2>/dev/null)" || {
+    fail "bind mount source file exists" "could not resolve path from compose dir"
+    return
+  }
+  if [[ -f "$resolved" ]]; then
+    pass "bind mount source resolves to existing file: $resolved"
+  else
+    fail "bind mount source file exists" "resolved path $resolved does not exist"
+  fi
+}
+
+test_old_wrong_bind_mount_path_rejected() {
+  # The old wrong path pi/compose/synapse-poc/homeserver.yaml must NOT exist.
+  local wrong
+  wrong="$(dirname "$COMPOSE_FILE")/synapse-poc/homeserver.yaml"
+  if [[ -f "$wrong" ]]; then
+    fail "old wrong bind mount path" "REJECTED: $wrong must not exist (wrong resolution)"
+  else
+    pass "old wrong bind mount path rejected: $wrong does not exist"
+  fi
+}
+
+# ---------------------------------------------------------------------------
+# 11. Runtime config assertions (Retry 2 — Corrections 2 & 3)
+# ---------------------------------------------------------------------------
+test_homeserver_yaml_signing_key_path() {
+  local sk_path
+  sk_path=$(yq_hs "data.get('signing_key_path', None)") || {
+    fail "homeserver: signing_key_path" "signing_key_path is not set"
+    return
+  }
+  if echo "$sk_path" | grep -qE '^/data/'; then
+    pass "homeserver: signing_key_path is '$sk_path' (under /data, i.e. HDD data volume)"
+  else
+    fail "homeserver: signing_key_path" "expected path under /data, got '$sk_path'"
+  fi
+}
+
+test_homeserver_yaml_no_log_config() {
+  # log_config must not be set — Synapse defaults to stdout logging
+  local lc
+  lc=$(yq_hs "data.get('log_config', None)") && {
+    fail "homeserver: no log_config" "log_config is set to '$lc' (should be unset/null for stdout)"
+    return
+  }
+  pass "homeserver: log_config is not set (Synapse logs to stdout by default)"
+}
+
+test_config_paths_are_not_dangling() {
+  # Assert that every file path referenced in the versioned config exists
+  # at the runtime mount target. For each path, if it's under /data we check
+  # that it's either auto-generated by Synapse or mapped via versioned file.
+  # Non-dangling means: signing_key_path is auto-created by Synapse, no log_config.
+
+  local sk_path
+  sk_path=$(yq_hs "data.get('signing_key_path', '')") || sk_path=""
+  if [[ -z "$sk_path" ]]; then
+    fail "config paths not dangling" "signing_key_path must be set"
+    return
+  fi
+  # signing_key_path is under /data so it's created by Synapse at runtime
+  if echo "$sk_path" | grep -qE '^/data/'; then
+    pass "config paths: signing_key_path '$sk_path' is under /data (auto-created)"
+  else
+    fail "config paths not dangling" "signing_key_path '$sk_path' not under /data"
+  fi
+
+  # Verify that no other path reference is dangling
+  local log_cfg
+  log_cfg=$(yq_hs "data.get('log_config', None)") && {
+    fail "config paths not dangling" "log_config is set to '$log_cfg' but no log config file is mounted"
+    return
+  }
+  pass "config paths: no dangling log_config reference (not set — stdout default)"
+}
+
+# ---------------------------------------------------------------------------
+# 9. Exact pinned image digests (Correction 4)
+# ---------------------------------------------------------------------------
+test_synapse_image_expected_digest() {
+  local image
+  image=$(yq "data.get('services', {}).get('synapse', {}).get('image', '')") || {
+    fail "synapse image digest" "could not read image field"
+    return
+  }
+  local expected="ghcr.io/element-hq/synapse@sha256:6882d26594b87171e0fe807ac6bd7f0000665cd70e73fb88c58ec9bff14c19ce"
+  if [[ "$image" == "$expected" ]]; then
+    pass "synapse image has expected pinned digest"
+  else
+    fail "synapse image digest" "expected '$expected', got '$image'"
+  fi
+}
+
+test_postgres_image_expected_digest() {
+  local image
+  image=$(yq "data.get('services', {}).get('postgres', {}).get('image', '')") || {
+    fail "postgres image digest" "could not read image field"
+    return
+  }
+  local expected="docker.io/library/postgres@sha256:742f40ea20b9ff2ff31db5458d127452988a2164df9e17441e191f3b72252193"
+  if [[ "$image" == "$expected" ]]; then
+    pass "postgres image has expected pinned digest"
+  else
+    fail "postgres image digest" "expected '$expected', got '$image'"
+  fi
+}
+
+# ---------------------------------------------------------------------------
+# 12. Bootstrap command validation (Retry 3 — explicit bootstrap before compose)
+# ---------------------------------------------------------------------------
+PLAN_FILE="$REPO_ROOT/docs/matrix/poc-plan.md"
+
+test_plan_file_exists() {
+  if [[ -f "$PLAN_FILE" ]]; then
+    pass "plan file exists at docs/matrix/poc-plan.md"
+  else
+    fail "plan file exists" "not found at $PLAN_FILE"
+  fi
+}
+
+test_bootstrap_has_generate_config() {
+  if grep -q -- '--generate-config' "$PLAN_FILE"; then
+    pass "plan documents --generate-config flag"
+  else
+    fail "plan documents --generate-config" "not found in plan"
+  fi
+}
+
+test_bootstrap_has_config_path() {
+  if grep -q -- '--config-path /data/bootstrap.yaml' "$PLAN_FILE"; then
+    pass "plan documents --config-path /data/bootstrap.yaml"
+  else
+    fail "plan documents --config-path" "not found in plan"
+  fi
+}
+
+test_bootstrap_has_server_name() {
+  if grep -q -- '--server-name synapse-poc.local' "$PLAN_FILE"; then
+    pass "plan documents --server-name synapse-poc.local"
+  else
+    fail "plan documents --server-name" "not found in plan"
+  fi
+}
+
+test_bootstrap_has_report_stats() {
+  if grep -q -- '--report-stats=no' "$PLAN_FILE"; then
+    pass "plan documents --report-stats=no"
+  else
+    fail "plan documents --report-stats" "not found in plan"
+  fi
+}
+
+test_bootstrap_has_pinned_digest() {
+  if grep -q -- 'ghcr.io/element-hq/synapse@sha256:6882d26594b87171e0fe807ac6bd7f0000665cd70e73fb88c58ec9bff14c19ce' "$PLAN_FILE"; then
+    pass "plan documents pinned synapse digest in bootstrap command"
+  else
+    fail "plan documents pinned digest" "not found in plan"
+  fi
+}
+
+test_bootstrap_has_cleanup() {
+  if grep -q -- 'rm -f /mnt/hardDrive/docker/synapse-poc/data/bootstrap.yaml' "$PLAN_FILE"; then
+    pass "plan documents bootstrap.yaml cleanup after generation"
+  else
+    fail "plan documents bootstrap.yaml cleanup" "not found in plan"
+  fi
+}
+
+test_bootstrap_has_entrypoint_python3() {
+  if grep -q -- '--entrypoint python3' "$PLAN_FILE"; then
+    pass "plan documents --entrypoint python3 in bootstrap command"
+  else
+    fail "plan documents --entrypoint python3" "not found in plan"
+  fi
+}
+
+test_bootstrap_has_rm_flag() {
+  if grep -q -- '--rm' "$PLAN_FILE"; then
+    pass "plan documents --rm flag in bootstrap command"
+  else
+    fail "plan documents --rm flag" "not found in plan"
+  fi
+}
+
+test_bootstrap_has_hdd_mount() {
+  if grep -q -- '/mnt/hardDrive/docker/synapse-poc/data:/data' "$PLAN_FILE"; then
+    pass "plan documents HDD data mount in bootstrap command"
+  else
+    fail "plan documents HDD data mount" "not found in plan"
+  fi
+}
+
+test_procedure_order_is_correct() {
+  # Extract the step headings in order and verify the sequence
+  local steps
+  steps=$(grep -n '^### Step' "$PLAN_FILE" | head -9)
+  local expected_order="Step 1 — Create HDD directories
+Step 2 — Bootstrap runtime material
+Step 3 — Start the stack
+Step 4 — Run health checks
+Step 5 — Measure idle metrics"
+  local actual_order
+  actual_order=$(echo "$steps" | sed 's/^[0-9]*://' | head -5)
+  if echo "$actual_order" | grep -q 'Step 1.*Create HDD' \
+    && echo "$actual_order" | grep -q 'Step 2.*Bootstrap' \
+    && echo "$actual_order" | grep -q 'Step 3.*Start the stack' \
+    && echo "$actual_order" | grep -q 'Step 4.*Run health checks' \
+    && echo "$actual_order" | grep -q 'Step 5.*Measure idle'; then
+    pass "procedure order is: HDD dirs -> Bootstrap -> Compose start -> Health -> Measurements"
+  else
+    fail "procedure order" "expected HDD dirs -> Bootstrap -> Compose start -> Health -> Measurements, got: $(echo "$steps" | head -5)"
+  fi
+}
+
+# ---------------------------------------------------------------------------
+# Run all tests
+# ---------------------------------------------------------------------------
+echo "test_synapse_poc: static assertions for synapse-poc.yml"
+echo ""
+
+test_compose_file_exists
+test_compose_file_is_valid_yaml
+
+echo ""
+echo "--- Security / Isolation ---"
+test_no_published_ports
+test_no_frontproxy_network
+test_no_external_networks
+test_no_environment_secrets
+test_no_federation_config
+test_no_oidc_config
+test_container_name_isolation
