+#!/usr/bin/env python3
+"""Tests for the channel-neutral Matrix inbound adapter."""
+
+import io
+import json
+import os
+import sys
+import unittest
+import urllib.error
+import urllib.parse
+
+
+REPO_ROOT = os.path.normpath(os.path.join(os.path.dirname(__file__), "../.."))
+sys.path.insert(0, os.path.join(REPO_ROOT, "runtime/matrix"))
+sys.path.insert(0, os.path.join(REPO_ROOT, "runtime/messaging"))
+
+import inbound  # noqa: E402
+import client as matrix_client  # noqa: E402
+import validate_envelope  # noqa: E402
+
+
+class FakeClient:
+    def __init__(self, response):
+        self.response = response
+        self.cursors = []
+
+    def sync(self, cursor):
+        self.cursors.append(cursor)
+        return self.response
+
+
+class FakeHTTPResponse:
+    def __init__(self, payload):
+        self.payload = json.dumps(payload).encode("utf-8")
+
+    def __enter__(self):
+        return self
+
+    def __exit__(self, exc_type, exc, traceback):
+        return False
+
+    def read(self):
+        return self.payload
+
+
+def sync_response(*events, next_batch="cursor-2"):
+    return {
+        "next_batch": next_batch,
+        "rooms": {
+            "join": {
+                "!control:matrix.example.org": {
+                    "timeline": {"events": list(events)}
+                }
+            }
+        },
+    }
+
+
+class TestMatrixInbound(unittest.TestCase):
+    def test_text_event_becomes_valid_envelope(self):
+        event = {
+            "event_id": "$event-text:matrix.example.org",
+            "type": "m.room.message",
+            "sender": "@alice:matrix.example.org",
+            "origin_server_ts": 1720990003123,
+            "content": {"msgtype": "m.text", "body": "/status"},
+        }
+        client = FakeClient(sync_response(event))
+        adapter = inbound.MatrixInboundAdapter(client)
+
+        envelopes = adapter.poll_once("cursor-1")
+
+        self.assertEqual(["cursor-1"], client.cursors)
+        self.assertEqual("cursor-2", adapter.next_cursor)
+        self.assertEqual(1, len(envelopes))
+        envelope = envelopes[0]
+        self.assertEqual(1, envelope["envelope_version"])
+        self.assertRegex(envelope["message_id"], r"^mx-lydia-[A-Za-z0-9._~-]+$")
+        self.assertEqual("mx-lydia", envelope["origin_id"])
+        self.assertEqual("matrix", envelope["channel"])
+        self.assertEqual({"id": "@alice:matrix.example.org"}, envelope["sender"])
+        self.assertEqual(
+            {"id": "!control:matrix.example.org", "type": "room"},
+            envelope["target"],
+        )
+        self.assertEqual("/status", envelope["text"])
+        self.assertEqual(1720990003, envelope["timestamp"])
+        self.assertEqual([], envelope["hops"])
+        self.assertEqual("$event-text:matrix.example.org", envelope["metadata"]["event_id"])
+        self.assertEqual([], validate_envelope.validate(envelope))
+
+    def test_reply_relation_and_fallback_are_extracted(self):
+        event = {
+            "event_id": "$event-reply:matrix.example.org",
+            "type": "m.room.message",
+            "sender": "@alice:matrix.example.org",
+            "origin_server_ts": 1720990004123,
+            "content": {
+                "msgtype": "m.text",
+                "body": (
+                    "> <@bob:matrix.example.org> Original message\n"
+                    "> second quoted line\n\nReply text"
+                ),
+                "m.relates_to": {
+                    "m.in_reply_to": {"event_id": "$original:matrix.example.org"}
+                },
+            },
+        }
+        adapter = inbound.MatrixInboundAdapter(FakeClient(sync_response(event)))
+
+        envelope = adapter.poll_once(None)[0]
+
+        self.assertEqual("Reply text", envelope["text"])
+        self.assertEqual(
+            {"message_id": "$original:matrix.example.org"},
+            envelope["reply_to"],
+        )
+        self.assertEqual([], validate_envelope.validate(envelope))
+
+    def test_unknown_event_is_ignored_with_structured_reason(self):
+        event = {
+            "event_id": "$member:matrix.example.org",
+            "type": "m.room.member",
+            "sender": "@alice:matrix.example.org",
+            "origin_server_ts": 1720990005123,
+            "content": {"membership": "join", "displayname": "Sensitive Name"},
+        }
+        audit_records = []
+        adapter = inbound.MatrixInboundAdapter(
+            FakeClient(sync_response(event)), audit=audit_records.append
+        )
+
+        envelopes = adapter.poll_once("cursor-1")
+
+        self.assertEqual([], envelopes)
+        self.assertEqual(
+            [
+                {
+                    "action": "ignored",
+                    "reason": "unsupported_event_type",
+                    "event_id": "$member:matrix.example.org",
+                    "room_id": "!control:matrix.example.org",
+                    "event_type": "m.room.member",
+                }
+            ],
+            audit_records,
+        )
+        self.assertNotIn("Sensitive Name", repr(audit_records))
+
+    def test_invalid_sync_payload_fails_closed(self):
+        adapter = inbound.MatrixInboundAdapter(FakeClient({"rooms": {}}))
+
+        with self.assertRaisesRegex(inbound.MatrixPayloadError, "next_batch"):
+            adapter.poll_once("cursor-1")
+
+        self.assertIsNone(adapter.next_cursor)
+
+    def test_invalid_text_event_fails_closed_without_message_content(self):
+        event = {
+            "event_id": "$invalid:matrix.example.org",
+            "type": "m.room.message",
+            "origin_server_ts": 1720990006123,
+            "content": {"msgtype": "m.text", "body": "private message body"},
+        }
+        adapter = inbound.MatrixInboundAdapter(FakeClient(sync_response(event)))
+
+        with self.assertRaisesRegex(inbound.MatrixPayloadError, "sender") as raised:
+            adapter.poll_once("cursor-1")
+
+        self.assertNotIn("private message body", str(raised.exception))
+        self.assertIsNone(adapter.next_cursor)
+
+    def test_malformed_reply_relation_fails_closed(self):
+        event = {
+            "event_id": "$invalid-reply:matrix.example.org",
+            "type": "m.room.message",
+            "sender": "@alice:matrix.example.org",
+            "origin_server_ts": 1720990007123,
+            "content": {
+                "msgtype": "m.text",
+                "body": "reply",
+                "m.relates_to": "not-an-object",
+            },
+        }
+        adapter = inbound.MatrixInboundAdapter(FakeClient(sync_response(event)))
+
+        with self.assertRaisesRegex(inbound.MatrixPayloadError, "m.relates_to"):
+            adapter.poll_once("cursor-1")
+
+        self.assertIsNone(adapter.next_cursor)
+
+
+class TestMatrixClient(unittest.TestCase):
+    def test_sync_uses_cursor_long_poll_and_message_filter(self):
+        requests = []
+
+        def requester(request, timeout):
+            requests.append((request, timeout))
+            return FakeHTTPResponse({"next_batch": "cursor-2", "rooms": {}})
+
+        client = matrix_client.MatrixClient(
+            "https://matrix.example.org", "secret-token", requester=requester
+        )
+
+        response = client.sync("cursor-1")
+
+        self.assertEqual("cursor-2", response["next_batch"])
+        self.assertEqual(1, len(requests))
+        request, request_timeout = requests[0]
+        parsed = urllib.parse.urlparse(request.full_url)
+        query = urllib.parse.parse_qs(parsed.query)
+        self.assertEqual("/_matrix/client/v3/sync", parsed.path)
+        self.assertEqual(["cursor-1"], query["since"])
+        self.assertEqual(["30000"], query["timeout"])
+        self.assertEqual(
+            {"room": {"timeline": {"types": ["m.room.message"]}}},
+            json.loads(query["filter"][0]),
+        )
+        self.assertEqual("Bearer secret-token", request.get_header("Authorization"))
+        self.assertEqual(35, request_timeout)
+
+    def test_http_429_maps_to_rate_limit_error(self):
+        def requester(request, timeout):
+            payload = json.dumps({
+                "errcode": "M_LIMIT_EXCEEDED",
+                "error": "Too Many Requests",
+                "retry_after_ms": 2500,
+            }).encode("utf-8")
+            raise urllib.error.HTTPError(
+                request.full_url,
+                429,
+                "Too Many Requests",
+                {},
+                io.BytesIO(payload),
+            )
+
+        client = matrix_client.MatrixClient(
+            "https://matrix.example.org", "secret-token", requester=requester
+        )
+
+        with self.assertRaises(matrix_client.MatrixRateLimitError) as raised:
+            client.sync("cursor-1")
+
+        self.assertEqual(2500, raised.exception.retry_after_ms)
+        self.assertEqual("Matrix rate limited; retry after 2500 ms", str(raised.exception))
+        self.assertNotIn("secret-token", str(raised.exception))
+
+    def test_http_429_prefers_retry_after_header(self):
+        def requester(request, timeout):
+            payload = json.dumps({
+                "errcode": "M_LIMIT_EXCEEDED",
+                "retry_after_ms": 9000,
+            }).encode("utf-8")
+            raise urllib.error.HTTPError(
+                request.full_url,
+                429,
+                "Too Many Requests",
+                {"Retry-After": "3"},
+                io.BytesIO(payload),
+            )
+
+        client = matrix_client.MatrixClient(
+            "https://matrix.example.org", "secret-token", requester=requester
+        )
+
+        with self.assertRaises(matrix_client.MatrixRateLimitError) as raised:
+            client.sync("cursor-1")
+
+        self.assertEqual(3000, raised.exception.retry_after_ms)
+
+
+if __name__ == "__main__":
+    unittest.main()
