+test_synapse_has_healthcheck
+test_postgres_has_healthcheck
+test_synapse_healthcheck_tests_exist
+test_postgres_healthcheck_tests_exist
+
+echo ""
+echo "--- Compose Topology ---"
+test_expected_services
+test_expected_volumes
+test_postgres_depends_on_synapse
+test_no_extra_services
+
+echo ""
+echo "--- HDD-Backed Volumes (driver_opts) ---"
+test_volume_driver_opts_exist "synapse_data"
+test_volume_driver_opts_type "synapse_data"
+test_volume_driver_opts_o "synapse_data"
+test_volume_driver_opts_device "synapse_data" "/mnt/hardDrive/docker/synapse-poc/data"
+test_volume_driver_opts_exist "synapse_media"
+test_volume_driver_opts_type "synapse_media"
+test_volume_driver_opts_o "synapse_media"
+test_volume_driver_opts_device "synapse_media" "/mnt/hardDrive/docker/synapse-poc/media"
+test_volume_driver_opts_exist "synapse_db"
+test_volume_driver_opts_type "synapse_db"
+test_volume_driver_opts_o "synapse_db"
+test_volume_driver_opts_device "synapse_db" "/mnt/hardDrive/docker/synapse-poc/db"
+
+echo ""
+echo "--- Versioned homeserver.yaml ---"
+test_homeserver_yaml_exists
+test_homeserver_yaml_is_valid_yaml
+test_homeserver_yaml_listener_only_client
+test_homeserver_yaml_no_federation_listener
+test_homeserver_yaml_mounted_in_compose
+
+echo ""
+echo "--- Exact Pinned Digests ---"
+test_synapse_image_expected_digest
+test_postgres_image_expected_digest
+
+echo ""
+echo "--- Config Bind-Mount Resolution (Retry 2 — Correction 1) ---"
+test_config_bind_mount_source_is_correct
+test_config_bind_mount_is_type_bind
+test_bind_mount_source_file_exists
+test_old_wrong_bind_mount_path_rejected
+
+echo ""
+echo "--- Runtime Config Validation (Retry 2 — Corrections 2 & 3) ---"
