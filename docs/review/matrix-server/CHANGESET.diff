@@ -0,0 +1,243 @@
+#!/usr/bin/env python3
+"""Tests for idempotent Matrix outbound message delivery."""
+
+import io
+import json
+import os
+import sys
+import unittest
+import urllib.error
+import urllib.parse
+
+
+REPO_ROOT = os.path.normpath(os.path.join(os.path.dirname(__file__), "../.."))
+sys.path.insert(0, os.path.join(REPO_ROOT, "runtime/matrix"))
+
+import outbound  # noqa: E402
+
+
+class FakeHTTPResponse:
+    def __init__(self, payload):
+        self.payload = json.dumps(payload).encode("utf-8")
+
+    def __enter__(self):
+        return self
+
+    def __exit__(self, exc_type, exc, traceback):
+        return False
+
+    def read(self):
+        return self.payload
+
+
+def matrix_envelope():
+    return {
+        "envelope_version": 1,
+        "message_id": "mx-lydia-ZXZlbnQtMQ",
+        "origin_id": "mx-lydia",
+        "channel": "matrix",
+        "sender": {"id": "@alice:matrix.example.org"},
+        "target": {"id": "!control:matrix.example.org", "type": "room"},
+        "text": "/status",
+        "timestamp": 1720990003,
+        "hops": [],
+        "metadata": {
+            "event_id": "$event-1:matrix.example.org",
+            "room_id": "!control:matrix.example.org",
+        },
+    }
+
+
+class MatrixOutboundTest(unittest.TestCase):
+    def test_success_sends_reply_and_returns_redacted_receipt(self):
+        requests = []
+
+        def requester(request, timeout):
+            requests.append((request, timeout))
+            return FakeHTTPResponse({"event_id": "$response-1:matrix.example.org"})
+
+        adapter = outbound.MatrixOutboundAdapter(
+            "https://matrix.example.org", "secret-token", requester=requester
+        )
+
+        receipt = adapter.send(matrix_envelope(), "Status: OK")
+
+        self.assertEqual("sent", receipt["status"])
+        self.assertEqual("$response-1:matrix.example.org", receipt["event_id"])
+        self.assertEqual("!control:matrix.example.org", receipt["room_id"])
+        self.assertRegex(receipt["transaction_id"], r"^lydia-[a-f0-9]{32}$")
+        self.assertNotIn("secret-token", repr(receipt))
+        self.assertNotIn("Status: OK", repr(receipt))
+
+        self.assertEqual(1, len(requests))
+        request, timeout = requests[0]
+        self.assertEqual("PUT", request.get_method())
+        self.assertEqual("Bearer secret-token", request.get_header("Authorization"))
+        self.assertEqual("application/json", request.get_header("Content-type"))
+        self.assertEqual(30, timeout)
+        path = urllib.parse.unquote(urllib.parse.urlparse(request.full_url).path)
+        self.assertEqual(
+            (
+                "/_matrix/client/v3/rooms/!control:matrix.example.org/"
+                f"send/m.room.message/{receipt['transaction_id']}"
+            ),
+            path,
+        )
+        self.assertEqual(
+            {
+                "msgtype": "m.text",
+                "body": "Status: OK",
+                "m.relates_to": {
+                    "m.in_reply_to": {"event_id": "$event-1:matrix.example.org"}
+                },
+            },
+            json.loads(request.data),
+        )
+
+    def test_retry_reuses_deterministic_transaction_id(self):
+        requests = []
+
+        def requester(request, timeout):
+            requests.append(request)
+            return FakeHTTPResponse({"event_id": "$response-1:matrix.example.org"})
+
+        adapter = outbound.MatrixOutboundAdapter(
+            "https://matrix.example.org", "secret-token", requester=requester
+        )
+        envelope = matrix_envelope()
+
+        first = adapter.send(envelope, "Status: OK")
+        second = adapter.send(envelope, "Status: OK")
+
+        self.assertEqual(first["transaction_id"], second["transaction_id"])
+        self.assertEqual(requests[0].full_url, requests[1].full_url)
+
+    def test_http_429_is_retryable_and_redacted(self):
+        def requester(request, timeout):
+            raise urllib.error.HTTPError(
+                request.full_url,
+                429,
+                "response body must stay private",
+                {"Retry-After": "2"},
+                io.BytesIO(b'{"error":"response body must stay private"}'),
+            )
+
+        adapter = outbound.MatrixOutboundAdapter(
+            "https://matrix.example.org", "secret-token", requester=requester
+        )
+
+        with self.assertRaises(outbound.MatrixDeliveryError) as raised:
+            adapter.send(matrix_envelope(), "Status: sensitive")
+
+        error = raised.exception
+        self.assertTrue(error.retryable)
+        self.assertEqual(429, error.status)
+        self.assertEqual(2000, error.retry_after_ms)
+        self.assertNotIn("secret-token", str(error))
+        self.assertNotIn("Status: sensitive", str(error))
+        self.assertNotIn("response body", str(error))
+
+    def test_http_429_with_malformed_guidance_stays_retryable(self):
+        def requester(request, timeout):
+            raise urllib.error.HTTPError(
+                request.full_url,
+                429,
+                "Too Many Requests",
+                {},
+                io.BytesIO(b"[]"),
+            )
+
+        adapter = outbound.MatrixOutboundAdapter(
+            "https://matrix.example.org", "secret-token", requester=requester
+        )
+
+        with self.assertRaises(outbound.MatrixDeliveryError) as raised:
+            adapter.send(matrix_envelope(), "Status: sensitive")
+
+        self.assertTrue(raised.exception.retryable)
+        self.assertIsNone(raised.exception.retry_after_ms)
+
+    def test_http_5xx_is_retryable_and_http_4xx_is_not(self):
+        for status, expected_retryable in ((503, True), (403, False)):
+            with self.subTest(status=status):
+                def requester(request, timeout, response_status=status):
+                    raise urllib.error.HTTPError(
+                        request.full_url,
+                        response_status,
+                        "private server detail",
+                        {},
+                        io.BytesIO(b'{"error":"private server detail"}'),
+                    )
+
+                adapter = outbound.MatrixOutboundAdapter(
+                    "https://matrix.example.org",
+                    "secret-token",
+                    requester=requester,
+                )
+
+                with self.assertRaises(outbound.MatrixDeliveryError) as raised:
+                    adapter.send(matrix_envelope(), "Status: sensitive")
+
+                self.assertEqual(status, raised.exception.status)
+                self.assertEqual(expected_retryable, raised.exception.retryable)
+                self.assertNotIn("private server detail", str(raised.exception))
+
+    def test_invalid_success_response_is_retryable_and_redacted(self):
+        def requester(request, timeout):
+            return FakeHTTPResponse({"error": "private server detail"})
+
+        adapter = outbound.MatrixOutboundAdapter(
+            "https://matrix.example.org", "secret-token", requester=requester
+        )
+
+        with self.assertRaises(outbound.MatrixDeliveryError) as raised:
+            adapter.send(matrix_envelope(), "Status: sensitive")
+
+        self.assertEqual(200, raised.exception.status)
+        self.assertTrue(raised.exception.retryable)
+        self.assertNotIn("private server detail", str(raised.exception))
+        self.assertNotIn("Status: sensitive", str(raised.exception))
+
+    def test_invalid_matrix_routing_fails_before_network_call(self):
+        envelope = matrix_envelope()
+        envelope["metadata"] = {}
+        calls = []
+
+        def requester(request, timeout):
+            calls.append(request)
+            return FakeHTTPResponse({"event_id": "$unexpected"})
+
+        adapter = outbound.MatrixOutboundAdapter(
+            "https://matrix.example.org", "secret-token", requester=requester
+        )
+
+        with self.assertRaises(outbound.OutboundValidationError) as raised:
+            adapter.send(envelope, "Status: sensitive")
+
+        self.assertFalse(raised.exception.retryable)
+        self.assertEqual([], calls)
+        self.assertNotIn("Status: sensitive", str(raised.exception))
+
+    def test_target_must_match_original_matrix_room(self):
+        envelope = matrix_envelope()
+        envelope["target"]["id"] = "!other:matrix.example.org"
+        calls = []
+
+        def requester(request, timeout):
+            calls.append(request)
+            return FakeHTTPResponse({"event_id": "$unexpected"})
+
+        adapter = outbound.MatrixOutboundAdapter(
+            "https://matrix.example.org", "secret-token", requester=requester
+        )
+
+        with self.assertRaisesRegex(
+            outbound.OutboundValidationError, "original Matrix room"
+        ):
+            adapter.send(envelope, "Status: sensitive")
+
+        self.assertEqual([], calls)
+
+
+if __name__ == "__main__":
+    unittest.main()
