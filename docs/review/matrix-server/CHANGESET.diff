+#!/usr/bin/env bash
+# Static security-policy tests for the private Matrix deployment.
+set -euo pipefail
+
+REPO_ROOT="$(cd "$(dirname "$0")/../.." && pwd)"
+
+python3 - "$REPO_ROOT" <<'PY'
+import copy
+from pathlib import Path
+import sys
+
+import yaml
+
+
+root = Path(sys.argv[1])
+compose_path = root / "pi/compose/synapse.yml"
+config_path = root / "pi/synapse/synapse.yaml.example"
+policy_path = root / "docs/matrix/security-and-retention.md"
+
+
+def load(path):
+    if not path.is_file():
+        raise SystemExit(f"FAIL: required input missing: {path}")
+    with path.open(encoding="utf-8") as handle:
+        return yaml.safe_load(handle)
+
+
+def violations(compose, config):
+    found = []
+    services = compose.get("services", {})
+    for name in ("synapse", "postgres"):
+        service = services.get(name, {})
+        image = service.get("image", "")
+        if "@sha256:" not in image or ":latest" in image:
+            found.append(f"{name}:floating_image")
+        if name == "postgres" and service.get("ports"):
+            found.append("postgres:host_ports")
+    if config.get("enable_registration") is not False:
+        found.append("synapse:open_registration")
+    if config.get("enable_registration_without_verification") is not False:
+        found.append("synapse:unverified_registration")
+    if "password" in config.get("database", {}).get("args", {}):
+        found.append("synapse:versioned_database_password")
+    for name, secret in compose.get("secrets", {}).items():
+        source = secret.get("file", "")
+        if "/home/michael/matrix/secrets/" not in source or "${" not in source:
+            found.append(f"{name}:insecure_secret_path")
+    return found
+
+
+compose = load(compose_path)
+config = load(config_path)
+if violations(compose, config):
+    raise SystemExit(f"FAIL: production inputs violate policy: {violations(compose, config)}")
+print("PASS: production inputs satisfy the static hardening policy")
+
+mutations = []
+
+candidate = copy.deepcopy(config)
+candidate["enable_registration"] = True
+mutations.append(("open registration", compose, candidate, "synapse:open_registration"))
+
+candidate = copy.deepcopy(compose)
+candidate["services"]["synapse"]["image"] = "ghcr.io/element-hq/synapse:latest"
+mutations.append(("floating image", candidate, config, "synapse:floating_image"))
+
+candidate = copy.deepcopy(compose)
+candidate["services"]["postgres"]["ports"] = ["5432:5432"]
+mutations.append(("PostgreSQL host port", candidate, config, "postgres:host_ports"))
+
+candidate = copy.deepcopy(compose)
+candidate["secrets"]["synapse_signing_key"]["file"] = "/tmp/signing_key"
+mutations.append(
+    (
+        "insecure secret path",
+        candidate,
+        config,
+        "synapse_signing_key:insecure_secret_path",
+    )
+)
+
+for name, candidate_compose, candidate_config, expected in mutations:
+    result = violations(candidate_compose, candidate_config)
+    if expected not in result:
+        raise SystemExit(f"FAIL: policy accepted {name}")
+    print(f"PASS: policy rejects {name}")
+
+if not policy_path.is_file():
+    raise SystemExit(f"FAIL: required input missing: {policy_path}")
+policy = policy_path.read_text(encoding="utf-8")
+required_sections = (
+    "## Registration And Identity",
+    "## TLS And Network Boundary",
+    "## Resource And Abuse Limits",
+    "## Retention And Privacy",
+    "## Logging And Redaction",
+    "## Backup And Incident Response",
+    "## Agent Rooms And E2EE",
+    "## Threat-To-Control Matrix",
+)
+for section in required_sections:
+    if section not in policy:
+        raise SystemExit(f"FAIL: policy section missing: {section}")
+for risk_id in ("RISK-01", "RISK-02", "RISK-03", "RISK-04", "RISK-05", "RISK-06", "RISK-07"):
+    if risk_id not in policy:
+        raise SystemExit(f"FAIL: epic risk missing from control matrix: {risk_id}")
+print("PASS: hardening document maps all Matrix epic risks")
+PY
