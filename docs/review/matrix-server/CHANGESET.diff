+#!/usr/bin/env python3
+"""Bind Matrix approval commands to the channel-neutral Execution Gate store."""
+
+import importlib.util
+import os
+import re
+import sys
+
+
+GATE_MODULE_NAME = "execution_gate_approvals"
+GATE_MODULE_PATH = os.path.normpath(
+    os.path.join(os.path.dirname(__file__), "../gate/approvals.py")
+)
+if GATE_MODULE_NAME in sys.modules:
+    gate_approvals = sys.modules[GATE_MODULE_NAME]
+else:
+    gate_spec = importlib.util.spec_from_file_location(GATE_MODULE_NAME, GATE_MODULE_PATH)
+    gate_approvals = importlib.util.module_from_spec(gate_spec)
+    sys.modules[GATE_MODULE_NAME] = gate_approvals
+    gate_spec.loader.exec_module(gate_approvals)
+
+
+APPROVAL_ID = re.compile(r"^[A-Za-z0-9._~-]{1,128}$")
+
+
+class MatrixApprovalCommandError(ValueError):
+    """A Matrix event cannot safely be interpreted as an approval decision."""
+
+
+class MatrixApprovalHandler:
+    """Apply one Matrix decision without executing the approved action."""
+
+    def __init__(self, store, audit=None):
+        self.store = store
+        self.audit = audit or (lambda record: None)
+
+    def handle(self, envelope):
+        approval_id, decision, trace_id, event_id, principal_id = _command(envelope)
+        try:
+            record = self.store.decide(approval_id, principal_id, decision)
+        except gate_approvals.ApprovalPrincipalError:
+            return self._denied(approval_id, trace_id, event_id, "principal_mismatch")
+        except gate_approvals.ApprovalExpiredError:
+            return self._denied(approval_id, trace_id, event_id, "expired")
+        except gate_approvals.ApprovalReplayError:
+            return self._denied(approval_id, trace_id, event_id, "replay")
+        except gate_approvals.ApprovalUnknownError:
+            return self._denied(approval_id, trace_id, event_id, "unknown")
+        except (gate_approvals.ApprovalValidationError, gate_approvals.ApprovalStateError):
+            return self._denied(approval_id, trace_id, event_id, "gate_unavailable")
+
+        status = record["status"]
+        result = {"status": status, "approval_id": approval_id}
+        if status == "approved":
+            result["action_ref"] = record["action_ref"]
+        self._audit(trace_id, event_id, approval_id, status, None)
+        return result
+
+    def _denied(self, approval_id, trace_id, event_id, reason):
+        self._audit(trace_id, event_id, approval_id, "denied", reason)
+        return {"status": "denied", "approval_id": approval_id, "reason": reason}
+
+    def _audit(self, trace_id, event_id, approval_id, outcome, reason):
+        record = {
+            "action": "approval_decision",
+            "trace_id": trace_id,
+            "event_id": event_id,
+            "approval_id": approval_id,
+            "outcome": outcome,
+        }
+        if reason is not None:
+            record["reason"] = reason
+        self.audit(record)
+
+
+def _command(envelope):
+    if not isinstance(envelope, dict) or envelope.get("channel") != "matrix":
+        raise MatrixApprovalCommandError("approval command requires a Matrix envelope")
+    sender = envelope.get("sender")
+    metadata = envelope.get("metadata")
+    if not isinstance(sender, dict) or not isinstance(sender.get("id"), str):
+        raise MatrixApprovalCommandError("approval command requires a sender ID")
+    if not isinstance(metadata, dict) or not isinstance(metadata.get("event_id"), str):
+        raise MatrixApprovalCommandError("approval command requires an event ID")
+    trace_id = envelope.get("trace_id")
+    if not isinstance(trace_id, str) or not trace_id:
+        raise MatrixApprovalCommandError("approval command requires a trace ID")
+    text = envelope.get("text")
+    if not isinstance(text, str):
+        raise MatrixApprovalCommandError("approval command requires text")
+    parts = text.strip().split()
+    if len(parts) != 2 or parts[0].lower() not in {"/approve", "/reject"}:
+        raise MatrixApprovalCommandError("invalid approval command")
+    approval_id = parts[1]
+    if APPROVAL_ID.fullmatch(approval_id) is None:
+        raise MatrixApprovalCommandError("invalid approval ID")
+    decision = "approve" if parts[0].lower() == "/approve" else "reject"
+    return approval_id, decision, trace_id, metadata["event_id"], sender["id"]
