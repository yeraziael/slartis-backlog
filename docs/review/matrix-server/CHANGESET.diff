index 0000000..c962530
--- /dev/null
+++ b/runtime/matrix/outbound.py
@@ -0,0 +1,146 @@
+#!/usr/bin/env python3
+"""Send channel-neutral Lydia responses to their original Matrix room."""
+
+import hashlib
+import json
+import urllib.error
+import urllib.parse
+import urllib.request
+
+
+class MatrixDeliveryError(RuntimeError):
+    """A redacted Matrix delivery failure with retry guidance."""
+
+    def __init__(self, status=None, retryable=False, retry_after_ms=None):
+        self.status = status
+        self.retryable = retryable
+        self.retry_after_ms = retry_after_ms
+        detail = f" with status {status}" if status is not None else ""
+        super().__init__(f"Matrix delivery failed{detail}")
+
+
+class OutboundValidationError(ValueError):
+    """Matrix outbound input is invalid and must not be retried unchanged."""
+
+    retryable = False
+
+
+class MatrixOutboundAdapter:
+    """Deliver Matrix text replies with deterministic transaction IDs."""
+
+    def __init__(
+        self,
+        homeserver_url,
+        access_token,
+        request_timeout=30,
+        requester=None,
+    ):
+        parsed_homeserver = urllib.parse.urlparse(homeserver_url)
+        if parsed_homeserver.scheme not in {"http", "https"} or not parsed_homeserver.netloc:
+            raise OutboundValidationError("homeserver_url must be an HTTP(S) URL")
+        if not isinstance(access_token, str) or not access_token:
+            raise OutboundValidationError("access_token must be a non-empty string")
+        self.homeserver_url = homeserver_url.rstrip("/")
+        self.access_token = access_token
+        self.request_timeout = request_timeout
+        self.requester = requester or urllib.request.urlopen
+
+    def send(self, envelope, response):
+        message_id, room_id, source_event_id = _validate_routing(envelope, response)
+        transaction_id = _transaction_id(message_id, response)
+        url = (
+            f"{self.homeserver_url}/_matrix/client/v3/rooms/"
+            f"{urllib.parse.quote(room_id, safe='')}/send/m.room.message/"
+            f"{urllib.parse.quote(transaction_id, safe='')}"
+        )
+        content = {
+            "msgtype": "m.text",
+            "body": response,
+            "m.relates_to": {
+                "m.in_reply_to": {"event_id": source_event_id},
+            },
+        }
+        request = urllib.request.Request(
+            url,
+            data=json.dumps(content, separators=(",", ":")).encode("utf-8"),
+            headers={
+                "Authorization": f"Bearer {self.access_token}",
+                "Content-Type": "application/json",
+            },
+            method="PUT",
+        )
+        try:
+            with self.requester(request, timeout=self.request_timeout) as http_response:
+                response_body = http_response.read()
+        except urllib.error.HTTPError as exc:
+            retry_after_ms = _retry_after_ms(exc) if exc.code == 429 else None
+            raise MatrixDeliveryError(
+                status=exc.code,
+                retryable=exc.code == 429 or exc.code >= 500,
+                retry_after_ms=retry_after_ms,
+            ) from None
+        except urllib.error.URLError:
+            raise MatrixDeliveryError(retryable=True) from None
+
+        try:
+            payload = json.loads(response_body.decode("utf-8"))
+        except (UnicodeDecodeError, json.JSONDecodeError):
+            raise MatrixDeliveryError(status=200, retryable=True) from None
+        if not isinstance(payload, dict) or not isinstance(payload.get("event_id"), str):
+            raise MatrixDeliveryError(status=200, retryable=True)
+        if not payload["event_id"]:
+            raise MatrixDeliveryError(status=200, retryable=True)
+        return {
+            "status": "sent",
+            "event_id": payload["event_id"],
+            "room_id": room_id,
+            "transaction_id": transaction_id,
+        }
+
+
+def _transaction_id(message_id, response):
+    identity = f"{message_id}\0{response}".encode("utf-8")
+    return f"lydia-{hashlib.sha256(identity).hexdigest()[:32]}"
+
+
+def _validate_routing(envelope, response):
+    if not isinstance(envelope, dict) or envelope.get("channel") != "matrix":
+        raise OutboundValidationError("envelope must originate from Matrix")
+    if not isinstance(response, str):
+        raise OutboundValidationError("response must be a string")
+    message_id = envelope.get("message_id")
+    target = envelope.get("target")
+    metadata = envelope.get("metadata")
+    if not isinstance(message_id, str) or not message_id:
+        raise OutboundValidationError("envelope requires message_id")
+    if not isinstance(target, dict) or target.get("type") != "room":
+        raise OutboundValidationError("envelope requires a Matrix room target")
+    room_id = target.get("id")
+    if not isinstance(room_id, str) or not room_id:
+        raise OutboundValidationError("envelope requires a Matrix room ID")
+    if not isinstance(metadata, dict):
+        raise OutboundValidationError("envelope requires Matrix metadata")
+    original_room_id = metadata.get("room_id")
+    if original_room_id != room_id:
+        raise OutboundValidationError("target must match the original Matrix room")
+    source_event_id = metadata.get("event_id")
+    if not isinstance(source_event_id, str) or not source_event_id:
+        raise OutboundValidationError("envelope requires a Matrix event ID")
+    return message_id, room_id, source_event_id
+
+
+def _retry_after_ms(error):
+    try:
+        seconds = int(error.headers.get("Retry-After"))
+        if seconds >= 0:
+            return seconds * 1000
+    except (AttributeError, TypeError, ValueError):
+        pass
+    try:
+        payload = json.loads(error.read().decode("utf-8"))
+        milliseconds = payload.get("retry_after_ms")
+        if isinstance(milliseconds, int) and milliseconds >= 0:
+            return milliseconds
+    except (AttributeError, UnicodeDecodeError, json.JSONDecodeError):
+        pass
+    return None
