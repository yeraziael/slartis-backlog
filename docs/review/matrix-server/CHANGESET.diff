index 0000000..a929f5a
--- /dev/null
+++ b/runtime/matrix/observability.py
@@ -0,0 +1,138 @@
+#!/usr/bin/env python3
+"""Redacted health counters and fallback alerts for the Matrix adapter."""
+
+import time
+
+
+SYNC_WARNING_SECONDS = 60
+SYNC_CRITICAL_SECONDS = 300
+QUARANTINE_REASONS = frozenset(
+    {
+        "download_failed",
+        "download_timeout",
+        "invalid_content_uri",
+        "invalid_download",
+        "invalid_metadata",
+        "mime_mismatch",
+        "mime_missing",
+        "mime_not_allowed",
+        "size_limit",
+    }
+)
+
+
+class ObservabilityError(ValueError):
+    """An observability update violates the redacted health contract."""
+
+
+class MatrixObservability:
+    """Keep process-local counters without retaining message content or tokens."""
+
+    def __init__(self, clock=None, audit=None):
+        self.clock = clock or (lambda: int(time.time()))
+        self.audit = audit or (lambda record: None)
+        self.last_sync_at = None
+        self.last_processed_event_id = None
+        self.delivery_failures_total = 0
+        self.quarantined_attachments_total = 0
+        self._adapter_available = True
+
+    def record_sync(self, synced_at, event_id=None):
+        synced_at = _timestamp(synced_at, "synced_at")
+        if event_id is not None:
+            _identifier(event_id, "event_id")
+        self.last_sync_at = synced_at
+        self.audit({"action": "sync", "event_id": event_id, "synced_at": synced_at})
+
+    def record_processed(self, event_id):
+        _identifier(event_id, "event_id")
+        self.last_processed_event_id = event_id
+        self.audit({"action": "processed", "event_id": event_id})
+
+    def record_delivery_failure(self, error):
+        self.delivery_failures_total += 1
+        self.audit(
+            {
+                "action": "delivery_failed",
+                "failure_type": type(error).__name__,
+            }
+        )
+
+    def record_quarantine(self, reason):
+        if reason not in QUARANTINE_REASONS:
+            raise ObservabilityError("unsupported quarantine reason")
+        self.quarantined_attachments_total += 1
+        self.audit({"action": "attachment_quarantined", "reason": reason})
+
+    def set_adapter_health(self, available):
+        if not isinstance(available, bool):
+            raise ObservabilityError("adapter health must be boolean")
+        self._adapter_available = available
+        self.audit({"action": "adapter_health", "available": available})
+
+    def snapshot(self):
+        now = _timestamp(self.clock(), "clock")
+        lag = None if self.last_sync_at is None else max(0, now - self.last_sync_at)
+        status = _status(self._adapter_available, lag)
+        return {
+            "adapter_healthy": self._adapter_available and status != "unhealthy",
+            "delivery_failures_total": self.delivery_failures_total,
+            "generated_at": now,
+            "last_processed_event_id": self.last_processed_event_id,
+            "last_sync_at": self.last_sync_at,
+            "quarantined_attachments_total": self.quarantined_attachments_total,
+            "status": status,
+            "sync_lag_seconds": lag,
+        }
+
+    def fallback_alert(self):
+        metrics = self.snapshot()
+        reason, severity = _alert_reason(metrics)
+        return {
+            "type": "matrix.adapter.unhealthy",
+            "severity": severity,
+            "reason": reason,
+            "delivery_target": "external_gateway",
+            "metrics": metrics,
+        }
+
+
+def _status(available, lag):
+    if not available or (lag is not None and lag >= SYNC_CRITICAL_SECONDS):
+        return "unhealthy"
+    if lag is None:
+        return "starting"
+    if lag >= SYNC_WARNING_SECONDS:
+        return "degraded"
+    return "healthy"
+
+
+def _alert_reason(metrics):
+    if not metrics["adapter_healthy"] and metrics["sync_lag_seconds"] is None:
+        return "adapter_unavailable", "critical"
+    if (
+        metrics["sync_lag_seconds"] is not None
+        and metrics["sync_lag_seconds"] >= SYNC_CRITICAL_SECONDS
+    ):
+        return "sync_lag_critical", "critical"
+    if not metrics["adapter_healthy"]:
+        return "adapter_unavailable", "critical"
+    if metrics["sync_lag_seconds"] is None:
+        return "adapter_starting", "warning"
+    if metrics["sync_lag_seconds"] >= SYNC_WARNING_SECONDS:
+        return "sync_lag_warning", "warning"
+    if metrics["delivery_failures_total"]:
+        return "delivery_failures", "warning"
+    return "health_check", "info"
+
+
+def _timestamp(value, name):
+    if not isinstance(value, int) or isinstance(value, bool) or value < 0:
+        raise ObservabilityError(f"{name} must be a non-negative integer")
+    return value
+
+
+def _identifier(value, name):
+    if not isinstance(value, str) or not value:
+        raise ObservabilityError(f"{name} must be a non-empty string")
+    return value
