@@ -0,0 +1,247 @@
+#!/usr/bin/env bash
+# test_matrix_backup.sh — Static assertions for Matrix backup contract
+#
+# Validates:
+#   1. backupMatrix.sh exists and applies umask 077
+#   2. backupMatrix.sh covers all five artifact classes (DB, media, signing-key,
+#      config, adapter state)
+#   3. backupMatrix.sh generates SHA-256 checksums
+#   4. backupMatrix.sh implements retention (≥ 3 generations)
+#   5. backupMatrix.sh does not print secrets (no cat of key files, etc.)
+#   6. restoreMatrix.md exists
+#   7. restoreMatrix.md documents a safe restore order
+#   8. restoreMatrix.md targets isolated paths first
+#   9. restoreMatrix.md has an operator blackbox restore test with measurable
+#      success criteria
+#
+# Run from repo root: bash pi/tests/test_matrix_backup.sh
+set -uo pipefail
+
+REPO_ROOT="$(cd "$(dirname "$0")/../.." && pwd)"
+BACKUP_SCRIPT="$REPO_ROOT/pi/backupMatrix.sh"
+RESTORE_DOC="$REPO_ROOT/pi/restoreMatrix.md"
+PASS=0
+FAIL=0
+
+pass() { PASS=$((PASS + 1)); echo "  PASS  $1"; }
+fail() { FAIL=$((FAIL + 1)); echo "  FAIL  $1: $2"; }
+
+# ---------------------------------------------------------------------------
+# 1. backupMatrix.sh exists and is executable
+# ---------------------------------------------------------------------------
+test_backup_script_exists() {
+  if [[ -f "$BACKUP_SCRIPT" ]]; then
+    pass "backupMatrix.sh exists at pi/backupMatrix.sh"
+  else
+    fail "backupMatrix.sh exists" "not found at $BACKUP_SCRIPT"
+  fi
+}
+
+test_backup_script_executable() {
+  if [[ -x "$BACKUP_SCRIPT" ]]; then
+    pass "backupMatrix.sh is executable"
+  else
+    fail "backupMatrix.sh executable" "file is not executable (chmod +x)"
+  fi
+}
+
+# ---------------------------------------------------------------------------
+# 2. backupMatrix.sh sets umask 077
+# ---------------------------------------------------------------------------
+test_backup_umask_077() {
+  if grep -q 'umask 077' "$BACKUP_SCRIPT" 2>/dev/null; then
+    pass "backupMatrix.sh sets umask 077"
+  else
+    fail "backupMatrix.sh umask 077" "no 'umask 077' found in script"
+  fi
+}
+
+# ---------------------------------------------------------------------------
+# 3. backupMatrix.sh covers all five artifact classes
+# ---------------------------------------------------------------------------
+test_backup_covers_db_dump() {
+  if grep -qiE '(pg_dump|database.dump|synapse-db\.dump|\.sql|\.dump)' "$BACKUP_SCRIPT" 2>/dev/null; then
+    pass "backup covers artifact: database dump"
+  else
+    fail "backup covers artifact: database dump" "no DB dump command or reference found"
+  fi
+}
+
+test_backup_covers_media() {
+  if grep -qiE '(media|tar.*media|synapse-media\.tar|upload)' "$BACKUP_SCRIPT" 2>/dev/null; then
+    pass "backup covers artifact: media directory"
+  else
+    fail "backup covers artifact: media" "no media backup command or reference found"
+  fi
+}
+
+test_backup_covers_signing_key() {
+  if grep -qiE '(signing.key|signing_key|signing.*key)' "$BACKUP_SCRIPT" 2>/dev/null; then
+    pass "backup covers artifact: signing key"
+  else
+    fail "backup covers artifact: signing key" "no signing key reference found"
+  fi
+}
+
+test_backup_covers_config() {
+  if grep -qiE '(homeserver\.yaml|config|\.yaml)' "$BACKUP_SCRIPT" 2>/dev/null; then
+    pass "backup covers artifact: configuration (homeserver.yaml)"
+  else
+    fail "backup covers artifact: configuration" "no config reference found"
+  fi
+}
+
+test_backup_covers_adapter_state() {
+  if grep -qiE '(adapter|lydia.*state|matrix-state|state\.json)' "$BACKUP_SCRIPT" 2>/dev/null; then
+    pass "backup covers artifact: adapter state"
+  else
+    fail "backup covers artifact: adapter state" "no adapter state reference found"
+  fi
+}
+
+# ---------------------------------------------------------------------------
+# 4. backupMatrix.sh generates SHA-256 checksums
+# ---------------------------------------------------------------------------
+test_backup_checksum() {
+  if grep -qiE '(sha256|sha256sum|checksum)' "$BACKUP_SCRIPT" 2>/dev/null; then
+    pass "backup generates SHA-256 checksums"
+  else
+    fail "backup generates SHA-256 checksums" "no sha256/checksum command found"
+  fi
+}
+
+# ---------------------------------------------------------------------------
+# 5. backupMatrix.sh implements retention (≥ 3 generations)
+# ---------------------------------------------------------------------------
+test_backup_retention() {
+  if grep -qiE '(retention|rotate|keep|mtime|\+[0-9]+|generation|prune|cleanup.*old|rm.*old)' "$BACKUP_SCRIPT" 2>/dev/null; then
+    pass "backup implements retention policy (≥ 3 generations)"
+  else
+    fail "backup implements retention policy" "no retention/rotation/cleanup found"
+  fi
+}
+
+# ---------------------------------------------------------------------------
+# 6. backupMatrix.sh does not print secrets
+# ---------------------------------------------------------------------------
+test_backup_no_secret_printing() {
+  # Check for dangerous patterns that would print or expose secret content.
+  # Informational log messages that mention filenames are NOT flagged.
+  local has_secret_print=false
+  local reasons=""
+
+  # cat of explicit secret files (not informational echo with file paths)
+  if grep -qiE '(cat\s+\$|cat\s+/|cat.*signing|cat.*\.key)' "$BACKUP_SCRIPT" 2>/dev/null | grep -vqE '^\s*#'; then
+    has_secret_print=true
+    reasons+=" cat of secret-bearing file"
+  fi
+
+  # echo/printf that outputs variable content containing secrets
+  if grep -qiE '(echo\s+\$|printf\s+\$|echo.*\$TOKEN|echo.*\$PASSWORD|echo.*\$KEY|echo.*\$SECRET)' "$BACKUP_SCRIPT" 2>/dev/null; then
+    has_secret_print=true
+    reasons+=" echo of secret variable"
+  fi
+
+  # No pg_dump --password or PGPASSWORD in plaintext (jenkins-style)
+  if grep -qiE '(PGPASSWORD=|--password=|POSTGRES_PASSWORD=)' "$BACKUP_SCRIPT" 2>/dev/null; then
+    has_secret_print=true
+    reasons+=" plaintext PGPASSWORD assignment"
+  fi
+
+  if $has_secret_print; then
+    fail "backup does not print secrets" "found secret-bearing operations:$reasons"
+  else
+    pass "backup does not print secrets (no secret-exposing operations)"
+  fi
+}
+
+# ---------------------------------------------------------------------------
+# 7. restoreMatrix.md exists
+# ---------------------------------------------------------------------------
+test_restore_doc_exists() {
+  if [[ -f "$RESTORE_DOC" ]]; then
+    pass "restoreMatrix.md exists at pi/restoreMatrix.md"
+  else
+    fail "restoreMatrix.md exists" "not found at $RESTORE_DOC"
+  fi
+}
+
+# ---------------------------------------------------------------------------
+# 8. restoreMatrix.md documents safe restore order
+# ---------------------------------------------------------------------------
+test_restore_order_documented() {
+  if grep -qiE '(restore.*order|restore.*sequence|reihenfolge|schritt|step\s*[0-9]|phase\s*[0-9])' "$RESTORE_DOC" 2>/dev/null; then
+    pass "restore order is documented in restoreMatrix.md"
+  else
+    fail "restore order documented" "no restore order/sequence/steps found"
+  fi
+}
+
+# ---------------------------------------------------------------------------
+# 9. restoreMatrix.md targets isolated paths first
+# ---------------------------------------------------------------------------
+test_restore_isolated_paths_first() {
+  if grep -qiE '(isolated|zunächst.*getrennt|erst.*isoliert|isolated.*first|config.*first|separate.*path|zunächst.*config|git.*clone.*first|signing.*key.*before)' "$RESTORE_DOC" 2>/dev/null; then
+    pass "restore targets isolated paths first (config/signing key before DB/media)"
+  else
+    fail "restore targets isolated paths first" "no mention of isolated/config-first approach"
+  fi
+}
+
+# ---------------------------------------------------------------------------
+# 10. restoreMatrix.md has operator blackbox restore test with measurable
+#     success criteria
+# ---------------------------------------------------------------------------
+test_restore_blackbox_test() {
+  # Look for a test section with measurable criteria
+  if grep -qiE '(test.*restore|restore.*test|blackbox.*restore|prüfung|verify.*restore|restore.*verify|success.*criterion|success.*criteria|erfolgskriterium|measurable)' "$RESTORE_DOC" 2>/dev/null; then
+    pass "restoreMatrix.md includes operator blackbox restore test with measurable criteria"
+  else
+    fail "restoreMatrix.md blackbox test" "no restore test section with measurable criteria found"
+  fi
+}
+
+# ---------------------------------------------------------------------------
+# Run all tests
+# ---------------------------------------------------------------------------
+echo "test_matrix_backup: static assertions for Matrix backup contract"
+echo ""
+
+echo "--- backupMatrix.sh Presence ---"
+test_backup_script_exists
+test_backup_script_executable
+
+echo ""
+echo "--- backupMatrix.sh Permissions ---"
+test_backup_umask_077
+
+echo ""
+echo "--- backupMatrix.sh Artifact Coverage ---"
+test_backup_covers_db_dump
+test_backup_covers_media
+test_backup_covers_signing_key
+test_backup_covers_config
+test_backup_covers_adapter_state
+
+echo ""
+echo "--- backupMatrix.sh Integrity ---"
+test_backup_checksum
+test_backup_retention
+test_backup_no_secret_printing
+
+echo ""
+echo "--- restoreMatrix.md Presence ---"
+test_restore_doc_exists
+
+echo ""
+echo "--- restoreMatrix.md Content ---"
+test_restore_order_documented
+test_restore_isolated_paths_first
+test_restore_blackbox_test
+
+echo ""
+echo "test_matrix_backup: ${PASS} passed, ${FAIL} failed"
+
+if [[ $FAIL -gt 0 ]]; then
+  exit 1
+fi
