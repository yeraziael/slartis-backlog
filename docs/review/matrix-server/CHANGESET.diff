+#!/usr/bin/env python3
+"""Tests for the redacted Matrix adapter health contract."""
+
+import json
+import os
+import sys
+import unittest
+
+
+REPO_ROOT = os.path.normpath(os.path.join(os.path.dirname(__file__), "../.."))
+sys.path.insert(0, os.path.join(REPO_ROOT, "runtime/matrix"))
+
+import observability  # noqa: E402
+
+
+class MatrixObservabilityTest(unittest.TestCase):
+    def test_snapshot_contains_required_health_fields(self):
+        metrics = observability.MatrixObservability(clock=lambda: 1_720_990_100)
+        metrics.record_sync(1_720_990_090, "$event-1")
+        metrics.record_processed("$event-1")
+        metrics.record_delivery_failure(RuntimeError("homeserver unavailable"))
+        metrics.record_quarantine("mime_mismatch")
+
+        snapshot = metrics.snapshot()
+
+        self.assertEqual(
+            {
+                "adapter_healthy",
+                "delivery_failures_total",
+                "generated_at",
+                "last_processed_event_id",
+                "last_sync_at",
+                "quarantined_attachments_total",
+                "status",
+                "sync_lag_seconds",
+            },
+            set(snapshot),
+        )
+        self.assertEqual(10, snapshot["sync_lag_seconds"])
+        self.assertEqual(1, snapshot["delivery_failures_total"])
+        self.assertEqual(1, snapshot["quarantined_attachments_total"])
+        self.assertEqual("$event-1", snapshot["last_processed_event_id"])
+        self.assertTrue(snapshot["adapter_healthy"])
+
+    def test_audit_and_alert_payloads_never_expose_content_or_tokens(self):
+        audit = []
+        secret = "syt_secret_access_token_123456789"
+        message = "private medical message content"
+        metrics = observability.MatrixObservability(
+            clock=lambda: 1_720_990_500,
+            audit=audit.append,
+        )
+        metrics.record_sync(1_720_990_000, "$event-sensitive")
+        metrics.record_delivery_failure(RuntimeError(f"{secret}: {message}"))
+
+        alert = metrics.fallback_alert()
+        serialized = json.dumps({"audit": audit, "alert": alert}, sort_keys=True)
+
+        self.assertNotIn(secret, serialized)
+        self.assertNotIn(message, serialized)
+        self.assertEqual("matrix.adapter.unhealthy", alert["type"])
+        self.assertEqual("critical", alert["severity"])
+        self.assertEqual("sync_lag_critical", alert["reason"])
+        self.assertEqual("external_gateway", alert["delivery_target"])
+
+    def test_stale_sync_and_explicit_failure_change_health(self):
+        metrics = observability.MatrixObservability(clock=lambda: 1_720_990_500)
+        metrics.record_sync(1_720_990_400, "$event-2")
+        self.assertEqual("degraded", metrics.snapshot()["status"])
+
+        metrics.set_adapter_health(False)
+        snapshot = metrics.snapshot()
+
+        self.assertFalse(snapshot["adapter_healthy"])
+        self.assertEqual("unhealthy", snapshot["status"])
+
+    def test_invalid_event_and_quarantine_reason_fail_closed(self):
+        metrics = observability.MatrixObservability(clock=lambda: 1_720_990_500)
+
+        with self.assertRaises(observability.ObservabilityError):
+            metrics.record_processed("")
+        with self.assertRaises(observability.ObservabilityError):
+            metrics.record_quarantine("private message body")
+
+
+if __name__ == "__main__":
+    unittest.main()
