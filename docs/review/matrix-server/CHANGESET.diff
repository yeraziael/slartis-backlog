index 0000000..9355207
--- /dev/null
+++ b/runtime/matrix/chunking.py
@@ -0,0 +1,90 @@
+#!/usr/bin/env python3
+"""Split Matrix responses into deterministic, independently sendable parts."""
+
+import re
+
+
+DEFAULT_MATRIX_RESPONSE_LIMIT = 4000
+FENCED_CODE_BLOCK = re.compile(
+    r"^```[^\n]*(?:\n|$).*?^```[ \t]*(?:\n|$)",
+    re.MULTILINE | re.DOTALL,
+)
+
+
+def chunk_text(text, limit=DEFAULT_MATRIX_RESPONSE_LIMIT):
+    """Return response chunks whose final text does not exceed ``limit``."""
+    if not isinstance(text, str):
+        raise TypeError("text must be a string")
+    if not isinstance(limit, int) or isinstance(limit, bool) or limit <= 0:
+        raise ValueError("limit must be a positive integer")
+    if len(text) <= limit:
+        return [text]
+
+    total_hint = 2
+    while True:
+        prefix_width = len(f"[{total_hint}/{total_hint}] ")
+        payload_limit = limit - prefix_width
+        if payload_limit < 1:
+            raise ValueError("limit is too small for multipart prefixes")
+        parts = _split_payload(text, payload_limit)
+        total = len(parts)
+        if len(str(total)) == len(str(total_hint)):
+            break
+        total_hint = total
+
+    return [f"[{index}/{total}] {part}" for index, part in enumerate(parts, 1)]
+
+
+def _split_payload(text, limit):
+    parts = []
+    current = ""
+    for unit, protected in _payload_units(text):
+        if protected and len(unit) <= limit:
+            if current and len(current) + len(unit) > limit:
+                parts.append(current)
+                current = ""
+            current += unit
+            continue
+
+        remaining = unit
+        while remaining:
+            available = limit - len(current)
+            if len(remaining) <= available:
+                current += remaining
+                break
+            if available == 0:
+                parts.append(current)
+                current = ""
+                continue
+
+            candidate = remaining[:available]
+            whitespace = [
+                index for index, char in enumerate(candidate) if char.isspace()
+            ]
+            if whitespace:
+                cut = whitespace[-1] + 1
+            elif current:
+                parts.append(current)
+                current = ""
+                continue
+            else:
+                cut = available
+            current += remaining[:cut]
+            remaining = remaining[cut:]
+            parts.append(current)
+            current = ""
+
+    if current:
+        parts.append(current)
+    return parts
+
+
+def _payload_units(text):
+    cursor = 0
+    for match in FENCED_CODE_BLOCK.finditer(text):
+        if match.start() > cursor:
+            yield text[cursor:match.start()], False
+        yield match.group(0), True
+        cursor = match.end()
+    if cursor < len(text):
+        yield text[cursor:], False
