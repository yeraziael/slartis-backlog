+++ b/runtime/messaging/loop_guard.py
@@ -0,0 +1,130 @@
+#!/usr/bin/env python3
+"""Deterministic bridge-loop and replay decisions for Envelope v1."""
+
+import copy
+import threading
+
+
+class MemoryClaims:
+    """Atomically claim message and trace IDs for one process lifetime."""
+
+    def __init__(self):
+        self.message_ids = set()
+        self.trace_ids = set()
+        self.lock = threading.Lock()
+
+    def claim(self, message_id, trace_id):
+        with self.lock:
+            if message_id in self.message_ids:
+                return "replay"
+            if trace_id in self.trace_ids:
+                return "repeated_trace"
+            self.message_ids.add(message_id)
+            self.trace_ids.add(trace_id)
+            return None
+
+
+class LoopGuard:
+    """Authorize one bridge hop without executing channel delivery."""
+
+    def __init__(self, bridge_id, max_hops, claims, audit=None):
+        if not isinstance(bridge_id, str) or not bridge_id:
+            raise ValueError("bridge_id must be a non-empty string")
+        if not isinstance(max_hops, int) or isinstance(max_hops, bool) or max_hops < 1:
+            raise ValueError("max_hops must be a positive integer")
+        if not callable(getattr(claims, "claim", None)):
+            raise ValueError("claims must provide claim(message_id, trace_id)")
+        self.bridge_id = bridge_id
+        self.max_hops = max_hops
+        self.claims = claims
+        self.audit = audit or (lambda record: None)
+
+    def forward(self, envelope, to_channel, timestamp):
+        message_id = envelope.get("message_id") if isinstance(envelope, dict) else None
+        trace_id = envelope.get("trace_id") if isinstance(envelope, dict) else None
+        origin_id = envelope.get("origin_id") if isinstance(envelope, dict) else None
+        channel = envelope.get("channel") if isinstance(envelope, dict) else None
+        hops = envelope.get("hops") if isinstance(envelope, dict) else None
+
+        if not isinstance(trace_id, str) or not trace_id:
+            return self._reject(message_id, trace_id, channel, to_channel, hops, "missing_trace")
+        if not all(isinstance(value, str) and value for value in (message_id, origin_id, channel, to_channel)):
+            return self._reject(message_id, trace_id, channel, to_channel, hops, "invalid_envelope")
+        if not isinstance(timestamp, int) or isinstance(timestamp, bool) or timestamp < 0:
+            return self._reject(message_id, trace_id, channel, to_channel, hops, "invalid_envelope")
+        if not isinstance(hops, list) or any(not isinstance(hop, dict) for hop in hops):
+            return self._reject(message_id, trace_id, channel, to_channel, hops, "invalid_envelope")
+        if origin_id == self.bridge_id or any(
+            hop.get("forwarded_by") == self.bridge_id for hop in hops
+        ):
+            return self._reject(message_id, trace_id, channel, to_channel, hops, "self_origin")
+        if len(hops) >= self.max_hops:
+            return self._reject(message_id, trace_id, channel, to_channel, hops, "max_hops")
+
+        from_channel = hops[-1].get("to_channel") if hops else channel
+        if not isinstance(from_channel, str) or not from_channel:
+            return self._reject(message_id, trace_id, channel, to_channel, hops, "invalid_envelope")
+
+        try:
+            conflict = self.claims.claim(message_id, trace_id)
+        except Exception:
+            return self._reject(
+                message_id,
+                trace_id,
+                channel,
+                to_channel,
+                hops,
+                "claims_unavailable",
+            )
+        if conflict not in {None, "replay", "repeated_trace"}:
+            conflict = "claims_unavailable"
+        if conflict is not None:
+            return self._reject(message_id, trace_id, channel, to_channel, hops, conflict)
+
+        forwarded = copy.deepcopy(envelope)
+        forwarded["hops"].append(
+            {
+                "from_channel": from_channel,
+                "to_channel": to_channel,
+                "timestamp": timestamp,
+                "forwarded_by": self.bridge_id,
+            }
+        )
+        self._audit(message_id, trace_id, channel, to_channel, len(hops) + 1, "allowed")
+        return {"status": "allowed", "envelope": forwarded}
+
+    def _reject(self, message_id, trace_id, channel, to_channel, hops, reason):
+        hop_count = len(hops) if isinstance(hops, list) else None
+        self._audit(
+            message_id,
+            trace_id,
+            channel,
+            to_channel,
+            hop_count,
+            "rejected",
+            reason,
+        )
+        return {"status": "rejected", "reason": reason}
+
+    def _audit(
+        self,
+        message_id,
+        trace_id,
+        from_channel,
+        to_channel,
+        hop_count,
+        outcome,
+        reason=None,
+    ):
+        record = {
+            "action": "bridge_guard",
+            "message_id": message_id,
+            "trace_id": trace_id,
+            "from_channel": from_channel,
+            "to_channel": to_channel,
+            "hop_count": hop_count,
+            "outcome": outcome,
+        }
+        if reason is not None:
+            record["reason"] = reason
+        self.audit(record)
