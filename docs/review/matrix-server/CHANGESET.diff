new file mode 100644
index 0000000..6238185
--- /dev/null
+++ b/pi/compose/synapse-poc.yml
@@ -0,0 +1,104 @@
+# Synapse ARM64 Proof of Concept — Docker Compose
+#
+# Isolated PoC for the Pi 5 (Raspberry Pi, ARM64/aarch64).
+# NO federation, NO OIDC, NO frontproxy, NO externally published ports.
+#
+# Usage (on Pi 5):
+#   docker compose -f pi/compose/synapse-poc.yml up -d
+#
+# Bind mount source: ../synapse-poc/homeserver.yaml resolves from pi/compose/
+# to pi/synapse-poc/homeserver.yaml (the versioned config).
+#
+# Image digests verified 2026-07-14 (see docs/matrix/poc-plan.md for source)
+#   Synapse:  ghcr.io/element-hq/synapse@sha256:6882d26594b87171e0fe807ac6bd7f0000665cd70e73fb88c58ec9bff14c19ce
+#             OCI index (multi-arch: arm64 + amd64)
+#   Postgres: docker.io/library/postgres@sha256:742f40ea20b9ff2ff31db5458d127452988a2164df9e17441e191f3b72252193
+#             OCI index (multi-arch: arm64, amd64, arm, etc.)
+
+services:
+  postgres:
+    container_name: synapse-poc-db
+    image: docker.io/library/postgres@sha256:742f40ea20b9ff2ff31db5458d127452988a2164df9e17441e191f3b72252193
+    platform: linux/arm64
+    restart: unless-stopped
+    environment:
+      POSTGRES_DB: synapse
+      POSTGRES_USER: synapse
+      POSTGRES_PASSWORD: synapse_poc
+      POSTGRES_INITDB_ARGS: "--encoding=UTF-8 --lc-collate=C --lc-ctype=C"
+    healthcheck:
+      test: ["CMD-SHELL", "pg_isready -U synapse -d synapse"]
+      interval: 10s
+      timeout: 5s
+      retries: 5
+      start_period: 30s
+    deploy:
+      resources:
+        limits:
+          cpus: "1.0"
+          memory: 512M
+    volumes:
+      - synapse_db:/var/lib/postgresql/data
+    networks:
+      - synapse-poc-net
+
+  synapse:
+    container_name: synapse-poc
+    image: ghcr.io/element-hq/synapse@sha256:6882d26594b87171e0fe807ac6bd7f0000665cd70e73fb88c58ec9bff14c19ce
+    platform: linux/arm64
+    restart: unless-stopped
+    environment:
+      SYNAPSE_SERVER_NAME: synapse-poc.local
+      SYNAPSE_REPORT_STATS: "no"
+      SYNAPSE_ENABLE_REGISTRATION: "no"
+    depends_on:
+      postgres:
+        condition: service_healthy
+    healthcheck:
+      test: ["CMD", "python3", "-c", "import urllib.request; urllib.request.urlopen('http://localhost:8008/health', timeout=5)"]
+      interval: 15s
+      timeout: 10s
+      retries: 5
+      start_period: 60s
+    deploy:
+      resources:
+        limits:
+          cpus: "2.0"
+          memory: 1024M
+    volumes:
+      - synapse_data:/data
+      - synapse_media:/media
+      # Source resolves from pi/compose/ to pi/synapse-poc/homeserver.yaml
+      - type: bind
+        source: ../synapse-poc/homeserver.yaml
+        target: /data/homeserver.yaml
+        read_only: true
+    networks:
+      - synapse-poc-net
+
+volumes:
+  synapse_data:
+    name: synapse_poc_data
+    driver_opts:
+      type: none
+      device: /mnt/hardDrive/docker/synapse-poc/data
+      o: bind
+  synapse_media:
+    name: synapse_poc_media
+    driver_opts:
+      type: none
+      device: /mnt/hardDrive/docker/synapse-poc/media
+      o: bind
+  synapse_db:
+    name: synapse_poc_db
+    driver_opts:
+      type: none
+      device: /mnt/hardDrive/docker/synapse-poc/db
+      o: bind
+
+networks:
+  synapse-poc-net:
+    name: synapse-poc-net
+    driver: bridge
+    internal: true
+    # internal: true ensures no external connectivity — only container-to-container
