@@ -0,0 +1,143 @@
+#!/usr/bin/env python3
+"""Tests for binding Matrix approval commands to the Execution Gate store."""
+
+import importlib.util
+import json
+import os
+import tempfile
+import unittest
+
+
+REPO_ROOT = os.path.normpath(os.path.join(os.path.dirname(__file__), "../.."))
+MATRIX_MODULE = os.path.join(REPO_ROOT, "runtime/matrix/approvals.py")
+
+SPEC = importlib.util.spec_from_file_location("matrix_approvals", MATRIX_MODULE)
+matrix_approvals = importlib.util.module_from_spec(SPEC)
+SPEC.loader.exec_module(matrix_approvals)
+
+
+def envelope(text, sender="@operator:matrix.example.org"):
+    return {
+        "envelope_version": 1,
+        "message_id": "mx-lydia-command-1",
+        "trace_id": "trace-command-1",
+        "origin_id": "mx-lydia",
+        "channel": "matrix",
+        "sender": {"id": sender},
+        "target": {"id": "!control:matrix.example.org", "type": "room"},
+        "text": text,
+        "timestamp": 1_720_990_000,
+        "hops": [],
+        "metadata": {
+            "event_id": "$event-command-1",
+            "room_id": "!control:matrix.example.org",
+        },
+    }
+
+
+class MatrixApprovalHandlerTest(unittest.TestCase):
+    def setUp(self):
+        self.temporary = tempfile.TemporaryDirectory()
+        self.now = 1_720_990_000
+        self.audit = []
+        self.store = matrix_approvals.gate_approvals.ApprovalStore(
+            os.path.join(self.temporary.name, "approvals.json"),
+            clock=lambda: self.now,
+        )
+        self.handler = matrix_approvals.MatrixApprovalHandler(
+            self.store,
+            audit=self.audit.append,
+        )
+
+    def tearDown(self):
+        self.temporary.cleanup()
+
+    def create(self, approval_id="approval-1", principal="@operator:matrix.example.org"):
+        self.store.create(
+            approval_id,
+            principal,
+            "eddie-job:123",
+            self.now + 300,
+            "trace-request-1",
+        )
+
+    def test_valid_approval_returns_action_reference(self):
+        self.create()
+
+        result = self.handler.handle(envelope("/approve approval-1"))
+
+        self.assertEqual("approved", result["status"])
+        self.assertEqual("eddie-job:123", result["action_ref"])
+        self.assertEqual("approval-1", result["approval_id"])
+        self.assertEqual("approved", self.store.get("approval-1")["status"])
+
+    def test_valid_rejection_is_terminal_without_action(self):
+        self.create()
+
+        result = self.handler.handle(envelope("/reject approval-1"))
+
+        self.assertEqual(
+            {"status": "rejected", "approval_id": "approval-1"},
+            result,
+        )
+
+    def test_wrong_user_is_denied(self):
+        self.create()
+
+        result = self.handler.handle(
+            envelope("/approve approval-1", sender="@mallory:matrix.example.org")
+        )
+
+        self.assertEqual("denied", result["status"])
+        self.assertEqual("principal_mismatch", result["reason"])
+        self.assertEqual("pending", self.store.get("approval-1")["status"])
+
+    def test_expired_approval_is_denied(self):
+        self.create()
+        self.now += 301
+
+        result = self.handler.handle(envelope("/approve approval-1"))
+
+        self.assertEqual("expired", result["reason"])
+        self.assertEqual("expired", self.store.get("approval-1")["status"])
+
+    def test_replay_is_denied(self):
+        self.create()
+        self.handler.handle(envelope("/approve approval-1"))
+
+        result = self.handler.handle(envelope("/approve approval-1"))
+
+        self.assertEqual("replay", result["reason"])
+
+    def test_unknown_id_is_denied(self):
+        result = self.handler.handle(envelope("/reject missing-approval"))
+
+        self.assertEqual("unknown", result["reason"])
+
+    def test_audit_contains_ids_but_no_sensitive_payload(self):
+        self.create()
+        command = "/approve approval-1"
+
+        self.handler.handle(envelope(command))
+
+        serialized = json.dumps(self.audit, sort_keys=True)
+        self.assertIn("trace-command-1", serialized)
+        self.assertIn("$event-command-1", serialized)
+        self.assertIn("approval-1", serialized)
+        self.assertNotIn(command, serialized)
+        self.assertNotIn("eddie-job:123", serialized)
+        self.assertNotIn("@operator:matrix.example.org", serialized)
+
+    def test_non_matrix_or_malformed_command_fails_closed(self):
+        message = envelope("/approve approval-1 extra")
+        with self.assertRaises(matrix_approvals.MatrixApprovalCommandError):
+            self.handler.handle(message)
+
+        message = envelope("/approve approval-1")
+        message["channel"] = "telegram"
+        with self.assertRaises(matrix_approvals.MatrixApprovalCommandError):
+            self.handler.handle(message)
+
+
+if __name__ == "__main__":
+    unittest.main()
