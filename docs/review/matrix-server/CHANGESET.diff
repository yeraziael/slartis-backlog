+#!/usr/bin/env python3
+"""Tests for deterministic Matrix response chunking."""
+
+import os
+import sys
+import unittest
+
+
+REPO_ROOT = os.path.normpath(os.path.join(os.path.dirname(__file__), "../.."))
+sys.path.insert(0, os.path.join(REPO_ROOT, "runtime/matrix"))
+
+import chunking  # noqa: E402
+
+
+class MatrixChunkingTest(unittest.TestCase):
+    def test_short_text_is_returned_unchanged_without_prefix(self):
+        self.assertEqual(["Status: OK"], chunking.chunk_text("Status: OK", limit=20))
+
+    def test_text_at_exact_limit_is_not_split(self):
+        text = "1234567890"
+        self.assertEqual([text], chunking.chunk_text(text, limit=len(text)))
+
+    def test_multipart_text_uses_word_boundaries_and_numbered_prefixes(self):
+        text = "alpha beta gamma delta epsilon"
+        self.assertEqual(
+            [
+                "[1/3] alpha beta ",
+                "[2/3] gamma delta ",
+                "[3/3] epsilon",
+            ],
+            chunking.chunk_text(text, limit=18),
+        )
+
+    def test_long_word_is_hard_split_without_losing_text(self):
+        text = "x" * 30
+        self.assertEqual(
+            [
+                "[1/5] xxxxxxx",
+                "[2/5] xxxxxxx",
+                "[3/5] xxxxxxx",
+                "[4/5] xxxxxxx",
+                "[5/5] xx",
+            ],
+            chunking.chunk_text(text, limit=13),
+        )
+
+    def test_complete_code_fence_is_kept_in_one_chunk_when_it_fits(self):
+        block = "```python\nprint('x')\n```\n"
+        text = f"before words\n{block}after"
+        self.assertEqual(
+            [
+                "[1/3] before words\n",
+                f"[2/3] {block}",
+                "[3/3] after",
+            ],
+            chunking.chunk_text(text, limit=31),
+        )
+
+
+if __name__ == "__main__":
+    unittest.main()
