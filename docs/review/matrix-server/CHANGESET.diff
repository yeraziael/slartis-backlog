index 0000000..9c0cc4d
--- /dev/null
+++ b/pi/tests/test_synapse_storage.sh
@@ -0,0 +1,652 @@
+#!/usr/bin/env bash
+# test_synapse_storage.sh — Static assertions for Synapse storage contract
+#
+# Validates:
+#   1. Required mounts exist in the compose file (data, media, db, config bind)
+#   2. No host-published PostgreSQL ports
+#   3. No secret-bearing paths in versioned assets
+#   4. All #217 PoC isolation requirements preserved (internal network,
+#      no published ports, immutable digests, client-only listener)
+#   5. Storage document exists and covers all required sections
+#   6. Restore inputs enumerated and compatible with #235/#241
+#
+# Run from repo root: bash pi/tests/test_synapse_storage.sh
+set -uo pipefail
+
+REPO_ROOT="$(cd "$(dirname "$0")/../.." && pwd)"
+COMPOSE_FILE="$REPO_ROOT/pi/compose/synapse-poc.yml"
+HOMESERVER_FILE="$REPO_ROOT/pi/synapse-poc/homeserver.yaml"
+STORAGE_DOC="$REPO_ROOT/docs/matrix/storage-and-retention.md"
+PASS=0
+FAIL=0
+
+pass() { PASS=$((PASS + 1)); echo "  PASS  $1"; }
+fail() { FAIL=$((FAIL + 1)); echo "  FAIL  $1: $2"; }
+
+# ---------------------------------------------------------------------------
+# Helper: run a Python YAML query on the compose file
+# ---------------------------------------------------------------------------
+yq() {
+  python3 -c "
+import yaml, sys
+with open('$COMPOSE_FILE') as f:
+    data = yaml.safe_load(f)
+try:
+    result = $1
+    if result is None:
+        sys.exit(1)
+    if isinstance(result, list):
+        for item in result:
+            print(item)
+    elif isinstance(result, bool):
+        print(str(result))
+        sys.exit(0 if result else 1)
+    elif isinstance(result, (int, float)):
+        print(result)
+    else:
+        print(result)
+except (KeyError, IndexError, TypeError) as e:
+    sys.exit(1)
+" 2>&1
+}
+
+# Helper: run a Python YAML query on the homeserver file
+yq_hs() {
+  python3 -c "
+import yaml, sys
+with open('$HOMESERVER_FILE') as f:
+    data = yaml.safe_load(f)
+try:
+    result = $1
+    if result is None:
+        sys.exit(1)
+    if isinstance(result, list):
+        for item in result:
+            print(item)
+    elif isinstance(result, bool):
+        print(str(result))
+        sys.exit(0 if result else 1)
+    elif isinstance(result, (int, float)):
+        print(result)
+    else:
+        print(result)
+except (KeyError, IndexError, TypeError) as e:
+    sys.exit(1)
+" 2>&1
+}
+
+# ---------------------------------------------------------------------------
+# 1. Storage document existence and structure
+# ---------------------------------------------------------------------------
+test_storage_doc_exists() {
+  if [[ -f "$STORAGE_DOC" ]]; then
+    pass "storage document exists at docs/matrix/storage-and-retention.md"
+  else
+    fail "storage document exists" "not found at $STORAGE_DOC"
+  fi
+}
+
+test_storage_doc_has_all_paths() {
+  # Must document all five path categories (allow mixed EN/DE terms)
+  local doc
+  doc=$(cat "$STORAGE_DOC" 2>/dev/null) || { fail "storage doc contents" "could not read"; return; }
+
+  # Flexible matching: check for category presence via broader patterns
+  local has_db=false
+  local has_media=false
+  local has_config=false
+  local has_key=false
+  local has_backup=false
+
+  echo "$doc" | grep -qiE '(database|db|postgres)' && has_db=true
+  echo "$doc" | grep -qiE '(media|medien|upload)' && has_media=true
+  echo "$doc" | grep -qiE '(config|configure|homeserver\.yaml)' && has_config=true
+  echo "$doc" | grep -qiE 'signing[._-]key' && has_key=true
+  echo "$doc" | grep -qiE '(backup|restore)' && has_backup=true
+
+  local found=0
+  $has_db && found=$((found+1))
+  $has_media && found=$((found+1))
+  $has_config && found=$((found+1))
+  $has_key && found=$((found+1))
+  $has_backup && found=$((found+1))
+
+  if [[ $found -ge 5 ]]; then
+    pass "storage document covers all five path categories (DB, media, config, signing-key, backup)"
+  else
+    local missing=""
+    $has_db || missing="$missing DB"
+    $has_media || missing="$missing media"
+    $has_config || missing="$missing config"
+    $has_key || missing="$missing signing-key"
+    $has_backup || missing="$missing backup"
+    fail "storage document covers all five path categories" "missing:$missing (found $found/5)"
+  fi
+}
+
+test_storage_doc_has_quotas_and_retention() {
+  local doc
+  doc=$(cat "$STORAGE_DOC" 2>/dev/null) || { fail "storage doc contents" "could not read"; return; }
+
+  local has_quota=false has_retention=false
+  if echo "$doc" | grep -qiE 'quota|limit|size'; then has_quota=true; fi
+  if echo "$doc" | grep -qiE 'retention|keep|rotate'; then has_retention=true; fi
+
+  if $has_quota && $has_retention; then
+    pass "storage document includes quotas and retention policy"
+  else
+    local missing=""
+    $has_quota || missing="$missing quota"
+    $has_retention || missing="$missing retention"
+    fail "storage document includes quotas and retention" "missing:$missing"
+  fi
+}
+
+test_storage_doc_has_growth_alarms() {
+  if grep -qiE 'alarm|threshold|monitor|warn' "$STORAGE_DOC" 2>/dev/null; then
+    pass "storage document specifies growth alarms / thresholds"
+  else
+    fail "storage document specifies growth alarms" "no alarm/threshold/monitor/warn found"
+  fi
+}
+
+test_storage_doc_has_owners() {
+  if grep -qiE 'owner|responsible|managed.by' "$STORAGE_DOC" 2>/dev/null; then
+    pass "storage document defines owners for each path"
+  else
+    fail "storage document defines owners" "no owner/responsible/managed.by found"
+  fi
+}
+
+test_storage_doc_postgres_privacy() {
+  if grep -qiE 'private|internal|no.*(host|publish|expose)|bridge.*internal' "$STORAGE_DOC" 2>/dev/null; then
+    pass "storage document specifies PostgreSQL privacy (internal network, no host ports)"
+  else
+    fail "storage document specifies PostgreSQL privacy" "no privacy/internal/host restriction found"
+  fi
+}
+
+test_storage_doc_no_memory_as_disk_quota() {
+  # The Volume Inventory must NOT present deploy.resources.limits.memory as a disk quota.
+  # That field is a cgroup RAM limit and does not cap /var/lib/postgresql/data.
+  local doc
+  doc=$(cat "$STORAGE_DOC" 2>/dev/null) || { fail "no memory-as-disk-quota" "could not read storage doc"; return; }
+
+  # Check for the specific false pattern that was present in the original implementation
+  if echo "$doc" | grep -qF '512 MB (limit via `deploy.resources.limits.memory`)'; then
+    fail "no memory-as-disk-quota" "REJECTED: found '512 MB (limit via deploy.resources.limits.memory)' — treats RAM cgroup limit as disk quota"
+    return
+  fi
+
+  # General check: no line may pair the Compose memory setting with a quota
+  # value. The explanatory separation paragraph is intentionally allowed.
+  if echo "$doc" | grep -qiE 'deploy\.resources\.limits\.memory.*(quota|kontingent|grenze).*([0-9]+[[:space:]]*(MB|GB)|512M)' \
+    || echo "$doc" | grep -qiE '([0-9]+[[:space:]]*(MB|GB)|512M).*(quota|kontingent|grenze).*deploy\.resources\.limits\.memory'; then
+    fail "no memory-as-disk-quota" "REJECTED: deploy.resources.limits.memory referenced as a disk quota/limit"
+    return
+  fi
+
+  pass "no memory-as-disk-quota: Volume Inventory does not present RAM limit as disk quota"
+}
+
+test_storage_doc_no_hard_db_quota() {
+  # The document must explicitly state that the PoC has no enforced hard DB disk quota
+  local doc
+  doc=$(cat "$STORAGE_DOC" 2>/dev/null) || { fail "no hard DB quota statement" "could not read storage doc"; return; }
+
+  # Look for explicit denial of enforced disk quota for the DB volume
+  if echo "$doc" | grep -qiE '(kein.*(hard|fest)|no.*hard|no.*enforced).*(quota|kontingent|grenze)'; then
+    pass "no hard DB quota: document states absence of enforced disk quota for DB"
+  else
+    fail "no hard DB quota" "could not find statement that DB has no hard enforced disk quota"
+  fi
+}
+
+test_storage_doc_absolute_db_thresholds() {
+  # DB growth thresholds must be absolute (MB/GB), not percentages derived from RAM
+  local db_alarm_line
+  db_alarm_line=$(grep -E '\.\./db/' "$STORAGE_DOC" 2>/dev/null || true)
+  if [[ -z "$db_alarm_line" ]]; then
+    fail "absolute DB thresholds" "could not find '../db/' row in growth alarms table"
+    return
+  fi
+
+  # Must NOT contain a percentage threshold
+  if echo "$db_alarm_line" | grep -q '%'; then
+    fail "absolute DB thresholds" "REJECTED: DB growth alarm uses percentage: $db_alarm_line"
+    return
+  fi
+
+  # Must contain absolute units (MB or GB)
+  if echo "$db_alarm_line" | grep -qiE '[0-9]+\s*(MB|GB)'; then
+    pass "absolute DB thresholds: DB growth alarm uses absolute MB/GB values"
+  else
+    fail "absolute DB thresholds" "DB growth alarm does not use absolute MB/GB values: $db_alarm_line"
+  fi
+}
+
+test_storage_doc_filesystem_free_space_thresholds() {
+  local doc
+  doc=$(cat "$STORAGE_DOC" 2>/dev/null) || { fail "filesystem free-space thresholds" "could not read storage doc"; return; }
+
+  # Free-space alarms must be absolute and must target the HDD filesystem,
+  # not the PostgreSQL RAM cgroup limit.
+  if echo "$doc" | grep -qE 'HDD freier Speicher.*< 20 GB frei.*< 10 GB frei'; then
+    pass "filesystem free-space thresholds: /mnt/hardDrive has 20 GB/10 GB absolute alarms"
+  else
+    fail "filesystem free-space thresholds" "expected /mnt/hardDrive alarms at <20 GB and <10 GB free"
+  fi
+}
+
+test_storage_doc_ram_disk_separation() {
+  local doc
+  doc=$(cat "$STORAGE_DOC" 2>/dev/null) || { fail "RAM/disk separation" "could not read storage doc"; return; }
+
+  if echo "$doc" | grep -qF 'cgroup-basierter RAM-Limit' \
+    && echo "$doc" | grep -qF 'kein Plattenkontingent' \
+    && echo "$doc" | grep -qF 'kein erzwungenes Hard-Quota'; then
+    pass "RAM/disk separation: 512M is RAM-only and DB has no enforced hard disk quota"
+  else
+    fail "RAM/disk separation" "missing explicit RAM-only/no-hard-quota contract"
+  fi
+}
+
+# ---------------------------------------------------------------------------
+# 2. Required mounts in compose file
+# ---------------------------------------------------------------------------
+test_required_mounts_data() {
+  local volumes_str
+  volumes_str=$(yq "str(data.get('services', {}).get('synapse', {}).get('volumes', []))") || {
+    fail "required mount: synapse_data" "could not read synapse volumes"
+    return
+  }
+  if echo "$volumes_str" | grep -q 'synapse_data'; then
+    pass "required mount: synapse_data (keys, pid, homeserver.yaml)"
+  else
+    fail "required mount: synapse_data" "not found in synapse volumes"
+  fi
+}
+
+test_required_mounts_media() {
+  local volumes_str
+  volumes_str=$(yq "str(data.get('services', {}).get('synapse', {}).get('volumes', []))") || {
+    fail "required mount: synapse_media" "could not read synapse volumes"
+    return
+  }
+  if echo "$volumes_str" | grep -q 'synapse_media'; then
+    pass "required mount: synapse_media (uploads, thumbnails)"
+  else
+    fail "required mount: synapse_media" "not found in synapse volumes"
+  fi
+}
+
+test_required_mounts_db() {
+  local volumes_str
+  volumes_str=$(yq "str(data.get('services', {}).get('postgres', {}).get('volumes', []))") || {
+    fail "required mount: synapse_db" "could not read postgres volumes"
+    return
+  }
+  if echo "$volumes_str" | grep -q 'synapse_db'; then
+    pass "required mount: synapse_db (PostgreSQL data)"
+  else
+    fail "required mount: synapse_db" "not found in postgres volumes"
+  fi
+}
+
+test_required_mounts_config_bind() {
+  local volumes_str
+  volumes_str=$(yq "str(data.get('services', {}).get('synapse', {}).get('volumes', []))") || {
+    fail "required mount: homeserver.yaml bind" "could not read synapse volumes"
+    return
+  }
+  if echo "$volumes_str" | grep -q 'homeserver.yaml'; then
+    pass "required mount: homeserver.yaml (read-only bind mount)"
+  else
+    fail "required mount: homeserver.yaml bind" "not found in synapse volumes"
+  fi
+}
+
+test_config_bind_is_readonly() {
+  local ro_flag
+  ro_flag=$(yq "[v for v in data.get('services', {}).get('synapse', {}).get('volumes', []) if isinstance(v, dict) and v.get('type') == 'bind'][0].get('read_only', False)") || {
+    fail "config bind mount read_only" "could not read read_only flag"
+    return
+  }
+  if [[ "$ro_flag" == "True" ]]; then
+    pass "config bind mount is read_only (True)"
+  else
+    fail "config bind mount read_only" "expected True, got '$ro_flag'"
+  fi
+}
+
+# ---------------------------------------------------------------------------
+# 3. No host-published PostgreSQL ports
+# ---------------------------------------------------------------------------
+test_db_no_host_ports() {
+  local ports_section
+  ports_section=$(yq "data.get('services', {}).get('postgres', {}).get('ports', None)") && {
+    fail "postgres: no host ports published" "found ports section: $ports_section"
+    return
+  }
+  pass "postgres: no ports section (no host-exposed DB port)"
+}
+
+test_db_no_port_map_in_compose() {
+  # Double-check: no "5432" appears in any port mapping of the compose file
+  if grep -qE '5432.*:' "$COMPOSE_FILE" 2>/dev/null; then
+    fail "postgres: no port mapping 5432" "found '5432' in port mapping context"
+  else
+    pass "postgres: no '5432' port mapping in compose file"
+  fi
+}
+
+test_db_internal_network() {
+  # Networks can be a list (service network names) or a dict (with aliases/etc)
+  # In our compose it's a simple list: ['synapse-poc-net']
+  local net_raw
+  net_raw=$(yq "str(data.get('services', {}).get('postgres', {}).get('networks', []))") || {
+    fail "postgres internal network" "could not read networks"
+    return
+  }
+  if echo "$net_raw" | grep -q 'synapse-poc-net'; then
+    pass "postgres is on synapse-poc-net (internal bridge)"
+  else
+    fail "postgres internal network" "expected synapse-poc-net, got '$net_raw'"
+  fi
+}
+
+# ---------------------------------------------------------------------------
+# 4. No secret-bearing paths in versioned assets
+# ---------------------------------------------------------------------------
+test_homeserver_no_secret_paths() {
+  # Check that signing_key_path is under /data (HDD volume) not in versioned tree
+  local sk_path
+  sk_path=$(yq_hs "data.get('signing_key_path', '')")
+  if echo "$sk_path" | grep -qE '^/data/'; then
+    pass "signing_key_path '$sk_path' is under /data (HDD-backed, not versioned)"
+  else
+    fail "signing_key_path in versioned asset" "expected path under /data, got '$sk_path'"
+  fi
+}
+
+test_homeserver_no_secrets_in_config() {
+  # The versioned homeserver.yaml must not contain real secrets/tokens/passwords
+  local hs_content
+  hs_content=$(cat "$HOMESERVER_FILE" 2>/dev/null) || {
+    fail "homeserver.yaml no secrets" "could not read file"
+    return
+  }
+
+  # Check for known PoC-only non-secret patterns
+  if echo "$hs_content" | grep -q 'synapse_poc'; then
+    pass "homeserver.yaml uses PoC-only non-secret password (synapse_poc)"
+  else
+    # It might be a different non-secret value — check no real credential pattern
+    if echo "$hs_content" | grep -qE '(password|token|secret|key).*:.*[A-Za-z0-9]{20,}'; then
+      fail "homeserver.yaml potentially contains real secrets" "found long credential value"
+    else
+      pass "homeserver.yaml contains no real secrets (PoC credentials only)"
+    fi
+  fi
+}
+
+test_homeserver_no_secret_in_bind_mount_source() {
+  # The bind mount source in compose must not point to a secret-bearing path
+  local source
+  source=$(yq "[v for v in data.get('services', {}).get('synapse', {}).get('volumes', []) if isinstance(v, dict) and v.get('type') == 'bind'][0].get('source', '')") || {
+    fail "bind mount source no secret" "could not read bind mount source"
+    return
+  }
+  if echo "$source" | grep -qE '(secret|key|token|password|credential)'; then
+    fail "bind mount source contains secret-bearing term" "source: $source"
+  else
+    pass "bind mount source path is free of secret-bearing terms: $source"
+  fi
+}
+
+test_homeserver_no_signing_key_in_versioned_tree() {
+  # The signing key file itself must NOT exist in the versioned tree
+  local sk_versioned="$REPO_ROOT/pi/synapse-poc/synapse-poc.local.signing.key"
+  if [[ -f "$sk_versioned" ]]; then
+    fail "signing key in versioned tree" "REJECTED: $sk_versioned must not be committed"
+  else
+    pass "signing key is NOT in versioned tree (only on HDD via bootstrap)"
+  fi
+}
+
+# ---------------------------------------------------------------------------
+# 5. #217 PoC Isolation Preserved
+# ---------------------------------------------------------------------------
+test_poc_no_published_ports_synapse() {
+  local ports
+  ports=$(yq "data.get('services', {}).get('synapse', {}).get('ports', None)") && {
+    fail "PoC isolation: synapse has published ports" "found: $ports"
+    return
+  }
+  pass "PoC isolation: synapse has no published ports"
+}
+
+test_poc_no_published_ports_postgres() {
+  local ports
+  ports=$(yq "data.get('services', {}).get('postgres', {}).get('ports', None)") && {
+    fail "PoC isolation: postgres has published ports" "found: $ports"
+    return
+  }
+  pass "PoC isolation: postgres has no published ports"
+}
+
+test_poc_immutable_digests() {
+  local syn_image pg_image
+  syn_image=$(yq "data.get('services', {}).get('synapse', {}).get('image', '')") || syn_image=""
+  pg_image=$(yq "data.get('services', {}).get('postgres', {}).get('image', '')") || pg_image=""
+
+  local ok=0
+  if echo "$syn_image" | grep -q '@sha256:'; then ok=$((ok+1)); fi
+  if echo "$pg_image" | grep -q '@sha256:'; then ok=$((ok+1)); fi
+
+  if [[ $ok -eq 2 ]]; then
+    pass "PoC isolation: both images pinned by immutable digest"
+  else
+    fail "PoC isolation: images pinned by digest" "synapse: $syn_image, postgres: $pg_image"
+  fi
+}
+
+test_poc_internal_network() {
+  local net_name
+  net_name=$(yq "data.get('networks', {}).keys()") || {
+    fail "PoC isolation: internal network" "could not read networks"
+    return
+  }
+  if echo "$net_name" | grep -q 'synapse-poc-net'; then
+    pass "PoC isolation: synapse-poc-net defined"
+  else
+    fail "PoC isolation: internal network" "synapse-poc-net not found"
+  fi
+}
+
+test_poc_client_only_listener() {
+  # homeserver.yaml must expose only 'client' resource, never 'federation'
+  local listener_resources
+  listener_resources=$(yq_hs "[r.get('names', []) for l in data.get('listeners', []) for r in l.get('resources', [])]") || {
+    fail "PoC isolation: client-only listener" "could not read listener resources"
+    return
+  }
+  if echo "$listener_resources" | grep -q 'federation'; then
+    fail "PoC isolation: client-only listener" "found 'federation' resource (must be client-only)"
+    return
+  fi
+  if echo "$listener_resources" | grep -q 'client'; then
+    pass "PoC isolation: listeners expose only 'client' resource (no federation)"
+  else
+    fail "PoC isolation: listener resources" "no 'client' resource found"
+  fi
+}
+
+test_poc_no_deployment_references() {
+  # The compose file must not reference frontproxy, OIDC, or Keycloak
+  # as active configuration. The 'deploy:' Docker Compose key for resource
+  # limits is legitimate and expected.
+  local compose_str
+  compose_str=$(yq "str(data)") || compose_str=""
+
+  local forbidden=("frontproxy" "oidc" "keycloak")
+  local found_forbidden=""
+  for term in "${forbidden[@]}"; do
+    if echo "$compose_str" | grep -qi "$term"; then
+      found_forbidden="$found_forbidden $term"
+    fi
+  done
+
+  if [[ -z "$found_forbidden" ]]; then
+    pass "PoC isolation: no frontproxy/OIDC/Keycloak reference in compose"
+  else
+    fail "PoC isolation: deployment references" "found forbidden terms:$found_forbidden in compose"
+  fi
+}
+
+# ---------------------------------------------------------------------------
+# 6. Restore input enumeration compatible with #235/#241
+# ---------------------------------------------------------------------------
+test_restore_inputs_enumerated() {
+  if grep -qiE 'restore.input|backup.*artifact|restore.*path|input.*restore' "$STORAGE_DOC" 2>/dev/null; then
+    pass "storage document enumerates restore inputs"
+  else
+    fail "storage document enumerates restore inputs" "no restore input/artifact enumeration found"
+  fi
+}
+
+test_restore_inputs_list_complete() {
+  # Must enumerate at least: DB dump, media, signing key, homeserver config, adapter state
+  local doc
+  doc=$(cat "$STORAGE_DOC" 2>/dev/null) || { fail "restore inputs" "could not read storage doc"; return; }
+
+  local inputs=("db.dump" "media" "signing.key" "homeserver.yaml" "adapter")
+  local found=0
+  for inp in "${inputs[@]}"; do
+    if echo "$doc" | grep -iq "$inp"; then
+      found=$((found + 1))
+    fi
+  done
+  if [[ $found -ge 4 ]]; then
+    pass "restore inputs list covers at least 4/5 required categories (found $found)"
+  else
+    fail "restore inputs list" "found $found/5 restore input categories"
+  fi
+}
+
+# ---------------------------------------------------------------------------
+# 7. Volume definitions complete and correct
+# ---------------------------------------------------------------------------
+test_volumes_defined_in_compose() {
+  local volumes_list
+  volumes_list=$(yq "list(data.get('volumes', {}).keys())") || {
+    fail "volume definitions" "could not list volumes"
+    return
+  }
+  local count
+  count=$(echo "$volumes_list" | wc -l)
+  if [[ $count -eq 3 ]]; then
+    pass "exactly 3 volumes defined (synapse_data, synapse_media, synapse_db)"
+  else
+    fail "expected 3 volumes" "found $count: $volumes_list"
+  fi
+}
+
+test_volumes_have_driver_opts() {
+  for vol in synapse_data synapse_media synapse_db; do
+    local opts
+    opts=$(yq "data.get('volumes', {}).get('$vol', {}).get('driver_opts', None)") || {
+      fail "$vol: HDD-backed driver_opts" "missing driver_opts"
+      continue
+    }
+    pass "$vol: has HDD-backed driver_opts"
+  done
+}
+
+test_volume_device_paths_match_doc() {
+  # Verify that device paths in compose match what the storage doc specifies
+  local doc
+  doc=$(cat "$STORAGE_DOC" 2>/dev/null) || { fail "volume paths match doc" "could not read storage doc"; return; }
+
+  for vol in synapse_data synapse_media synapse_db; do
+    local device
+    device=$(yq "data.get('volumes', {}).get('$vol', {}).get('driver_opts', {}).get('device', '')") || device=""
+    if [[ -n "$device" ]]; then
+      # Check the base path is documented
+      if echo "$doc" | grep -qF "/mnt/hardDrive/docker/synapse-poc"; then
+        pass "$vol: device path '$device' matches documented base path"
+      else
+        fail "$vol: device path" "/mnt/hardDrive/docker/synapse-poc not found in storage doc"
+      fi
+    else
+      fail "$vol: device path" "empty or unreadable"
+    fi
+  done
+}
+
+# ---------------------------------------------------------------------------
+# Run all tests
+# ---------------------------------------------------------------------------
+echo "test_synapse_storage: static assertions for storage contract"
+echo ""
+
+echo "--- Storage Document Structure ---"
+test_storage_doc_exists
+test_storage_doc_has_all_paths
+test_storage_doc_has_quotas_and_retention
+test_storage_doc_has_growth_alarms
+test_storage_doc_has_owners
+test_storage_doc_postgres_privacy
+test_storage_doc_no_memory_as_disk_quota
+test_storage_doc_no_hard_db_quota
+test_storage_doc_absolute_db_thresholds
+test_storage_doc_filesystem_free_space_thresholds
+test_storage_doc_ram_disk_separation
+
+echo ""
+echo "--- Required Mounts ---"
+test_required_mounts_data
+test_required_mounts_media
+test_required_mounts_db
+test_required_mounts_config_bind
+test_config_bind_is_readonly
+
+echo ""
+echo "--- PostgreSQL Privacy (No Host Ports) ---"
+test_db_no_host_ports
+test_db_no_port_map_in_compose
+test_db_internal_network
+
+echo ""
+echo "--- No Secrets in Versioned Assets ---"
+test_homeserver_no_secret_paths
+test_homeserver_no_secrets_in_config
+test_homeserver_no_secret_in_bind_mount_source
+test_homeserver_no_signing_key_in_versioned_tree
+
+echo ""
+echo "--- #217 PoC Isolation Preserved ---"
+test_poc_no_published_ports_synapse
+test_poc_no_published_ports_postgres
+test_poc_immutable_digests
+test_poc_internal_network
+test_poc_client_only_listener
+test_poc_no_deployment_references
+
+echo ""
+echo "--- Restore Inputs (#235 / #241 Compatibility) ---"
+test_restore_inputs_enumerated
+test_restore_inputs_list_complete
+
+echo ""
+echo "--- Volume Definitions ---"
+test_volumes_defined_in_compose
+test_volumes_have_driver_opts
+test_volume_device_paths_match_doc
+
+echo ""
+echo "test_synapse_storage: ${PASS} passed, ${FAIL} failed"
+
+if [[ $FAIL -gt 0 ]]; then
+  exit 1
+fi


