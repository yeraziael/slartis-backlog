+#!/usr/bin/env python3
+"""
+Unit tests for Matrix room bootstrap.
+
+Tests that bootstrap_rooms.py validates policy correctly, bootstraps
+rooms idempotently via mocked Matrix API, and that restricted users
+(Vekling, gateway) cannot perform privileged actions.
+"""
+
+import json
+import os
+import pathlib
+import subprocess
+import sys
+import tempfile
+import unittest
+from unittest.mock import MagicMock, patch
+
+REPO_ROOT = os.path.normpath(os.path.join(os.path.dirname(__file__), "../.."))
+sys.path.insert(0, os.path.join(REPO_ROOT, "runtime/matrix"))
+REPO_PATH = pathlib.Path(REPO_ROOT)
+
+import bootstrap_rooms  # noqa: E402
+
+# ---------------------------------------------------------------------------
+# Fixtures
+# ---------------------------------------------------------------------------
+
+VALID_POLICY = {
+    "homeserver_url": "https://matrix.hl.maier.wtf",
+    "domain": "matrix.hl.maier.wtf",
+    "bot_user_id": "@lydia:matrix.hl.maier.wtf",
+    "rooms": [
+        {
+            "room_alias": "general",
+            "name": "General",
+            "topic": "General discussion",
+            "preset": "public_chat",
+            "members": ["@slarti:matrix.hl.maier.wtf"],
+            "power_levels": {
+                "ban": 50,
+                "events_default": 0,
+                "invite": 50,
+                "kick": 50,
+                "notifications": {"room": 50},
+                "redact": 50,
+                "state_default": 50,
+                "users": {},
+                "users_default": 0,
+            },
+        },
+        {
+            "room_alias": "admin",
+            "name": "Admin",
+            "topic": "Admin ops",
+            "preset": "private_chat",
+            "members": [],
+            "power_levels": {
+                "ban": 100,
+                "events_default": 50,
+                "invite": 100,
+                "kick": 100,
+                "notifications": {"room": 100},
+                "redact": 100,
+                "state_default": 100,
+                "users": {},
+                "users_default": 0,
+            },
+        },
+        {
+            "room_alias": "bridge",
+            "name": "Bridge Relay",
+            "topic": "Cross-channel bridge",
+            "preset": "public_chat",
+            "members": ["@telegram-gateway:matrix.hl.maier.wtf"],
+            "power_levels": {
+                "ban": 50,
+                "events_default": 0,
+                "invite": 50,
+                "kick": 50,
+                "notifications": {"room": 50},
+                "redact": 50,
+                "state_default": 50,
+                "users": {},
+                "users_default": 0,
+            },
+        },
+    ],
+    "restricted_users": [
+        {
+            "user_id_pattern": "@.*vekling.*:",
+            "power_level": 0,
+            "denied_actions": ["invite", "kick", "ban", "redact", "state"],
+        },
+        {
+            "user_id_pattern": "@.*gateway.*:",
+            "power_level": 0,
+            "denied_actions": ["invite", "kick", "ban", "redact", "state"],
+        },
+    ],
+}
+
+
+def _write_policy(policy_dict):
+    """Write a policy dict to a temporary file and return the path."""
+    fd, path = tempfile.mkstemp(suffix=".json", prefix="test_policy_")
+    with os.fdopen(fd, "w") as fh:
+        json.dump(policy_dict, fh)
+    return path
+
+
+# ---------------------------------------------------------------------------
+# Policy Validation Tests
+# ---------------------------------------------------------------------------
+
+
+class TestPolicyValidation(unittest.TestCase):
+    """Valid and invalid policy documents."""
+
+    def test_valid_policy_passes(self):
+        """A well-formed policy must pass validation."""
+        self.assertTrue(bootstrap_rooms.validate_policy(VALID_POLICY))
+
+    def test_non_dict_fails(self):
+        with self.assertRaises(bootstrap_rooms.PolicyValidationError):
+            bootstrap_rooms.validate_policy([])
+
+    def test_missing_required_keys_fails(self):
+        for key in ["homeserver_url", "domain", "bot_user_id", "rooms"]:
+            policy = dict(VALID_POLICY)
+            del policy[key]
+            with self.assertRaises(bootstrap_rooms.PolicyValidationError):
+                bootstrap_rooms.validate_policy(policy)
+
+    def test_empty_homeserver_url_fails(self):
+        policy = dict(VALID_POLICY)
+        policy["homeserver_url"] = ""
+        with self.assertRaises(bootstrap_rooms.PolicyValidationError):
+            bootstrap_rooms.validate_policy(policy)
+
+    def test_bot_user_id_must_start_with_at(self):
+        policy = dict(VALID_POLICY)
+        policy["bot_user_id"] = "lydia:homelab.local"
+        with self.assertRaises(bootstrap_rooms.PolicyValidationError):
+            bootstrap_rooms.validate_policy(policy)
+
+    def test_rooms_must_be_nonempty_list(self):
+        policy = dict(VALID_POLICY)
+        policy["rooms"] = []
+        with self.assertRaises(bootstrap_rooms.PolicyValidationError):
+            bootstrap_rooms.validate_policy(policy)
+
+        policy["rooms"] = "not_a_list"
+        with self.assertRaises(bootstrap_rooms.PolicyValidationError):
+            bootstrap_rooms.validate_policy(policy)
+
+    def test_room_missing_keys_fails(self):
+        for key in ["room_alias", "name", "preset", "members", "power_levels"]:
+            room = dict(VALID_POLICY["rooms"][0])
+            del room[key]
+            policy = dict(VALID_POLICY)
+            policy["rooms"] = [room]
+            with self.assertRaises(bootstrap_rooms.PolicyValidationError):
+                bootstrap_rooms.validate_policy(policy)
+
+    def test_invalid_preset_fails(self):
+        room = dict(VALID_POLICY["rooms"][0])
+        room["preset"] = "invalid_preset"
+        policy = dict(VALID_POLICY)
+        policy["rooms"] = [room]
+        with self.assertRaises(bootstrap_rooms.PolicyValidationError):
+            bootstrap_rooms.validate_policy(policy)
+
+    def test_power_levels_missing_keys_fails(self):
+        for key in ["ban", "events_default", "state_default"]:
+            room = dict(VALID_POLICY["rooms"][0])
+            pl = dict(room["power_levels"])
+            del pl[key]
+            room["power_levels"] = pl
+            policy = dict(VALID_POLICY)
+            policy["rooms"] = [room]
+            with self.assertRaises(bootstrap_rooms.PolicyValidationError):
+                bootstrap_rooms.validate_policy(policy)
+
+    def test_state_default_lt_events_default_fails(self):
+        room = dict(VALID_POLICY["rooms"][0])
+        pl = dict(room["power_levels"])
+        pl["state_default"] = -1   # below events_default
+        room["power_levels"] = pl
+        policy = dict(VALID_POLICY)
+        policy["rooms"] = [room]
+        with self.assertRaises(bootstrap_rooms.PolicyValidationError):
+            bootstrap_rooms.validate_policy(policy)
+
+    def test_invite_lt_state_default_fails(self):
+        room = dict(VALID_POLICY["rooms"][0])
+        pl = dict(room["power_levels"])
+        pl["invite"] = 10
+        pl["state_default"] = 50
+        room["power_levels"] = pl
+        policy = dict(VALID_POLICY)
+        policy["rooms"] = [room]
+        with self.assertRaises(bootstrap_rooms.PolicyValidationError):
+            bootstrap_rooms.validate_policy(policy)
+
+    def test_room_members_must_be_matrix_user_ids(self):
+        room = dict(VALID_POLICY["rooms"][0])
+        room["members"] = ["not-a-matrix-id"]
+        policy = dict(VALID_POLICY)
+        policy["rooms"] = [room]
+        with self.assertRaises(bootstrap_rooms.PolicyValidationError):
+            bootstrap_rooms.validate_policy(policy)
+
+    def test_explicit_restricted_user_cannot_be_elevated(self):
+        room = dict(VALID_POLICY["rooms"][0])
+        room["power_levels"] = dict(room["power_levels"])
+        room["power_levels"]["users"] = {
+            "@build-vekling-7:matrix.hl.maier.wtf": 50,
+        }
