+#!/usr/bin/env python3
+"""Tests for durable Matrix sync cursor and event deduplication state."""
+
+import json
+import os
+import sys
+import tempfile
+import unittest
+from concurrent.futures import ThreadPoolExecutor
+from unittest import mock
+
+import jsonschema
+
+
+REPO_ROOT = os.path.normpath(os.path.join(os.path.dirname(__file__), "../.."))
+MATRIX_DIR = os.path.join(REPO_ROOT, "runtime/matrix")
+SCHEMA_PATH = os.path.join(MATRIX_DIR, "state.schema.json")
+sys.path.insert(0, MATRIX_DIR)
+
+import state_store  # noqa: E402
+
+
+class MatrixStateStoreTest(unittest.TestCase):
+    def setUp(self):
+        self.temporary_directory = tempfile.TemporaryDirectory()
+        self.addCleanup(self.temporary_directory.cleanup)
+        self.state_path = os.path.join(self.temporary_directory.name, "matrix-state.json")
+
+    def test_restart_after_complete_never_reexecutes_event(self):
+        first = state_store.MatrixStateStore(self.state_path, owner_id="run-1")
+        self.assertTrue(first.claim("$event-1:matrix.example.org"))
+        self.assertTrue(first.complete("$event-1:matrix.example.org", "cursor-2"))
+
+        restarted = state_store.MatrixStateStore(self.state_path, owner_id="run-2")
+
+        self.assertFalse(restarted.claim("$event-1:matrix.example.org"))
+        self.assertTrue(restarted.is_processed("$event-1:matrix.example.org"))
+        self.assertEqual("cursor-2", restarted.get_cursor())
+
+        with open(SCHEMA_PATH, encoding="utf-8") as schema_file:
+            schema = json.load(schema_file)
+        jsonschema.Draft7Validator.check_schema(schema)
+        with open(self.state_path, encoding="utf-8") as state_file:
+            persisted_state = json.load(state_file)
+        jsonschema.Draft7Validator(schema).validate(persisted_state)
+
+    def test_restart_before_complete_retries_event_once(self):
+        first = state_store.MatrixStateStore(self.state_path, owner_id="run-1")
+        self.assertTrue(first.claim("$event-1:matrix.example.org"))
+
+        restarted = state_store.MatrixStateStore(self.state_path, owner_id="run-2")
+        self.assertTrue(restarted.claim("$event-1:matrix.example.org"))
+
+        restarted_again = state_store.MatrixStateStore(
+            self.state_path, owner_id="run-3"
+        )
+        self.assertFalse(restarted_again.claim("$event-1:matrix.example.org"))
+        self.assertFalse(restarted_again.is_processed("$event-1:matrix.example.org"))
+        self.assertTrue(restarted.complete("$event-1:matrix.example.org", "cursor-2"))
+
+    def test_duplicate_claim_from_same_run_is_rejected(self):
+        store = state_store.MatrixStateStore(self.state_path, owner_id="run-1")
+
+        self.assertTrue(store.claim("$event-1:matrix.example.org"))
+        self.assertFalse(store.claim("$event-1:matrix.example.org"))
+        self.assertFalse(store.is_processed("$event-1:matrix.example.org"))
+
+    def test_storage_failure_is_retryable_and_fails_closed(self):
+        blocked_parent = os.path.join(self.temporary_directory.name, "not-a-directory")
+        with open(blocked_parent, "w", encoding="utf-8") as blocked_file:
+            blocked_file.write("block child creation")
+        store = state_store.MatrixStateStore(
+            os.path.join(blocked_parent, "matrix-state.json"), owner_id="run-1"
+        )
+
+        with self.assertRaises(state_store.RetryableStateStoreError) as raised:
+            store.claim("$event-1:matrix.example.org")
+
+        self.assertTrue(raised.exception.retryable)
+        self.assertNotIn("$event-1", str(raised.exception))
+
+    def test_replaced_owner_cannot_complete_or_advance_cursor(self):
+        first = state_store.MatrixStateStore(self.state_path, owner_id="run-1")
+        recovered = state_store.MatrixStateStore(self.state_path, owner_id="run-2")
+        self.assertTrue(first.claim("$event-1:matrix.example.org"))
+        self.assertTrue(recovered.claim("$event-1:matrix.example.org"))
+
+        with self.assertRaises(state_store.StateConflictError) as raised:
+            first.complete("$event-1:matrix.example.org", "stale-cursor")
+
+        self.assertFalse(raised.exception.retryable)
+        self.assertIsNone(first.get_cursor())
+        self.assertTrue(recovered.complete("$event-1:matrix.example.org", "cursor-2"))
+
+    def test_corrupt_state_is_rejected_without_overwrite(self):
+        with open(self.state_path, "w", encoding="utf-8") as state_file:
+            state_file.write("not-json")
+        store = state_store.MatrixStateStore(self.state_path, owner_id="run-1")
+
+        with self.assertRaises(state_store.StateValidationError) as raised:
+            store.claim("$event-1:matrix.example.org")
+
+        self.assertFalse(raised.exception.retryable)
+        with open(self.state_path, encoding="utf-8") as state_file:
+            self.assertEqual("not-json", state_file.read())
+
+    def test_concurrent_duplicate_claim_is_atomic(self):
+        store = state_store.MatrixStateStore(self.state_path, owner_id="run-1")
+
+        with ThreadPoolExecutor(max_workers=8) as executor:
+            results = list(
+                executor.map(
+                    store.claim,
+                    ["$event-1:matrix.example.org"] * 8,
+                )
+            )
+
+        self.assertEqual(1, results.count(True))
+        self.assertEqual(7, results.count(False))
+
+    def test_atomic_replace_failure_leaves_no_partial_state(self):
+        store = state_store.MatrixStateStore(self.state_path, owner_id="run-1")
+
+        with mock.patch.object(
+            state_store.os, "replace", side_effect=OSError("simulated failure")
+        ):
+            with self.assertRaises(state_store.RetryableStateStoreError):
+                store.claim("$event-1:matrix.example.org")
+
+        self.assertFalse(os.path.exists(self.state_path))
+        self.assertEqual(
+            ["matrix-state.json.lock"],
+            sorted(os.listdir(self.temporary_directory.name)),
+        )
+
+    def test_explicit_empty_owner_is_rejected(self):
+        with self.assertRaisesRegex(state_store.StateValidationError, "owner_id"):
+            state_store.MatrixStateStore(self.state_path, owner_id="")
+
+
+if __name__ == "__main__":
+    unittest.main()


