@@ -0,0 +1,356 @@
+#!/usr/bin/env python3
+"""Tests for bounded, metadata-only Matrix attachment handling."""
+
+import io
+import os
+import sys
+import unittest
+import urllib.error
+import urllib.parse
+
+
+REPO_ROOT = os.path.normpath(os.path.join(os.path.dirname(__file__), "../.."))
+sys.path.insert(0, os.path.join(REPO_ROOT, "runtime/matrix"))
+
+import client as matrix_client  # noqa: E402
+import attachments  # noqa: E402
+
+
+class FakeMediaResponse:
+    def __init__(self, content, content_type, content_length=None):
+        self.content = content
+        self.headers = {"Content-Type": content_type}
+        if content_length is not None:
+            self.headers["Content-Length"] = str(content_length)
+        self.read_sizes = []
+
+    def __enter__(self):
+        return self
+
+    def __exit__(self, exc_type, exc, traceback):
+        return False
+
+    def read(self, size=-1):
+        self.read_sizes.append(size)
+        return self.content if size < 0 else self.content[:size]
+
+
+class MatrixMediaClientTest(unittest.TestCase):
+    def test_non_mxc_uri_is_rejected_before_network_access(self):
+        requests = []
+        client = matrix_client.MatrixClient(
+            "https://matrix.example.org",
+            "secret-token",
+            requester=lambda *args, **kwargs: requests.append((args, kwargs)),
+        )
+
+        with self.assertRaises(matrix_client.MatrixMediaURIError):
+            client.download_media("https://evil.example/file.pdf", max_bytes=100)
+
+        self.assertEqual([], requests)
+
+    def test_malformed_mxc_values_are_rejected_before_network_access(self):
+        requests = []
+        client = matrix_client.MatrixClient(
+            "https://matrix.example.org",
+            "secret-token",
+            requester=lambda *args, **kwargs: requests.append((args, kwargs)),
+        )
+        invalid_values = (
+            "mxc://remote.example/media/extra",
+            "mxc://remote.example/media?download=1",
+            "mxc://user@remote.example/media",
+            "mxc://remote.example/media%2Fescape",
+            "mxc://remote example/media",
+            "mxc://remote.example:99999/media",
+            "mxc://[invalid/media",
+        )
+
+        for value in invalid_values:
+            with self.subTest(value=value):
+                with self.assertRaises(matrix_client.MatrixMediaURIError):
+                    client.download_media(value, max_bytes=100)
+
+        self.assertEqual([], requests)
+
+    def test_mxc_download_uses_authenticated_local_homeserver_endpoint(self):
+        requests = []
+        response = FakeMediaResponse(b"pdf-data", "application/pdf", 8)
+
+        def requester(request, timeout):
+            requests.append((request, timeout))
+            return response
+
+        client = matrix_client.MatrixClient(
+            "https://matrix.example.org", "secret-token", requester=requester
+        )
+        result = client.download_media(
+            "mxc://remote.example:8448/media_123", max_bytes=100
+        )
+
+        self.assertEqual(
+            {"content": b"pdf-data", "content_type": "application/pdf"}, result
+        )
+        self.assertEqual([101], response.read_sizes)
+        request, timeout = requests[0]
+        parsed = urllib.parse.urlparse(request.full_url)
+        self.assertEqual("matrix.example.org", parsed.netloc)
+        self.assertEqual(
+            "/_matrix/client/v1/media/download/remote.example%3A8448/media_123",
+            parsed.path,
+        )
+        self.assertEqual({"timeout_ms": ["30000"]}, urllib.parse.parse_qs(parsed.query))
+        self.assertEqual("Bearer secret-token", request.get_header("Authorization"))
+        self.assertNotIn("secret-token", request.full_url)
+        self.assertEqual(35, timeout)
+
+    def test_cross_origin_media_redirect_does_not_forward_access_token(self):
+        handler = matrix_client.MatrixRedirectHandler()
+        original = urllib.request.Request(
+            "https://matrix.example.org/_matrix/client/v1/media/download/a/b",
+            headers={"Authorization": "Bearer secret-token"},
+        )
+
+        redirected = handler.redirect_request(
+            original,
+            None,
+            307,
+            "Temporary Redirect",
+            {},
+            "https://cdn.example.org/object",
+        )
+
+        self.assertIsNotNone(redirected)
+        self.assertIsNone(redirected.get_header("Authorization"))
+
+    def test_same_origin_media_redirect_keeps_access_token(self):
+        handler = matrix_client.MatrixRedirectHandler()
+        original = urllib.request.Request(
+            "https://matrix.example.org/_matrix/client/v1/media/download/a/b",
+            headers={"Authorization": "Bearer secret-token"},
+        )
+
+        redirected = handler.redirect_request(
+            original,
+            None,
+            307,
+            "Temporary Redirect",
+            {},
+            "https://matrix.example.org/cached/object",
+        )
+
+        self.assertEqual("Bearer secret-token", redirected.get_header("Authorization"))
+
+    def test_content_length_over_limit_is_rejected_before_read(self):
+        response = FakeMediaResponse(b"x", "application/pdf", 101)
+        client = matrix_client.MatrixClient(
+            "https://matrix.example.org",
+            "secret-token",
+            requester=lambda request, timeout: response,
+        )
+
+        with self.assertRaises(matrix_client.MatrixMediaTooLargeError):
+            client.download_media("mxc://remote.example/media", max_bytes=100)
+
+        self.assertEqual([], response.read_sizes)
+
+    def test_streamed_response_is_read_only_one_byte_past_limit(self):
+        response = FakeMediaResponse(b"x" * 101, "application/pdf")
+        client = matrix_client.MatrixClient(
+            "https://matrix.example.org",
+            "secret-token",
+            requester=lambda request, timeout: response,
+        )
+
+        with self.assertRaises(matrix_client.MatrixMediaTooLargeError):
+            client.download_media("mxc://remote.example/media", max_bytes=100)
+
+        self.assertEqual([101], response.read_sizes)
+
+    def test_download_timeout_is_mapped_to_redacted_transport_error(self):
+        def timeout(request, timeout):
+            raise TimeoutError("socket details")
+
+        client = matrix_client.MatrixClient(
+            "https://matrix.example.org", "secret-token", requester=timeout
+        )
+
+        with self.assertRaisesRegex(
+            matrix_client.MatrixMediaTimeoutError, "Matrix media download timed out"
+        ):
+            client.download_media("mxc://remote.example/media", max_bytes=100)
+
+    def test_missing_response_mime_is_rejected(self):
+        response = FakeMediaResponse(b"data", None, 4)
+        client = matrix_client.MatrixClient(
+            "https://matrix.example.org",
+            "secret-token",
+            requester=lambda request, timeout: response,
+        )
+
+        with self.assertRaises(matrix_client.MatrixMediaTypeError):
+            client.download_media("mxc://remote.example/media", max_bytes=100)
+
+    def test_matrix_502_media_too_large_response_is_mapped_to_size_error(self):
+        def too_large(request, timeout):
+            raise urllib.error.HTTPError(
+                request.full_url,
+                502,
+                "too large",
+                {},
+                io.BytesIO(b'{"errcode":"M_TOO_LARGE"}'),
+            )
+
+        client = matrix_client.MatrixClient(
+            "https://matrix.example.org", "secret-token", requester=too_large
+        )
+
+        with self.assertRaises(matrix_client.MatrixMediaTooLargeError):
+            client.download_media("mxc://remote.example/media", max_bytes=100)
+
+
+class FakeMatrixClient:
+    def __init__(self, content=b"pdf-data", content_type="application/pdf"):
+        self.content = content
+        self.content_type = content_type
+        self.calls = []
+
+    def download_media(self, content_uri, max_bytes):
+        self.calls.append((content_uri, max_bytes))
+        return {"content": self.content, "content_type": self.content_type}
+
+
+def attachment_source(content_type="application/pdf"):
+    return {
+        "content_uri": "mxc://remote.example/media_123",
+        "content_type": content_type,
+        "filename": "document.pdf",
+        "sender_id": "@alice:matrix.example.org",
+        "room_id": "!control:matrix.example.org",
+        "event_id": "$event-1:matrix.example.org",
+    }
+
+
+class MatrixAttachmentPipelineTest(unittest.TestCase):
+    def test_accepted_attachment_returns_metadata_without_payload(self):
+        client = FakeMatrixClient()
+
+        metadata = attachments.process_attachment(
+            client, attachment_source(), max_size_bytes=100
+        )
+
+        self.assertEqual(
+            {
+                "content_uri": "mxc://remote.example/media_123",
+                "content_type": "application/pdf",
+                "filename": "document.pdf",
+                "size_bytes": 8,
+                "sha256": "5fe9b114c0a92fa1d940462c3f76c253b3594f7b7826d506a7c23e1fdf5f60d9",
+            },
+            metadata,
+        )
+        self.assertEqual(
+            [("mxc://remote.example/media_123", 100)], client.calls
+        )
+        self.assertNotIn("content", metadata)
+        self.assertNotIn("data_base64", metadata)
+
+    def test_default_allowlist_accepts_pdf_image_audio_and_text(self):
+        cases = (
+            ("application/pdf", "application/pdf"),
+            ("image/png", "image/png"),
+            ("audio/ogg", "audio/ogg"),
+            ("text/plain", "text/plain; charset=utf-8"),
+        )
+        for claimed_type, response_type in cases:
+            with self.subTest(content_type=claimed_type):
+                metadata = attachments.process_attachment(
+                    FakeMatrixClient(b"x", response_type),
+                    attachment_source(claimed_type),
+                    max_size_bytes=100,
+                )
+                self.assertEqual(claimed_type, metadata["content_type"])
+
+    def test_mime_mismatch_is_quarantined_with_redacted_audit(self):
+        audits = []
+        source = attachment_source("application/pdf")
+        source["filename"] = "private-medical-record.pdf"
+
+        with self.assertRaises(attachments.AttachmentRejected) as raised:
+            attachments.process_attachment(
+                FakeMatrixClient(b"image-data", "image/png"),
+                source,
+                max_size_bytes=100,
+                audit=audits.append,
+            )
+
+        self.assertEqual("mime_mismatch", raised.exception.reason)
+        self.assertEqual(
+            [
+                {
+                    "action": "quarantined",
+                    "reason": "mime_mismatch",
+                    "event_id": "$event-1:matrix.example.org",
+                    "room_id": "!control:matrix.example.org",
+                }
+            ],
+            audits,
+        )
+        self.assertNotIn("private-medical-record.pdf", repr(audits))
+        self.assertNotIn("image-data", repr(audits))
+
+    def test_download_timeout_is_quarantined(self):
+        class TimeoutClient:
+            def download_media(self, content_uri, max_bytes):
+                raise matrix_client.MatrixMediaTimeoutError("private socket details")
+
+        audits = []
+        with self.assertRaises(attachments.AttachmentRejected) as raised:
+            attachments.process_attachment(
+                TimeoutClient(),
+                attachment_source(),
+                max_size_bytes=100,
+                audit=audits.append,
+            )
+
+        self.assertEqual("download_timeout", raised.exception.reason)
+        self.assertEqual("download_timeout", audits[0]["reason"])
+        self.assertNotIn("private socket details", repr(audits))
+
+    def test_disallowed_mime_is_rejected_before_download(self):
+        audits = []
+        client = FakeMatrixClient(content_type="application/x-executable")
+
+        with self.assertRaises(attachments.AttachmentRejected) as raised:
+            attachments.process_attachment(
+                client,
+                attachment_source("application/x-executable"),
+                max_size_bytes=100,
+                audit=audits.append,
+            )
+
+        self.assertEqual("mime_not_allowed", raised.exception.reason)
+        self.assertEqual([], client.calls)
+        self.assertEqual("mime_not_allowed", audits[0]["reason"])
+
+    def test_over_limit_download_is_quarantined(self):
+        class TooLargeClient:
+            def download_media(self, content_uri, max_bytes):
+                raise matrix_client.MatrixMediaTooLargeError("private size")
+
+        audits = []
+        with self.assertRaises(attachments.AttachmentRejected) as raised:
+            attachments.process_attachment(
+                TooLargeClient(),
+                attachment_source(),
+                max_size_bytes=100,
+                audit=audits.append,
+            )
+
+        self.assertEqual("size_limit", raised.exception.reason)
+        self.assertEqual("size_limit", audits[0]["reason"])
+        self.assertNotIn("private size", repr(audits))
+
+
+if __name__ == "__main__":
+    unittest.main()
