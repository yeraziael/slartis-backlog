+#!/usr/bin/env bash
+# Contract tests for staged Matrix discovery and private federation mode.
+set -euo pipefail
+
+REPO_ROOT="$(cd "$(dirname "$0")/../.." && pwd)"
+
+python3 - \
+  "$REPO_ROOT/pi/synapse/well-known/client.json.example" \
+  "$REPO_ROOT/pi/synapse/well-known/server.json.example" \
+  "$REPO_ROOT/pi/synapse/well-known/headers.example" \
+  "$REPO_ROOT/pi/synapse/synapse.yaml.example" \
+  "$REPO_ROOT/pi/compose/synapse.yml" \
+  "$REPO_ROOT/docs/matrix/federation-mode.md" <<'PY'
+from pathlib import Path
+import json
+import sys
+
+import yaml
+
+
+def require(condition, message):
+    if not condition:
+        raise SystemExit(f"FAIL: {message}")
+    print(f"PASS: {message}")
+
+
+paths = [Path(raw_path) for raw_path in sys.argv[1:]]
+for path in paths:
+    require(path.is_file(), f"required input exists: {path.name}")
+
+client = json.loads(paths[0].read_text(encoding="utf-8"))
+server = json.loads(paths[1].read_text(encoding="utf-8"))
+require(client == {"m.homeserver": {"base_url": "https://matrix.hl.maier.wtf"}},
+        "client discovery points only to the public HTTPS homeserver")
+require(server == {"m.server": "matrix.hl.maier.wtf:443"},
+        "server discovery stages federation through public HTTPS port 443")
+
+headers = {}
+for line in paths[2].read_text(encoding="utf-8").splitlines():
+    line = line.strip()
+    if not line or line.startswith("#"):
+        continue
+    key, value = line.split(":", 1)
+    headers[key.lower()] = value.strip()
+require(headers.get("content-type") == "application/json",
+        "well-known responses declare JSON content")
+require(headers.get("access-control-allow-origin") == "*",
+        "client discovery permits cross-origin reads")
+
+config = yaml.safe_load(paths[3].read_text(encoding="utf-8"))
+resource_names = {
+    resource
+    for listener in config.get("listeners", [])
+    for group in listener.get("resources", [])
+    for resource in group.get("names", [])
+}
+require(resource_names == {"client"},
+        "private mode exposes client resources but no federation resource")
+require(config.get("allow_public_rooms_over_federation") is False,
+        "private mode denies the public room directory over federation")
+require(config.get("serve_server_wellknown", False) is False,
+        "Synapse does not publish server discovery in private mode")
+
+compose = yaml.safe_load(paths[4].read_text(encoding="utf-8"))
+synapse_mounts = str(compose["services"]["synapse"].get("volumes", []))
+require("well-known" not in synapse_mounts,
+        "staged discovery examples are not mounted or published by Compose")
+
+documentation = paths[5].read_text(encoding="utf-8")
+for required in (
+    "Private Mode",
+    "Activation",
+    "Rollback",
+    "Access-Control-Allow-Origin: *",
+    "https://matrix.hl.maier.wtf/.well-known/matrix/client",
+    "https://matrix.hl.maier.wtf/_matrix/federation/v1/version",
+):
+    require(required in documentation, f"federation documentation contains: {required}")
+PY
