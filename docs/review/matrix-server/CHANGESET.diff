index 0000000..6b942e1
--- /dev/null
+++ b/pi/tests/test_coturn_compose.sh
@@ -0,0 +1,215 @@
+#!/usr/bin/env bash
+# Static and rendered contract tests for the private Matrix TURN service.
+set -euo pipefail
+
+REPO_ROOT="$(cd "$(dirname "$0")/../.." && pwd)"
+
+python3 - "$REPO_ROOT" <<'PY'
+import copy
+import os
+from pathlib import Path
+import subprocess
+import sys
+import tempfile
+
+import yaml
+
+
+root = Path(sys.argv[1])
+compose_path = root / "pi/compose/coturn.yml"
+config_path = root / "pi/coturn/turnserver.conf.example"
+env_path = root / "pi/coturn/turn.env.example"
+doc_path = root / "docs/matrix/turn.md"
+synapse_compose_path = root / "pi/compose/synapse.yml"
+synapse_config_path = root / "pi/synapse/synapse.yaml.example"
+required_paths = (
+    compose_path,
+    config_path,
+    env_path,
+    doc_path,
+    synapse_compose_path,
+    synapse_config_path,
+)
+for path in required_paths:
+    if not path.is_file():
+        raise SystemExit(f"FAIL: required input missing: {path}")
+
+
+def require(condition, message):
+    if not condition:
+        raise SystemExit(f"FAIL: {message}")
+    print(f"PASS: {message}")
+
+
+def violations(compose):
+    found = []
+    service = compose.get("services", {}).get("coturn", {})
+    image = service.get("image", "")
+    if "@sha256:" not in image or ":latest" in image:
+        found.append("floating_image")
+    volumes = " ".join(str(value) for value in service.get("volumes", []))
+    if "/var/run/docker.sock" in volumes:
+        found.append("docker_socket")
+    ports = set(str(value) for value in service.get("ports", []))
+    expected_ports = {
+        "3478:3478/tcp",
+        "3478:3478/udp",
+        "5349:5349/tcp",
+        "5349:5349/udp",
+        "49160-49200:49160-49200/tcp",
+        "49160-49200:49160-49200/udp",
+    }
+    if ports != expected_ports:
+        found.append("port_contract")
+    if any("49152-65535" in value for value in ports):
+        found.append("broad_relay_range")
+    return found
+
+
+with compose_path.open(encoding="utf-8") as handle:
+    compose = yaml.safe_load(handle)
+require(not violations(compose), f"Coturn Compose satisfies policy: {violations(compose)}")
+service = compose["services"]["coturn"]
+require(service.get("platform") == "linux/arm64", "Coturn is explicitly ARM64")
+require(service.get("user") == "1000:1000", "Coturn runs as the non-root Pi secret owner")
+require(service.get("read_only") is True, "Coturn root filesystem is read-only")
+require(service.get("cap_drop") == ["ALL"], "Coturn drops all Linux capabilities")
+require("no-new-privileges:true" in service.get("security_opt", []), "Coturn enables no-new-privileges")
+require("healthcheck" in service, "Coturn has a healthcheck")
+require("mem_limit" in service and "cpus" in service, "Coturn has resource limits")
+require("frontproxy_default" not in str(compose.get("networks", {})), "Coturn does not join frontproxy")
+
+secrets = compose.get("secrets", {})
+require(
+    set(secrets) == {"turn_shared_secret", "turn_tls_cert", "turn_tls_key"},
+    "Coturn declares only shared-secret and TLS secret files",
+)
+for name, variable in (
+    ("turn_shared_secret", "TURN_SHARED_SECRET_FILE"),
+    ("turn_tls_cert", "TURN_TLS_CERT_FILE"),
+    ("turn_tls_key", "TURN_TLS_KEY_FILE"),
+):
+    source = secrets[name].get("file", "")
+    require(variable in source and "/home/michael/matrix/secrets/" in source, f"{name} is external and overridable")
+
+config = config_path.read_text(encoding="utf-8")
+for required in (
+    "realm=turn.hl.maier.wtf",
+    "listening-port=3478",
+    "tls-listening-port=5349",
+    "min-port=49160",
+    "max-port=49200",
+    "use-auth-secret",
+    "cert=/run/coturn/tls_cert.pem",
+    "pkey=/run/coturn/tls_key.pem",
+    "no-tlsv1_2",
+    "no-multicast-peers",
+):
+    require(required in config, f"Coturn config contains {required}")
+require("static-auth-secret=" not in config, "versioned Coturn config contains no shared secret")
+require("allow-loopback-peers" not in config, "loopback peers remain denied by default")
+require("cli=" not in config and "cli-password" not in config, "Coturn management CLI remains disabled")
+
+command = service.get("command", "")
+for required in (
+    "/run/secrets/turn_shared_secret",
+    "/run/secrets/turn_tls_cert",
+    "/run/secrets/turn_tls_key",
+    "static-auth-secret=%s",
+    "external-ip=%s/%s",
+    "exec turnserver -c /run/coturn/turnserver.conf",
+):
+    require(required in command, f"Coturn bootstrap contains {required}")
+
+with synapse_compose_path.open(encoding="utf-8") as handle:
+    synapse_compose = yaml.safe_load(handle)
+synapse_secrets = synapse_compose.get("secrets", {})
+require("synapse_turn_shared_secret" in synapse_secrets, "Synapse declares the TURN shared-secret file")
+synapse_command = synapse_compose["services"]["synapse"].get("command", "")
+require('config["turn_shared_secret"] = turn_secret' in synapse_command, "Synapse injects TURN secret at runtime")
+with synapse_config_path.open(encoding="utf-8") as handle:
+    synapse_config = yaml.safe_load(handle)
+require(
+    set(synapse_config.get("turn_uris", []))
+    == {
+        "turn:turn.hl.maier.wtf:3478?transport=udp",
+        "turn:turn.hl.maier.wtf:3478?transport=tcp",
+        "turns:turn.hl.maier.wtf:5349?transport=tcp",
+    },
+    "Synapse advertises the restricted TURN listeners",
+)
+require("turn_shared_secret" not in synapse_config, "versioned Synapse config contains no TURN secret")
+require(synapse_config.get("turn_allow_guests") is False, "guest TURN credentials are disabled")
+
+env_keys = {
+    line.split("=", 1)[0]
+    for line in env_path.read_text(encoding="utf-8").splitlines()
+    if line and not line.startswith("#")
+}
+require(
+    env_keys
+    == {
+        "TURN_EXTERNAL_IP",
+        "TURN_SHARED_SECRET_FILE",
+        "TURN_TLS_CERT_FILE",
+        "TURN_TLS_KEY_FILE",
+    },
+    "TURN environment example contains only public IP and secret paths",
+)
+
+documentation = doc_path.read_text(encoding="utf-8")
+for required in (
+    "turn.hl.maier.wtf",
+    "49160-49200",
+    "CNAME",
+    "firewall",
+    "certificate",
+    "rollback",
+    "trickle-ice",
+):
+    require(required in documentation, f"TURN runbook contains {required}")
+
+mutations = []
+candidate = copy.deepcopy(compose)
+candidate["services"]["coturn"]["image"] = "coturn/coturn:latest"
+mutations.append((candidate, "floating_image"))
+candidate = copy.deepcopy(compose)
+candidate["services"]["coturn"]["volumes"].append("/var/run/docker.sock:/var/run/docker.sock")
+mutations.append((candidate, "docker_socket"))
+candidate = copy.deepcopy(compose)
+candidate["services"]["coturn"]["ports"] = ["49152-65535:49152-65535/udp"]
+mutations.append((candidate, "broad_relay_range"))
+candidate = copy.deepcopy(compose)
+candidate["services"]["coturn"]["ports"] = [
+    value for value in candidate["services"]["coturn"]["ports"] if not str(value).endswith("/udp")
+]
+mutations.append((candidate, "port_contract"))
+for candidate, expected in mutations:
+    require(expected in violations(candidate), f"policy rejects {expected}")
+
+with tempfile.TemporaryDirectory() as temporary_directory:
+    temporary = Path(temporary_directory)
+    secret_files = {}
+    for name in ("shared", "cert", "key"):
+        path = temporary / name
+        path.write_text(f"harmless-{name}\n", encoding="utf-8")
+        secret_files[name] = str(path)
+    environment = os.environ.copy()
+    environment.update(
+        {
+            "TURN_EXTERNAL_IP": "192.0.2.10",
+            "TURN_SHARED_SECRET_FILE": secret_files["shared"],
+            "TURN_TLS_CERT_FILE": secret_files["cert"],
+            "TURN_TLS_KEY_FILE": secret_files["key"],
+        }
+    )
+    result = subprocess.run(
+        ["docker-compose", "-f", str(compose_path), "config"],
+        cwd=root,
+        env=environment,
+        text=True,
+        capture_output=True,
+        check=False,
+    )
+    require(result.returncode == 0, f"Compose renders with harmless external test inputs: {result.stderr}")
+PY
