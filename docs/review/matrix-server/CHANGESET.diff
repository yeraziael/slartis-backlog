diff --git a/pi/tests/test_matrix_release_profile.sh b/pi/tests/test_matrix_release_profile.sh
new file mode 100644
index 0000000..a7b96b6
--- /dev/null
+++ b/pi/tests/test_matrix_release_profile.sh
@@ -0,0 +1,157 @@
+#!/usr/bin/env bash
+# Matrix Release Profile Contract Tests
+#
+# Validates docs/releases/matrix-profile-v1.md and
+# docs/releases/matrix-release-manifest.example.json against the
+# homelab-release/v1 contract.
+#
+# Tests:
+#   1. Release profile exists and is non-empty
+#   2. Release profile contains all required sections
+#   3. Release manifest exists and is valid JSON
+#   4. Release manifest contains all required fields
+#   5. No floating tags or missing digests in manifest
+#   6. Backup evidence fields are present
+#   7. No secrets in release artifacts
+
+PASS=0
+FAIL=0
+
+assert_eq() {
+  local expected="$1" actual="$2" label="$3"
+  if [ "$expected" = "$actual" ]; then
+    echo "  PASS  $label"
+    PASS=$((PASS + 1))
+  else
+    echo "  FAIL  $label (expected: '$expected', got: '$actual')"
+    FAIL=$((FAIL + 1))
+  fi
+}
+
+assert_contains() {
+  local haystack="$1" needle="$2" label="$3"
+  if echo "$haystack" | grep -qF "$needle"; then
+    echo "  PASS  $label"
+    PASS=$((PASS + 1))
+  else
+    echo "  FAIL  $label (expected to contain: '$needle')"
+    FAIL=$((FAIL + 1))
+  fi
+}
+
+assert_not_contains() {
+  local haystack="$1" needle="$2" label="$3"
+  if echo "$haystack" | grep -qF "$needle"; then
+    echo "  FAIL  $label (found: '$needle')"
+    FAIL=$((FAIL + 1))
+  else
+    echo "  PASS  $label"
+    PASS=$((PASS + 1))
+  fi
+}
+
+REPO_ROOT="$(cd "$(dirname "$0")/../.." && pwd)"
+PROFILE="$REPO_ROOT/docs/releases/matrix-profile-v1.md"
+MANIFEST="$REPO_ROOT/docs/releases/matrix-release-manifest.example.json"
+
+echo "============================================"
+echo "  Matrix Release Profile Contract Tests"
+echo "============================================"
+echo ""
+
+echo "--- Test 1: Release profile exists and is non-empty ---"
+[ -f "$PROFILE" ]
+assert_eq 0 $? "T1a: matrix-profile-v1.md exists" $?
+[ -s "$PROFILE" ]
+assert_eq 0 $? "T1b: matrix-profile-v1.md is non-empty" $?
+
+echo ""
+echo "--- Test 2: Required sections present ---"
+CONTENT=$(cat "$PROFILE")
+assert_contains "$CONTENT" "Image Digests" "T2a: Image Digests section"
+assert_contains "$CONTENT" "Config Checksum" "T2b: Config Checksum section"
+assert_contains "$CONTENT" "PostgreSQL Kompatibilit" "T2c: PostgreSQL compatibility section"
+assert_contains "$CONTENT" "Backup/Restore Evidence" "T2d: Backup/Restore Evidence section"
+assert_contains "$CONTENT" "Smoke-Test Contract" "T2e: Smoke-Test Contract section"
+assert_contains "$CONTENT" "Rollback-Klassifikation" "T2f: Rollback classification section"
+
+echo ""
+echo "--- Test 3: Release manifest is valid JSON ---"
+jq -e '.' "$MANIFEST" >/dev/null 2>&1
+assert_eq 0 $? "T3: release-manifest.example.json is valid JSON" $?
+
+echo ""
+echo "--- Test 4: Required manifest fields ---"
+META=$(jq -r '.schema_version' "$MANIFEST" 2>/dev/null)
+assert_eq "homelab-release/v1" "$META" "T4a: schema_version is homelab-release/v1"
+PROF=$(jq -r '.profile' "$MANIFEST" 2>/dev/null)
+assert_eq "matrix-profile-v1" "$PROF" "T4b: profile is matrix-profile-v1"
+
+for field in release_version release_commit created_at artifacts compatibility; do
+  VAL=$(jq -r ".$field // empty" "$MANIFEST" 2>/dev/null)
+  [ -n "$VAL" ]
+  assert_eq 0 $? "T4c: field '$field' is present" $?
+done
+
+echo ""
+echo "--- Test 5: No floating tags or missing digests ---"
+for service in synapse postgresql coturn element; do
+  DIGEST=$(jq -r ".artifacts.$service.image.digest // empty" "$MANIFEST" 2>/dev/null)
+  if [ -n "$DIGEST" ]; then
+    echo "$DIGEST" | grep -q '^sha256:'
+    if [ $? -eq 0 ]; then
+      echo "  PASS  T5a: $service has sha256 digest"
+      PASS=$((PASS + 1))
+    else
+      echo "  FAIL  T5a: $service digest is not sha256 format: $DIGEST"
+      FAIL=$((FAIL + 1))
+    fi
+  else
+    echo "  FAIL  T5a: $service has no image.digest field"
+    FAIL=$((FAIL + 1))
+  fi
+
+  TAG=$(jq -r ".artifacts.$service.image.tag // \"\"" "$MANIFEST" 2>/dev/null)
+  if [ -n "$TAG" ]; then
+    echo "$TAG" | grep -qE '^v?[0-9]+\.'
+    if [ $? -ne 0 ] && [ "$TAG" != "16-alpine" ]; then
+      echo "  FAIL  T5b: $service uses floating tag pattern: $TAG"
+      FAIL=$((FAIL + 1))
+    else
+      echo "  PASS  T5b: $service tag is explicit: $TAG"
+      PASS=$((PASS + 1))
+    fi
+  else
+    echo "  PASS  T5b: $service has no tag field (digest-only)"
+    PASS=$((PASS + 1))
+  fi
+done
+
+echo ""
+echo "--- Test 6: Backup evidence fields ---"
+BACKUP=$(jq -r '.backup_evidence // empty' "$MANIFEST" 2>/dev/null)
+if [ -n "$BACKUP" ]; then
+  for field in backup_timestamp backup_sha256 restore_tested smoke_test_passed; do
+    VAL=$(jq -r ".backup_evidence.$field // empty" "$MANIFEST" 2>/dev/null)
+    [ -n "$VAL" ]
+    assert_eq 0 $? "T6: backup_evidence.$field is present" $?
+  done
+else
+  echo "  FAIL  T6: backup_evidence section missing"
+  FAIL=$((FAIL + 1))
+fi
+
+echo ""
+echo "--- Test 7: No secrets in release artifacts ---"
+assert_not_contains "$CONTENT" "sk-" "T7a: no OpenAI-style keys in profile"
+assert_not_contains "$CONTENT" "token" "T7b: no 'token' keyword in profile (expected placeholder)"
+MANIFEST_STR=$(cat "$MANIFEST")
+assert_not_contains "$MANIFEST_STR" "CHANGEME" "T7c: no CHANGEME placeholders in manifest"
+assert_not_contains "$MANIFEST_STR" "sk-" "T7d: no API keys in manifest"
+
+echo ""
+echo "============================================"
+echo "  Results: $PASS passed, $FAIL failed"
+echo "============================================"
+
+[ "$FAIL" -eq 0 ] || exit 1

