diff --git a/pi/tests/test_audiobookshelf_proxy.sh b/pi/tests/test_audiobookshelf_proxy.sh
new file mode 100755
index 0000000..e6cfc5a
--- /dev/null
+++ b/pi/tests/test_audiobookshelf_proxy.sh
@@ -0,0 +1,92 @@
+#!/usr/bin/env bash
+# Static contract tests for Audiobookshelf reverse proxy and TLS.
+set -euo pipefail
+
+REPO_ROOT="$(cd "$(dirname "$0")/../.." && pwd)"
+
+python3 - \
+  "$REPO_ROOT/pi/compose/audiobookshelf.yml" \
+  "$REPO_ROOT/pi/compose/vhost.d/audiobookshelf.hl.maier.wtf_location" \
+  "$REPO_ROOT/docs/AUDIOBOOKSHELF.md" <<'PY'
+from pathlib import Path
+import re
+import sys
+
+import yaml
+
+
+def require(condition, message):
+    if not condition:
+        raise SystemExit(f"FAIL: {message}")
+    print(f"PASS: {message}")
+
+
+compose_path, vhost_path, docs_path = (Path(value) for value in sys.argv[1:])
+for path in (compose_path, vhost_path, docs_path):
+    require(path.is_file(), f"required input exists: {path}")
+
+compose = yaml.safe_load(compose_path.read_text(encoding="utf-8"))
+require(set(compose.get("services", {})) == {"audiobookshelf"}, "stack defines only Audiobookshelf")
+abs = compose["services"]["audiobookshelf"]
+
+# Image pinning
+require(
+    abs.get("image") ==
+    "ghcr.io/advplyr/audiobookshelf@sha256:1eef6716183c52abafe5405e7d6be8390248ecd59c7488c44af871757ac8fc4d",
+    "Audiobookshelf image is pinned by immutable digest",
+)
+require(abs.get("platform") == "linux/arm64", "Audiobookshelf explicitly selects ARM64")
+require(abs.get("restart") == "unless-stopped", "Audiobookshelf has a restart policy")
+
+# No host ports (only internal + frontproxy)
+require("ports" not in abs, "Audiobookshelf publishes no host port")
+require(set(abs.get("expose", [])) == {"13378"}, "Audiobookshelf exposes only internal port 13378")
+
+# Proxy environment
+expected_proxy_env = {
+    "VIRTUAL_HOST": "audiobookshelf.hl.maier.wtf",
+    "VIRTUAL_PORT": "13378",
+    "LETSENCRYPT_HOST": "audiobookshelf.hl.maier.wtf",
+    "LETSENCRYPT_EMAIL": "webmaster@maier.wtf",
+}
+env = abs.get("environment", {})
+for key, val in expected_proxy_env.items():
+    require(env.get(key) == val, f"Audiobookshelf proxy env: {key}={val}")
+
+# Networks
+networks = set(abs.get("networks", []))
+require("frontproxy_default" in networks, "Audiobookshelf joins frontproxy_default network")
+require("audiobookshelf_internal" in networks, "Audiobookshelf joins audiobookshelf_internal network")
+
+expected_networks = {
+    "audiobookshelf_internal": {"internal": True},
+    "frontproxy_default": {"external": True},
+}
+require(compose.get("networks") == expected_networks, "network declarations are exact")
+
+# Security and resources
+require("no-new-privileges:true" in abs.get("security_opt", []), "Audiobookshelf blocks privilege escalation")
+require("mem_limit" in abs and "cpus" in abs, "Audiobookshelf has CPU and memory limits")
+logging = abs.get("logging", {}).get("options", {})
+require(logging == {"max-size": "10m", "max-file": "7"}, "Audiobookshelf logs are bounded")
+require(abs.get("healthcheck") is not None, "Audiobookshelf has a healthcheck")
+
+# Secrets / configs
+require("secrets" not in abs and "configs" not in abs, "Audiobookshelf declares no secrets or extra configs")
+
+# vhost.d config
+vhost = vhost_path.read_text(encoding="utf-8")
+require("client_max_body_size" in vhost, "vhost.d sets client_max_body_size for large uploads")
+require("proxy_set_header Upgrade" in vhost, "vhost.d forwards WebSocket Upgrade header")
+require("proxy_set_header Connection" in vhost, "vhost.d forwards WebSocket Connection header")
+
+# Documentation
+docs = docs_path.read_text(encoding="utf-8")
+for required in (
+    "audiobookshelf.hl.maier.wtf",
+    "frontproxy",
+    "nginx-proxy",
+    "VIRTUAL_HOST",
+):
+    require(required in docs, f"Audiobookshelf architecture docs contain: {required}")
+PY

