@@ -0,0 +1,136 @@
+#!/usr/bin/env bash
+# Static contract test for the repository-only mautrix-instagram bridge.
+set -uo pipefail
+
+REPO_ROOT="$(cd "$(dirname "$0")/../.." && pwd)"
+
+python3 - "$REPO_ROOT" <<'PY'
+from pathlib import Path
+import re
+import sys
+
+import yaml
+
+root = Path(sys.argv[1])
+compose_path = root / "pi/compose/mautrix-instagram.yml"
+config_path = root / "pi/mautrix-instagram/config.yaml.example"
+facebook_compose_path = root / "pi/compose/mautrix-facebook.yml"
+facebook_config_path = root / "pi/mautrix-facebook/config.yaml.example"
+synapse_path = root / "pi/synapse/synapse.yaml.example"
+runbook_path = root / "pi/synapse/BRIDGES.md"
+
+
+def require(condition, message):
+    if not condition:
+        raise SystemExit(f"FAIL: {message}")
+    print(f"PASS: {message}")
+
+
+for path in (
+    compose_path,
+    config_path,
+    facebook_compose_path,
+    facebook_config_path,
+    synapse_path,
+    runbook_path,
+):
+    require(path.is_file(), f"required input exists: {path.relative_to(root)}")
+
+compose = yaml.safe_load(compose_path.read_text(encoding="utf-8"))
+services = compose.get("services", {})
+require(set(services) == {"mautrix-instagram"}, "stack defines only mautrix-instagram")
+
+service = services["mautrix-instagram"]
+require(
+    service.get("image")
+    == "dock.mau.dev/mautrix/meta@sha256:3f9c260c05c8880e1d7d54677e311e530afdcbd4ec08e4f42f1273b47579e881",
+    "Instagram image uses the verified ig-v26.07 multi-arch manifest digest",
+)
+require(service.get("platform") == "linux/arm64", "Instagram bridge is explicitly ARM64")
+require(service.get("restart") == "unless-stopped", "Instagram bridge has restart policy")
+require(service.get("mem_limit") == "256m", "Instagram bridge has explicit memory limit")
+require(service.get("cpus") == "0.5", "Instagram bridge has explicit CPU limit")
+require("ports" not in service and "expose" not in service, "Instagram bridge publishes no port")
+require("environment" not in service, "Instagram bridge has no proxy or inline secret environment")
+require("secrets" not in service, "Instagram Compose declares no secret values")
+require(
+    "no-new-privileges:true" in service.get("security_opt", []),
+    "Instagram bridge prevents privilege escalation",
+)
+require(
+    service.get("volumes") == ["/home/michael/mautrix-instagram:/data:z"],
+    "Instagram config and data use the dedicated persistent path",
+)
+require(set(service.get("networks", [])) == {"bridge_internal"}, "Instagram joins only bridge_internal")
+require(
+    compose.get("networks", {}).get("bridge_internal", {}).get("external") is True,
+    "bridge_internal is external",
+)
+
+config_text = config_path.read_text(encoding="utf-8")
+config = yaml.safe_load(config_text)
+require(config["bridge"]["command_prefix"] == "!instagram", "Instagram command prefix is unique")
+require(
+    config["bridge"]["permissions"]
+    == {
+        "*": "relay",
+        "matrix.hl.maier.wtf": "user",
+        "@slarti:matrix.hl.maier.wtf": "admin",
+    },
+    "Instagram permissions follow the Homelab policy",
+)
+require(
+    config["database"]["uri"]
+    == "postgres://mautrix_instagram:CHANGEME@compose-postgres-1:5432/mautrix_instagram?sslmode=disable",
+    "Instagram uses a dedicated database placeholder",
+)
+require(config["homeserver"]["address"] == "http://compose-synapse-1:8008", "internal Synapse URL is configured")
+require(config["homeserver"]["domain"] == "matrix.hl.maier.wtf", "homeserver domain is configured")
+
+appservice = config["appservice"]
+require(appservice["address"] == "http://mautrix-instagram:29330", "internal appservice URL is configured")
+require(appservice["public_address"] is None, "Instagram appservice has no public address")
+require(appservice["hostname"] == "0.0.0.0" and appservice["port"] == 29330, "container listener matches generated schema")
+require(appservice["id"] == "instagram", "Instagram appservice ID is unique")
+require(appservice["bot"]["username"] == "instagrambot", "Instagram bot MXID localpart is unique")
+require(appservice["username_template"] == "instagram_{{.}}", "Instagram ghost namespace is unique")
+sentinel = "This value is generated when generating the registration"
+require(appservice["as_token"] == sentinel and appservice["hs_token"] == sentinel, "registration tokens remain generator sentinels")
+
+encryption = config["encryption"]
+require(encryption["allow"] is True, "Matrix end-to-bridge encryption is enabled")
+require(encryption["default"] is False and encryption["require"] is False, "Matrix encryption is supported but not forced")
+require(encryption["pickle_key"] == "generate", "encryption pickle key is generated at deployment")
+require(config["provisioning"]["shared_secret"] == "generate", "provisioning secret is generated at deployment")
+require(config["public_media"]["enabled"] is False, "public media endpoint is disabled")
+require(config["direct_media"]["enabled"] is False, "direct media endpoint is disabled")
+require(config["double_puppet"]["secrets"] == {"matrix.hl.maier.wtf": ""}, "double-puppet secret is an empty placeholder")
+cookie_assignment = re.compile(r"(?im)(?:^|\s)(?:sessionid|csrftoken|mid|ig_did|ds_user_id)\s*[:=]")
+require(cookie_assignment.search(config_text) is None, "Instagram login cookie assignments are absent")
+require(config["logging"]["min_level"] == "info", "Instagram debug logging is disabled")
+require(
+    config["logging"]["writers"] == [{"type": "stdout", "format": "pretty-colored"}],
+    "Instagram logs only to container stdout",
+)
+
+facebook_compose = yaml.safe_load(facebook_compose_path.read_text(encoding="utf-8"))
+facebook_service = facebook_compose["services"]["mautrix-facebook"]
+facebook_config = yaml.safe_load(facebook_config_path.read_text(encoding="utf-8"))
+require(service["volumes"] != facebook_service["volumes"], "Instagram and Facebook persistent paths are separate")
+require(config["database"]["uri"] != facebook_config["database"]["uri"], "Instagram and Facebook databases are separate")
+require(appservice["id"] != facebook_config["appservice"]["id"], "Instagram and Facebook appservice IDs are separate")
+require(appservice["bot"]["username"] != facebook_config["appservice"]["bot"]["username"], "Instagram and Facebook bots are separate")
+require(appservice["username_template"] != facebook_config["appservice"]["username_template"], "Instagram and Facebook ghost namespaces are separate")
+
+synapse = yaml.safe_load(synapse_path.read_text(encoding="utf-8"))
+require(
+    "/data/appservice/mautrix-instagram.yaml" in synapse.get("app_service_config_files", []),
+    "Synapse template references the Instagram registration path",
+)
+runbook = runbook_path.read_text(encoding="utf-8")
+require("mautrix-instagram" in runbook, "runbook documents the Instagram bridge")
+require("^@instagram_.*:matrix\\.hl\\.maier\\.wtf$" in runbook, "runbook records the generated Instagram ghost namespace")
+require("CPU, RSS, Swap und Storage" in runbook, "runbook requires Instagram resource measurement")
+
+print("PASS: mautrix-instagram repository contract satisfied")
+PY
