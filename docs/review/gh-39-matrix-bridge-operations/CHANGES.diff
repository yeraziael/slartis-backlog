@@ -0,0 +1,100 @@
+#!/usr/bin/env bash
+# Static contract test for Matrix bridge operations, backup, and upgrades.
+set -uo pipefail
+
+REPO_ROOT="$(cd "$(dirname "$0")/../.." && pwd)"
+
+python3 - "$REPO_ROOT" <<'PY'
+from pathlib import Path
+import re
+import sys
+
+root = Path(sys.argv[1])
+runbook_path = root / "pi/synapse/BRIDGE-OPERATIONS.md"
+install_guide_path = root / "pi/synapse/BRIDGES.md"
+
+
+def require(condition, message):
+    if not condition:
+        raise SystemExit(f"FAIL: {message}")
+    print(f"PASS: {message}")
+
+
+require(runbook_path.is_file(), "bridge operations runbook exists")
+text = runbook_path.read_text(encoding="utf-8")
+normalized_text = " ".join(text.split())
+require(
+    "BRIDGE-OPERATIONS.md" in install_guide_path.read_text(encoding="utf-8"),
+    "bridge installation guide links the operations runbook",
+)
+
+for heading in (
+    "## Preconditions And Safety",
+    "## Start And Stop",
+    "## Health And Regression Gates",
+    "## Safe Log Diagnosis",
+    "## Backup",
+    "## Restore",
+    "## Upgrade",
+    "## Rollback",
+    "## Operator Blackbox Test",
+):
+    require(heading in text, f"runbook contains {heading}")
+
+for bridge in ("signal", "telegram", "whatsapp"):
+    require(f"mautrix-{bridge}" in text, f"runbook covers mautrix-{bridge}")
+    require(f"/home/michael/mautrix-{bridge}" in text, f"runbook covers {bridge} persistent state")
+    require(f"mautrix_{bridge}" in text, f"runbook covers {bridge} database")
+    require(
+        f"/data/appservice/mautrix-{bridge}.yaml" in text,
+        f"runbook covers {bridge} registration",
+    )
+
+for command in (
+    'ARCHITECTURE_ROOT="<architecture-checkout>"',
+    'COMPOSE_FILE="$ARCHITECTURE_ROOT/pi/compose/mautrix-<bridge>.yml"',
+    'git -C "$ARCHITECTURE_ROOT" diff --quiet',
+    'git -C "$ARCHITECTURE_ROOT" diff --cached --quiet',
+    'docker compose -f "$COMPOSE_FILE"',
+    "docker inspect",
+    "/_matrix/mau/live",
+    "/_matrix/mau/ready",
+    "pg_dump",
+    "pg_restore",
+    "cmp pi/synapse/synapse.yaml.example",
+    "sha256sum -c",
+    'git -C "$ARCHITECTURE_ROOT" switch --detach <release-commit>',
+    'git -C "$ARCHITECTURE_ROOT" switch --detach <previous-release-commit>',
+):
+    require(command in text, f"runbook contains command or contract: {command}")
+
+require("umask 077" in text, "backup procedure uses restrictive permissions")
+require("existing registrations" in text, "registration changes preserve existing registrations")
+require("homeserver.active.yaml" in text, "backup captures the active Synapse configuration")
+require("app_service_config_files.json" in text, "backup captures the active appservice list")
+require("pi/synapse/synapse.yaml.example" in text, "backup and restore cover the versioned Synapse template")
+require(
+    "restart it and pass its health gates before selecting the next bridge" in normalized_text,
+    "backup sequence prevents unintended multi-bridge outage",
+)
+require("CPU, RSS, Swap, and Storage" in text, "resource acceptance is documented")
+require("Signal and Telegram" in text, "existing bridges are explicit regression gates")
+require("Never paste raw logs" in text, "raw runtime logs are prohibited as evidence")
+require("hashes only" in text, "token consistency uses hashes without values")
+require("Action:" in text and "Expected:" in text and "Evidence:" in text, "blackbox test is executable")
+require(
+    "/home/michael/matrix/compose/mautrix-<bridge>.yml" not in text,
+    "runbook never deploys an unbound runtime Compose copy",
+)
+
+secret_patterns = {
+    "Matrix access token": r"syt_[A-Za-z0-9_-]{12,}",
+    "Telegram bot token": r"\b[0-9]{8,10}:[A-Za-z0-9_-]{20,}\b",
+    "Meta cookie assignment": r"(?im)(?:sessionid|csrftoken|ig_did|ds_user_id|c_user|xs)\s*[:=]\s*[^<\s]",
+    "literal appservice token": r"(?im)(?:as_token|hs_token)\s*:\s*[A-Za-z0-9_-]{20,}",
+}
+for label, pattern in secret_patterns.items():
+    require(re.search(pattern, text) is None, f"runbook excludes {label}")
+
+print("PASS: Matrix bridge operations contract satisfied")
+PY
