diff --git a/pi/compose/audiobookshelf.yml b/pi/compose/audiobookshelf.yml
new file mode 100644
index 0000000..5045646
--- /dev/null
+++ b/pi/compose/audiobookshelf.yml
@@ -0,0 +1,44 @@
+services:
+  audiobookshelf:
+    image: ghcr.io/advplyr/audiobookshelf@sha256:1eef6716183c52abafe5405e7d6be8390248ecd59c7488c44af871757ac8fc4d
+    platform: linux/arm64
+    container_name: audiobookshelf
+    restart: unless-stopped
+    healthcheck:
+      test: ["CMD", "node", "-e", "try { require('http').get('http://localhost:13378/health', r => { process.exit(r.statusCode === 200 ? 0 : 1) }) } catch(e) { process.exit(1) }"]
+      interval: 15s
+      timeout: 10s
+      retries: 5
+      start_period: 60s
+    mem_limit: 512m
+    cpus: "1.0"
+    security_opt:
+      - no-new-privileges:true
+    logging:
+      driver: json-file
+      options:
+        max-size: "10m"
+        max-file: "7"
+    expose:
+      - "13378"
+    volumes:
+      - audiobookshelf_config:/config
+      - audiobookshelf_metadata:/metadata
+    networks:
+      - audiobookshelf_internal
+
+volumes:
+  audiobookshelf_config:
+    driver_opts:
+      type: none
+      device: /mnt/hardDrive/docker/audiobookshelf/config
+      o: bind
+  audiobookshelf_metadata:
+    driver_opts:
+      type: none
+      device: /mnt/hardDrive/docker/audiobookshelf/metadata
+      o: bind
+
+networks:
+  audiobookshelf_internal:
+    internal: true
