+++ b/pi/audiobookshelf/scripts/break-glass-setup.sh
@@ -0,0 +1,101 @@
+#!/usr/bin/env bash
+#
+# break-glass-setup.sh — GH-60: create/rotate the local Audiobookshelf
+# break-glass account `admin` and deliver its password to the operator over
+# the existing Telegram operator channel — exactly once, password only.
+#
+# SECURITY CONTRACT (GH-60 §6.2):
+#   * Password is generated with a cryptographic RNG (>= 192 bits entropy).
+#   * It is set on the local ABS `admin` account immediately.
+#   * It is sent to Telegram EXACTLY ONCE, message body = password ONLY
+#     (no prefix, no markdown, no code block, no companion text).
+#   * It is NEVER written to a file, shell history, process args, logs,
+#     CI output, issues, PRs, or the repository.
+#   * On unclear/failed Telegram delivery the password is DISCARDED, a NEW
+#     password is generated and set, and only the new value is sent once.
+#   * The same password is never sent twice.
+#   * Run WITHOUT `set -x`.
+#
+# Inputs (environment):
+#   ABS_URL                 default https://audiobookshelf.hl.maier.wtf
+#   ABS_ADMIN_TOKEN         root/admin ABS bearer token (required)
+#   TELEGRAM_BOT_TOKEN      operator-channel bot token (required)
+#   TELEGRAM_CHAT_ID        operator chat id            (required)
+#   BREAK_GLASS_USERNAME    default admin
+#
+set -euo pipefail
+if [[ ${-:-} == *x* ]]; then
+  echo "Refusing to run with 'set -x' (would leak the password). Aborting." >&2
+  exit 1
+fi
+
+ABS_URL="${ABS_URL:-https://audiobookshelf.hl.maier.wtf}"
+ADMIN_TOKEN="${ABS_ADMIN_TOKEN:?ABS_ADMIN_TOKEN must be set (root/admin ABS token)}"
+TG_TOKEN="${TELEGRAM_BOT_TOKEN:?TELEGRAM_BOT_TOKEN must be set (operator channel)}"
+TG_CHAT="${TELEGRAM_CHAT_ID:?TELEGRAM_CHAT_ID must be set (operator chat id)}"
+BG_USER="${BREAK_GLASS_USERNAME:-admin}"
+
+generate_password() {
+  # 32 random bytes -> 64 hex chars = 256 bits entropy (>= 192 bits required).
+  openssl rand -hex 32
+}
+
+set_abs_password() {
+  local pw="$1"
+  # Find existing user id (redacted: only the id is printed to stderr).
+  local uid
+  uid="$(curl -sS -X GET "$ABS_URL/api/users" \
+    -H "Authorization: Bearer $ADMIN_TOKEN" \
+    | jq -r --arg u "$BG_USER" '.[]? | select(.username==$u) | .id' | head -n1)"
+
+  if [[ -n "$uid" ]]; then
+    echo ">> Updating existing local user '$BG_USER' (id=$uid)" >&2
+    curl -sS -X PATCH "$ABS_URL/api/users/$uid" \
+      -H "Authorization: Bearer $ADMIN_TOKEN" \
+      -H "Content-Type: application/json" \
+      -d "$(jq -n --arg p "$pw" '{password:$p}')" >/dev/null
+  else
+    echo ">> Creating local break-glass user '$BG_USER'" >&2
+    curl -sS -X POST "$ABS_URL/api/users" \
+      -H "Authorization: Bearer $ADMIN_TOKEN" \
+      -H "Content-Type: application/json" \
+      -d "$(jq -n --arg u "$BG_USER" --arg p "$pw" '{username:$u,password:$p,type:"admin",isActive:true}')" >/dev/null
+  fi
+}
+
+send_once() {
+  local pw="$1"
+  # Body is the password ONLY. No parse_mode -> no markdown/code block.
+  local resp
+  resp="$(curl -sS "https://api.telegram.org/bot$TG_TOKEN/sendMessage" \
+    --data-urlencode "chat_id=$TG_CHAT" \
+    --data-urlencode "text=$pw")"
+  echo "$resp" | jq -e '.ok==true' >/dev/null 2>&1
+}
+
+# --- main -------------------------------------------------------------------
+PW="$(generate_password)"
+set_abs_password "$PW"
+
+if send_once "$PW"; then
+  echo ">> Break-glass password delivered exactly once to operator channel." >&2
+  echo ">> Operator stores it OFFLINE. Nothing else is printed." >&2
+  unset PW
+  exit 0
+fi
+
+# Delivery unclear/failed: discard, regenerate, set new, send new once.
+echo ">> Telegram delivery not confirmed. Discarding password, regenerating." >&2
+unset PW
+PW="$(generate_password)"
+set_abs_password "$PW"
+if send_once "$PW"; then
+  echo ">> New break-glass password delivered exactly once to operator channel." >&2
+  unset PW
+  exit 0
+fi
+
+echo ">> FATAL: unable to deliver break-glass password via Telegram." >&2
+echo ">> The ABS 'admin' password was set to a fresh secret; retrieve/rotate manually." >&2
+unset PW
+exit 1
