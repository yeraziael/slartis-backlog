+#!/usr/bin/env bash
+#
+# verify-break-glass.sh — GH-60 §6.3: blackbox verification of the local
+# break-glass login. The password is read interactively (no echo) and is
+# NEVER included in any output, log, or evidence file.
+#
+# Usage: ABS_ADMIN_USERNAME=admin ./verify-break-glass.sh
+#   (prompts for the password; prints only PASS/FAIL + redacted metadata)
+#
+set -euo pipefail
+ABS_URL="${ABS_URL:-https://audiobookshelf.hl.maier.wtf}"
+USER="${ABS_ADMIN_USERNAME:-admin}"
+
+echo "Target: $USER @ $ABS_URL"
+read -rsp "Break-glass password (not shown): " PW
+echo
+
+resp="$(curl -sS -X POST "$ABS_URL/api/login" \
+  -H "Content-Type: application/json" \
+  -d "$(jq -n --arg u "$USER" --arg p "$PW" '{username:$u,password:$p}')")"
+unset PW
+
+if echo "$resp" | jq -e '.user and (.user.username==env.USER or .user.username=="'"$USER"'")' >/dev/null 2>&1; then
+  echo "RESULT: PASS"
+  echo "When:   $(date -u +%Y-%m-%dT%H:%M:%SZ)"
+  echo "Target: $USER @ $ABS_URL (Keycloak-independent local login)"
+  echo "Note:   password not present in this output."
+else
+  echo "RESULT: FAIL"
+  echo "When:   $(date -u +%Y-%m-%dT%H:%M:%SZ)"
+  echo "Target: $USER @ $ABS_URL"
+  exit 1
+fi
