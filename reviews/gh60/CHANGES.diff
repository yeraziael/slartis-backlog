@@ -0,0 +1,62 @@
+#!/usr/bin/env bash
+#
+# apply-abs-settings.sh — GH-60: Push the OIDC server settings into the running
+# Audiobookshelf instance.
+#
+# SECURITY:
+#   * The client secret is supplied ONLY via environment variable
+#     OIDC_CLIENT_SECRET (or a file referenced by OIDC_CLIENT_SECRET_FILE).
+#   * It is substituted into the payload in memory and is NEVER written to a
+#     file, log, or the repository.
+#   * Run WITHOUT `set -x`.
+#
+# Prerequisites:
+#   * Audiobookshelf reachable at ABS_URL (default https://audiobookshelf.hl.maier.wtf).
+#   * An admin (root) ABS token in ABS_ADMIN_TOKEN (from `ABS_ADMIN_USERNAME` /
+#     `ABS_ADMIN_PASSWORD` exchanged for a token, or a pre-issued token).
+#   * jq available.
+#
+set -euo pipefail
+if [[ ${-:-} == *x* ]]; then
+  echo "Refusing to run with 'set -x' (would leak the client secret). Aborting." >&2
+  exit 1
+fi
+
+ABS_URL="${ABS_URL:-https://audiobookshelf.hl.maier.wtf}"
+SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
+SETTINGS_FILE="${SETTINGS_FILE:-$SCRIPT_DIR/oidc/abs-server-settings.json}"
+
+# Resolve the secret from env or from a referenced file (never echo it).
+if [[ -n "${OIDC_CLIENT_SECRET_FILE:-}" ]]; then
+  OIDC_CLIENT_SECRET="$(cat "$OIDC_CLIENT_SECRET_FILE")"
+elif [[ -z "${OIDC_CLIENT_SECRET:-}" ]]; then
+  echo "OIDC_CLIENT_SECRET (or OIDC_CLIENT_SECRET_FILE) must be set." >&2
+  exit 1
+fi
+
+ADMIN_TOKEN="${ABS_ADMIN_TOKEN:?ABS_ADMIN_TOKEN must be set (root/admin ABS token)}"
+
+# Substitute the secret in memory (no temp file, no trace in shell history
+# beyond this process which is discarded on exit).
+payload="$(jq --arg secret "$OIDC_CLIENT_SECRET" \
+  '._comment = null | .authOpenIDClientSecret = $secret' "$SETTINGS_FILE")"
+
+echo ">> Patching ABS server settings at $ABS_URL" >&2
+resp="$(curl -sS -X PATCH "$ABS_URL/api/settings" \
+  -H "Authorization: Bearer $ADMIN_TOKEN" \
+  -H "Content-Type: application/json" \
+  -d "$payload")"
+
+if echo "$resp" | jq -e '.authOpenIDIssuerURL' >/dev/null 2>&1; then
+  echo ">> Settings applied. OIDC issuer:" >&2
+  echo "$resp" | jq -r '.authOpenIDIssuerURL' >&2
+  echo ">> Verify 'authOpenIDClientSecret' is NOT echoed by the API (it is redacted)." >&2
+else
+  echo ">> ERROR: settings patch did not return expected fields:" >&2
+  echo "$resp" | head -c 500 >&2
+  echo >&2
+  exit 1
+fi
+
+# Discard the secret from memory immediately.
+unset OIDC_CLIENT_SECRET payload resp
