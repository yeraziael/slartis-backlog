index 0000000..89468f7
--- /dev/null
+++ b/pi/audiobookshelf/scripts/setup-keycloak.sh
@@ -0,0 +1,185 @@
+#!/usr/bin/env bash
+#
+# setup-keycloak.sh — GH-60: Provision the Audiobookshelf OIDC client in the
+# existing Keycloak `homelab` realm.
+#
+# This script is the SINGLE source of truth for the runtime Keycloak objects
+# required by issue GH-60. It is executed by the runtime operator (Lydia) on
+# the host that runs the `keycloak` container.
+#
+# SECURITY:
+#   * The generated client secret is printed EXACTLY ONCE to stdout.
+#   * It is NEVER written to a file, log, CI output, or the repository.
+#   * Capture it immediately into the runtime secret store (see runbook).
+#   * Run with `set +x` / never pass `-x` so the secret cannot leak via
+#     shell tracing.
+#
+# Prerequisites:
+#   * `keycloak` container running on this host (quay.io/keycloak, realm
+#     `homelab` already exists).
+#   * Keycloak admin credentials supplied via environment:
+#       KC_ADMIN          (master-realm admin, e.g. `admin`)
+#       KC_ADMIN_PASSWORD
+#   * Optional:
+#       ABS_ADMIN_USERNAME  (Keycloak user that becomes ABS admin; default `michael`)
+#
+set -euo pipefail
+
+# Never trace this script: it handles a secret.
+if [[ ${-:-} == *x* ]]; then
+  echo "Refusing to run with 'set -x' (would leak the client secret). Aborting." >&2
+  exit 1
+fi
+
+REALM="homelab"
+CLIENT_ID="audiobookshelf"
+ABS_URL="https://audiobookshelf.hl.maier.wtf"
+CALLBACK="${ABS_URL}/auth/openid/callback"
+POST_LOGOUT="${ABS_URL}/login"
+ADMIN_USER="${ABS_ADMIN_USERNAME:-michael}"
+
+KC_ADMIN="${KC_ADMIN:?KC_ADMIN must be set (Keycloak master-admin user)}"
+KC_ADMIN_PASSWORD="${KC_ADMIN_PASSWORD:?KC_ADMIN_PASSWORD must be set}"
+
+KCADM="docker exec -i keycloak /opt/keycloak/bin/kcadm.sh"
+
+echo ">> Authenticating to Keycloak (realm: master)" >&2
+$KCADM config credentials --server http://localhost:8080 --realm master \
+  --user "$KC_ADMIN" --password "$KC_ADMIN_PASSWORD" >&2
+
+# ---------------------------------------------------------------------------
+# 1. Realm groups (authoritative role source)
+# ---------------------------------------------------------------------------
+echo ">> Ensuring realm groups" >&2
+
+users_gid=$($KCADM get groups -r "$REALM" -q name=audiobookshelf-users --fields id,name -c 1 2>/dev/null | docker exec -i keycloak python3 -c 'import sys,json;d=json.load(sys.stdin);print(d[0]["id"] if d else "")' 2>/dev/null || true)
+if [[ -z "$users_gid" ]]; then
+  users_gid=$($KCADM create groups -r "$REALM" -s name=audiobookshelf-users 2>/dev/null | tr -d '"')
+  echo "   created group audiobookshelf-users -> $users_gid" >&2
+fi
+
+admins_gid=$($KCADM get groups -r "$REALM" -q name=audiobookshelf-admins --fields id,name -c 1 2>/dev/null | docker exec -i keycloak python3 -c 'import sys,json;d=json.load(sys.stdin);print(d[0]["id"] if d else "")' 2>/dev/null || true)
+if [[ -z "$admins_gid" ]]; then
+  admins_gid=$($KCADM create groups -r "$REALM" -s name=audiobookshelf-admins -s parentId="$users_gid" 2>/dev/null | tr -d '"')
+  echo "   created group audiobookshelf-admins (child of users) -> $admins_gid" >&2
+fi
+
+# ---------------------------------------------------------------------------
+# 2. Client (confidential, Authorization Code flow)
+# ---------------------------------------------------------------------------
+echo ">> Ensuring client $CLIENT_ID" >&2
+cid=$($KCADM get clients -r "$REALM" -q clientId="$CLIENT_ID" --fields id,clientId -c 1 2>/dev/null | docker exec -i keycloak python3 -c 'import sys,json;d=json.load(sys.stdin);print(d[0]["id"] if d else "")' 2>/dev/null || true)
+
+if [[ -z "$cid" ]]; then
+  cid=$($KCADM create clients -r "$REALM" \
+    -s clientId="$CLIENT_ID" \
+    -s enabled=true \
+    -s protocol=openid-connect \
+    -s publicClient=false \
+    -s bearerOnly=false \
+    -s standardFlowEnabled=true \
+    -s directAccessGrantsEnabled=false \
+    -s implicitFlowEnabled=false \
+    -s serviceAccountsEnabled=false \
+    -s frontchannelLogout=true \
+    -s rootUrl="$ABS_URL" \
+    -s baseUrl=/ \
+    -s adminUrl="$CALLBACK" \
+    -s 'redirectUris=["'"$CALLBACK"'"]' \
+    -s 'post.logout.redirect.uris=["'"$POST_LOGOUT"'"]' \
+    -s 'webOrigins=["'"$ABS_URL"'"]' \
+    2>/dev/null | tr -d '"')
+  echo "   created client -> $cid" >&2
+else
+  echo "   client already exists -> $cid" >&2
+fi
+
+# ---------------------------------------------------------------------------
+# 3. Client roles + group→role mapping
+#    audiobookshelf-users  -> client role `guest`  (ABS read-only)
+#    audiobookshelf-admins -> client role `admin`  (ABS administrator)
+# ---------------------------------------------------------------------------
+echo ">> Ensuring client roles and group mappings" >&2
+
+for role in admin guest; do
+  if ! $KCADM get clients/"$cid"/roles/"$role" -r "$REALM" >/dev/null 2>&1; then
+    $KCADM create clients/"$cid"/roles -r "$REALM" -s name="$role" >&2
+  fi
+done
+
+admin_role_id=$($KCADM get clients/"$cid"/roles/admin -r "$REALM" --fields id -c 1 2>/dev/null | docker exec -i keycloak python3 -c 'import sys,json;print(json.load(sys.stdin)["id"])' 2>/dev/null)
+guest_role_id=$($KCADM get clients/"$cid"/roles/guest -r "$REALM" --fields id -c 1 2>/dev/null | docker exec -i keycloak python3 -c 'import sys,json;print(json.load(sys.stdin)["id"])' 2>/dev/null)
+
+# Map group -> client role (idempotent: ignore "already exists")
+$KCADM create groups/"$users_gid"/role-mappings/clients/"$cid" -r "$REALM" \
+  -b "[{\"id\":\"$guest_role_id\",\"name\":\"guest\",\"clientRole\":true,\"containerId\":\"$cid\"}]" 2>/dev/null || true
+$KCADM create groups/"$admins_gid"/role-mappings/clients/"$cid" -r "$REALM" \
+  -b "[{\"id\":\"$admin_role_id\",\"name\":\"admin\",\"clientRole\":true,\"containerId\":\"$cid\"}]" 2>/dev/null || true
+
+# ---------------------------------------------------------------------------
+# 4. Protocol mappers
+#    groups   -> real Keycloak group names (audit / admission transparency)
+#    abs_role -> ABS-consumed role tokens (admin|guest) derived from groups
+# ---------------------------------------------------------------------------
+echo ">> Ensuring protocol mappers" >&2
+
+has_mapper() { $KCADM get clients/"$cid"/protocol-mappers/models -r "$REALM" -q name="$1" --fields name -c 1 2>/dev/null | docker exec -i keycloak python3 -c 'import sys,json;d=json.load(sys.stdin);print("yes" if d else "no")' 2>/dev/null; }
+
+if [[ "$(has_mapper audiobookshelf-groups)" != "yes" ]]; then
+  $KCADM create clients/"$cid"/protocol-mappers/models -r "$REALM" -b '{
+    "name":"audiobookshelf-groups",
+    "protocol":"openid-connect",
+    "protocolMapper":"oidc-group-membership-mapper",
+    "config":{
+      "claim.name":"groups",
+      "jsonType.label":"String",
+      "full.path":"false",
+      "id.token.claim":"true",
+      "access.token.claim":"true",
+      "userinfo.token.claim":"true"
+    }
+  }' >&2
+fi
+
+if [[ "$(has_mapper audiobookshelf-roles)" != "yes" ]]; then
+  $KCADM create clients/"$cid"/protocol-mappers/models -r "$REALM" -b '{
+    "name":"audiobookshelf-roles",
+    "protocol":"openid-connect",
+    "protocolMapper":"oidc-role-membership-mapper",
+    "config":{
+      "claim.name":"abs_role",
+      "jsonType.label":"String",
+      "id.token.claim":"true",
+      "access.token.claim":"true",
+      "userinfo.token.claim":"true",
+      "role":"admin",
+      "role":"guest"
+    }
+  }' >&2
+fi
+
+# ---------------------------------------------------------------------------
+# 5. Seed Michael as admin (member of BOTH groups)
+# ---------------------------------------------------------------------------
+echo ">> Ensuring $ADMIN_USER is member of both groups" >&2
+uid=$($KCADM get users -r "$REALM" -q username="$ADMIN_USER" --fields id -c 1 2>/dev/null | docker exec -i keycloak python3 -c 'import sys,json;d=json.load(sys.stdin);print(d[0]["id"] if d else "")' 2>/dev/null || true)
+if [[ -n "$uid" ]]; then
+  $KCADM update users/"$uid"/groups/"$users_gid" -r "$REALM" \
+    -b "{\"realm\":\"$REALM\",\"userId\":\"$uid\",\"groupId\":\"$users_gid\"}" >/dev/null 2>&1 || true
+  $KCADM update users/"$uid"/groups/"$admins_gid" -r "$REALM" \
+    -b "{\"realm\":\"$REALM\",\"userId\":\"$uid\",\"groupId\":\"$admins_gid\"}" >/dev/null 2>&1 || true
+else
+  echo "   WARNING: user '$ADMIN_USER' not found in realm; add a real person to both groups manually." >&2
+fi
+
+# ---------------------------------------------------------------------------
+# 6. Emit the client secret — ONCE, to stdout only.
+# ---------------------------------------------------------------------------
+SECRET=$($KCADM get clients/"$cid"/client-secret -r "$REALM" 2>/dev/null | docker exec -i keycloak python3 -c 'import sys,json;print(json.load(sys.stdin)["value"])' 2>/dev/null)
+
+echo "----------------------------------------------------------------------" >&2
+echo "Keycloak client '$CLIENT_ID' provisioned in realm '$REALM'." >&2
+echo "Capture the secret below into the ABS runtime secret store NOW." >&2
+echo "It will NOT be shown again and is never written to disk by this script." >&2
+echo "----------------------------------------------------------------------" >&2
+printf '%s\n' "$SECRET"
