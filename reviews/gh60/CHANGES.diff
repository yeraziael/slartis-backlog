@@ -0,0 +1,40 @@
+#!/usr/bin/env bash
+#
+# rotate-keycloak-secret.sh — GH-60 §10.6: rotate the Audiobookshelf OIDC
+# client secret in Keycloak and emit the NEW secret (stdout only).
+#
+# After running this, re-apply ABS settings with the new secret
+# (apply-abs-settings.sh with OIDC_CLIENT_SECRET set) and restart the
+# audiobookshelf container so the cached OIDC client picks up the new secret.
+#
+# SECURITY: the new secret is printed ONCE to stdout and is NEVER written to
+# a file, log, or repository. Run WITHOUT `set -x`.
+#
+set -euo pipefail
+if [[ ${-:-} == *x* ]]; then
+  echo "Refusing to run with 'set -x' (would leak the secret). Aborting." >&2
+  exit 1
+fi
+
+REALM="homelab"
+CLIENT_ID="audiobookshelf"
+KC_ADMIN="${KC_ADMIN:?KC_ADMIN must be set}"
+KC_ADMIN_PASSWORD="${KC_ADMIN_PASSWORD:?KC_ADMIN_PASSWORD must be set}"
+
+KCADM="docker exec -i keycloak /opt/keycloak/bin/kcadm.sh"
+$KCADM config credentials --server http://localhost:8080 --realm master \
+  --user "$KC_ADMIN" --password "$KC_ADMIN_PASSWORD" >&2
+
+cid=$($KCADM get clients -r "$REALM" -q clientId="$CLIENT_ID" --fields id -c 1 2>/dev/null | docker exec -i keycloak python3 -c 'import sys,json;print(json.load(sys.stdin)[0]["id"])' 2>/dev/null)
+
+# Rotate: POST to the client-secret endpoint regenerates the credential.
+NEW=$($KCADM create clients/"$cid"/client-secret -r "$REALM" 2>/dev/null | docker exec -i keycloak python3 -c 'import sys,json;print(json.load(sys.stdin)["value"])' 2>/dev/null)
+
+echo "----------------------------------------------------------------------" >&2
+echo "New client secret for '$CLIENT_ID' generated." >&2
+echo "1) Store it in the ABS runtime secret store." >&2
+echo "2) Re-apply ABS settings (apply-abs-settings.sh)." >&2
+echo "3) Restart the audiobookshelf container." >&2
+echo "4) Verify login with old secret FAILS and new secret WORKS." >&2
+echo "----------------------------------------------------------------------" >&2
+printf '%s\n' "$NEW"
